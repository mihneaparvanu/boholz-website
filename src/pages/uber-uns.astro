---
import Layout from "@/layouts/Layout.astro";
import { getMediaURL } from "@/lib/media";

import PageHero from "@/ui/sections/PageHero.astro";
import CTASection from "@/ui/sections/CTASection.astro";
import PrinciplesGrid from "@/ui/sections/PrinciplesGrid.astro";
import EyebrowHeadingLede from "@/ui/primitives/EyebrowHeadingLede.astro";
import PullQuote from "@/ui/primitives/PullQuote.astro";
import Divider from "@/ui/primitives/Divider.astro";
import StatBlock from "@/ui/primitives/StatBlock.vue";
import Button from "@/ui/primitives/Button.vue";
import LiteYouTube from "@/features/advantage/LiteYouTube.vue";
import PremiumPartnerBadge from "@/ui/icons/PremiumPartnerBadge.vue";
import { HeartHandshake, Compass, HardHat } from "lucide-vue-next";
import { keitel, keitelArray } from "@/features/faq/keitel";
import { whatWeDoItems } from "./uber-uns.content";

// "So entsteht ein Keitel-Haus" — https://www.youtube.com/watch?v=4zgslK2L3po
const KEITEL_VIDEO_ID = "4zgslK2L3po";
// Hotlinked from YouTube's CDN. If we later want a normalised R2 asset, swap
// to `getMediaURL("/images/pages/uber-uns/keitel-video-poster.webp")`.
const keitelVideoPoster = `https://i.ytimg.com/vi/${KEITEL_VIDEO_ID}/maxresdefault.jpg`;
const keitelIntroProse = keitelArray("uberUnsKeitelIntroProse");
---

<Layout title="Über Uns – BoHolz Haus">
  <div class="full-width">
    <PageHero
      eyebrow="Über uns"
      title="Zwei starke Partner."
      highlight="Ein Verbund aus fachlicher Kompetenz, Wissen und jahrelanger Erfahrung."
      subtitle="Genauso will ich wohnen."
      image={getMediaURL("/images/pages/uber-uns/hero-partner-2000x776.webp")}
      imageAlt="BoHolz und Keitel-Haus — zwei Familienunternehmen, ein Maßstab"
      align="center"
    />
  </div>

  <!-- 02 — Zwei starke Partner -->

  <section id="partner" class="section">
    <EyebrowHeadingLede
      heading="Ein Verbund aus fachlicher Kompetenz,"
      highlight="Wissen und jahrelanger Erfahrung."
      lede={keitel("uberUnsPartnerLede")}
    >
      <Fragment slot="eyebrow-icon">
        <HeartHandshake :size={14} :stroke-width={2} />
      </Fragment>
    </EyebrowHeadingLede>

    <div class="prose">
      <aside class="lede-badge" aria-label="BoHolz × Keitel-Haus Premium Partner">
        <PremiumPartnerBadge client:visible width="120px" />
      </aside>

      <p class="lead">
        <i class="open">{keitel("uberUnsLeadProseOpener")}</i>
        {" "}{keitel("uberUnsLeadProse")}
      </p>

      <p>{keitel("uberUnsLeadProseSecond")}</p>

      <blockquote class="pull">
        {keitel("uberUnsPartnerPullQuote")}
      </blockquote>
    </div>

    {/* Service-steps ladder — closes the partner section with the four
        concrete deliverables that follow the "Grundstein" pull-quote.
        Lives *outside* `.prose` so it escapes the 70ch editorial measure
        and reads at the section's natural width — a structural beat,
        not a paragraph. `PrinciplesGrid` is the editorial-quiet cadence
        (no boxes, numbered 01–04, hairlines only) that mirrors the
        "Vier Schritte zu Ihrem BoHolz-Haus" framing without adding a
        second heading. Item shape: PrinciplesGrid expects `body`, the
        content file authors `description` — map inline so the data file
        stays consistent with any other consumer that uses the icon. */}
    <div class="steps">
      <PrinciplesGrid
        columns={2}
        items={whatWeDoItems.map(({ label, description }) => ({
          label,
          body: description ?? "",
        }))}
      />
    </div>
  </section>


  <!-- 04 — Unser starker Partner Keitel-Haus -->
  <section id="keitel" class="section">
    <EyebrowHeadingLede
      heading={keitel("uberUnsKeitelHeading")}
      highlight={keitel("uberUnsKeitelHighlight")}
      lede={keitel("uberUnsKeitelLede")}
    >
      <Fragment slot="eyebrow-icon">
        <HardHat :size={14} :stroke-width={2} />
      </Fragment>
    </EyebrowHeadingLede>

    <div class="prose">
      <aside class="lede-badge" aria-label="BoHolz × Keitel-Haus Premium Partner">
        <PremiumPartnerBadge client:visible width="120px" />
      </aside>

      {keitelIntroProse.map((p) => <p>{p}</p>)}

      <p>
        Auch spezielle Wünsche wie Kombinationen von Wohn- und Arbeitsbereichen
        oder individuelle Erweiterungen setzt Keitel Haus mit seinem Partner
        BoHolz Haus gerne um. Ein weiterer Vorteil für alle Bauherren:
      </p>
    </div>

    <dl class="keitel-values">
      <div class="value-pair">
        <dt>Tradition</dt>
        <dd>
          Als Familienunternehmen mit 90-jähriger Geschichte legt Keitel Haus
          großen Wert auf eine Unternehmenskultur, die auf festen Prinzipien
          beruht.
        </dd>
      </div>
      <div class="value-pair">
        <dt>Qualität</dt>
        <dd>
          Qualität geht vor Quantität, Individualität vor
          Standardlösungen, umfassende Beratung vor Überredung,
          transparente Baubeschreibung vor Kleingedrucktem.
        </dd>
      </div>
      <div class="value-pair">
        <dt>Sicherheit</dt>
        <dd>
          Als finanziell solides Unternehmen, das ausschließlich mit eigenen
          Mitteln operiert, ist Keitel-Haus unabhängig von externen
          Finanzierungspartnern.
        </dd>
      </div>
      <div class="value-pair">
        <dt>Nachhaltigkeit</dt>
        <dd>
          Das ist gerade in der heutigen Zeit enorm wichtig und gibt Ihnen die
          nötige Sicherheit. So fließen alle Ressourcen gezielt in die Qualität,
          Nachhaltigkeit und Ausstattung der Häuser.
        </dd>
      </div>
    </dl>

    <div class="video-wrap">
      <LiteYouTube
        client:visible
        videoId={KEITEL_VIDEO_ID}
        posterURL={keitelVideoPoster}
        label={keitel("uberUnsKeitelVideoLabel")}
        caption={keitel("uberUnsKeitelVideoCaption")}
      />
    </div>
  </section>
 <!-- Stats -->
  <section class="stats" aria-label="BoHolz in Zahlen">
    <StatBlock
      value="90+"
      label="Jahre Holzbau"
      caption={keitel("uberUnsStatCaption")}
      icon="award"
      client:visible
    />
    <StatBlock
      value="2"
      label="Familienunternehmen"
      caption="Vertrieb und Produktion aus einer Hand — von Bad Kissingen bis Baden-Württemberg."
      icon="heart-handshake"
      client:visible
    />
    <StatBlock
      value="100%"
      label="Holz"
      caption="Jedes BoHolz-Haus wird in Holz gebaut. Keine Stilfrage, ein Bekenntnis."
      icon="tree-deciduous"
      client:visible
    />
  </section>

  <!-- Unsere Werte (alternating tone — secondary band) -->

  <div class="band full-width">
    <section id="werte" class="section band-inner">
      <EyebrowHeadingLede
        eyebrow="Unsere Werte"
        heading="Planung für Sie —"
        highlight="nicht für eine Zielgruppe."
        lede="Ein Haus ist eine Entscheidung fürs Leben. Deshalb planen wir nach Ihren Maßen, Ihren Gewohnheiten, Ihrer Lebenslage."
      >
        <Fragment slot="eyebrow-icon">
          <Compass :size={14} :stroke-width={2} />
        </Fragment>
      </EyebrowHeadingLede>

      <div class="prose">
        <p>
          Jedes BoHolz-Haus wird in Holz gebaut. Das ist keine Stilfrage, sondern
          ein Bekenntnis zur Nachhaltigkeit. Wir sind in Bad Kissingen zuhause,
          am Rand der bayerischen Rhön. Wer hier lebt, sucht keinen anderen
          Baustoff als Holz — robust, atmungsaktiv, im Alter schöner als am
          ersten Tag.
        </p>
      </div>
    </section>
  </div>

  <!-- 05 — Value image triptych -->
  <section class="values-grid full-width" aria-label="Unsere Werte in Bildern">
    <figure>
      <img
        src={getMediaURL("/images/pages/uber-uns/value-1.webp")}
        alt="Individuelle Planung — jedes Haus exakt nach Maß"
        loading="lazy"
        width="800"
        height="500"
      />
    </figure>
    <figure>
      <img
        src={getMediaURL("/images/pages/uber-uns/value-2.webp")}
        alt="Nachhaltige Holzbauweise — natürlich, atmungsaktiv, langlebig"
        loading="lazy"
        width="800"
        height="500"
      />
    </figure>
    <figure>
      <img
        src={getMediaURL("/images/pages/uber-uns/value-3.webp")}
        alt="Persönliche Beratung — ein Ansprechpartner durchgängig"
        loading="lazy"
        width="800"
        height="500"
      />
    </figure>
  </section>

  <!-- 06 — Pull quote -->
  <section class="quote-section">
    <PullQuote
      quote="Qualität vor Quantität. Individualität vor Standard. Beratung vor Überredung."
      author={keitel("uberUnsQuoteAuthor")}
      role="Drei Prinzipien, an denen sich alles misst"
      align="center"
    />
  </section>

  <!-- 08 — CTA -->
  <!-- Wrapped in `.full-width` so the CTA escapes the wrapper's content
       column and spans the full viewport — mirrors `bauen-mit-boholz.astro`
       and `ihr-neues-zuhause.astro`. -->
  <div class="full-width">
    <CTASection
      title="Lernen wir uns"
      highlight="kennen."
      subtitle="Ein Erstgespräch — unverbindlich, kostenfrei. Persönlich in Bad Kissingen oder in einem unserer Vertriebsbüros."
    >
      <Fragment slot="actions">
        <Button variant="primary" size="lg" href="/kontakt" client:visible>
          Beratungstermin vereinbaren
        </Button>
        <Button
          variant="secondary"
          size="lg"
          href="/vor-ort-beratung"
          client:visible
        >
          Standort finden
        </Button>
      </Fragment>
    </CTASection>
  </div>
</Layout>

<style>
  /* ============================================================
     Section rhythm.
     Pages composed in `<main class="wrapper">` — direct children
     land in the `content` grid column unless they declare
     `.full-width`. We give every content `section` a generous
     block padding so the page reads as a sequence of paced
     beats rather than a wall of text.
     ============================================================ */
  .section {
    padding-block: var(--spacing-5);
  }

  /* Alternating-tone band — wraps every other content section in a tinted
     full-width surface. `.band.full-width` escapes the wrapper grid;
     `.band-inner` re-caps the content width and re-centres. Mirrors the
     cadence used on `unser-versprechen.astro`. */
  .band {
    background: var(--clr-surface-secondary);
    padding-inline: var(--padding-inline);
  }

  .band-inner {
    max-width: var(--content-max-width);
    margin-inline: auto;
    width: 100%;
  }

  /* Prose column — kept narrow so editorial copy holds a
     comfortable measure independent of the wrapper width. */
  .prose {
    max-width: 70ch;
    margin-block-start: var(--spacing-4);
    color: var(--clr-content-secondary);
  }

  .prose p {
    margin: 0;
  }

  .prose p + p {
    margin-block-start: var(--spacing-3);
  }

  /* ── Lead paragraph: editorial drop-cap from tablet up.
        On mobile, no drop-cap (it cramps the column); instead the
        opening sentence reads in italic Instrument-Serif
        (`<i class="open">`) to mark the manifesto-ish entry. ── */
  .prose .lead {
    color: var(--clr-content-primary);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
  }

  .prose .lead .open {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
    color: var(--clr-content-primary);
  }

  @media (--from-tablet) {
    /* Drop-cap kicks in at tablet — one editorial flourish per page.
       The italic Instrument-Serif initial drops three lines into the
       paragraph; we keep optical adjustments narrow (padding-inline-end
       slightly less than spacing-2 reads better at the cap's optical
       weight) — comment in case a future polish pass wants to tune. */
    .prose .lead {
      /* Reset the lead back to body-size at tablet so the drop-cap
         doesn't fight an already-enlarged paragraph. */
      font-size: var(--fs-body);
    }

    .prose .lead .open {
      /* On tablet+, the italic opening is no longer the only marker —
         the drop-cap carries the editorial weight — so the inline
         italic sits in the body colour instead of competing. */
      font-family: var(--font-secondary);
      color: var(--clr-content-primary);
    }

    .prose .lead::first-letter {
      font-family: var(--font-secondary);
      font-style: italic;
      font-weight: var(--font-weight-regular);
      font-size: 4.5em;
      line-height: 1;
      float: inline-start;
      padding-inline-end: var(--spacing-2);
      padding-block-start: 0.05em;
      color: var(--clr-content-primary);
    }
  }

  /* ============================================================
     Stats row — three StatBlocks under the partner section.
     Stacked on mobile, three-up from tablet.
     ============================================================ */
  .stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    padding-block: var(--spacing-5);
  }

  @media (--from-tablet) {
    .stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-5);
    }
  }

  /* ============================================================
     Value triptych — full-width image row.
     `.full-width` escapes the wrapper's content column so the
     images bleed to the page padding edges; the inner grid
     re-establishes consistent column gaps.
     ============================================================ */
  .values-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2);
    padding-block: var(--spacing-5);
    padding-inline: var(--padding-inline);
  }

  @media (--from-tablet) {
    .values-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-3);
    }
  }

  .values-grid figure {
    margin: 0;
  }

  .values-grid img {
    width: 100%;
    height: auto;
    aspect-ratio: 8 / 5;
    object-fit: cover;
    /* Inner radius slightly smaller than section-level
       cards (no outer container here, so radius-lg reads as
       the editorial-image standard). */
    border-radius: var(--radius-lg);
    display: block;
  }

  /* ============================================================
     PullQuote section — narrows visually, breathing block padding
     so the quote lands as its own beat between sections.
     ============================================================ */
  .quote-section {
    padding-block: var(--spacing-6);
  }

  /* Service-steps ladder — sits between the partner prose and the
     stats row. Breathing room above so the hairlines don't fight the
     pull-quote's left rule; the section's own block padding plus the
     stats row's padding handle the gap below. */
  .steps {
    margin-block-start: var(--spacing-5);
  }

  /* Keitel partner section video frame — sits below the prose with
     extra breathing room, bounded so it doesn't outgrow the column
     on wide viewports. */
  .video-wrap {
    margin-block-start: var(--spacing-5);
    max-width: 64rem;
    margin-inline: auto;
  }

  .keitel-values {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin-block-start: var(--spacing-5);
    border-block-start: 1px solid var(--clr-border-secondary);
  }

  @media (--from-tablet) {
    .keitel-values {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .value-pair {
    border-block-end: 1px solid var(--clr-border-secondary);
    padding: var(--spacing-4) var(--spacing-3) var(--spacing-4) 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    min-width: 0;
  }

  @media (--from-tablet) {
    .value-pair {
      padding: var(--spacing-4);
      border-inline-start: 1px solid var(--clr-border-secondary);
    }
    .value-pair:nth-child(odd) {
      border-inline-start: 0;
    }
  }

  .value-pair dt {
    font-size: var(--fs-h5);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--ls-heading);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }

  .value-pair dd {
    margin: 0;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--clr-content-secondary);
  }

  /* ── Lede badge cameo: floats right inside the prose column so the
        Premium-Partner SVG sits alongside the opening copy. On mobile
        the float collapses to a centered block above the prose so the
        narrow column doesn't choke on a 120px aside. ── */
  .lede-badge {
    float: inline-end;
    width: 120px;
    margin-inline-start: var(--spacing-4);
    margin-block-end: var(--spacing-2);
    shape-outside: margin-box;
  }

  @media (--mobile) {
    .lede-badge {
      float: none;
      display: flex;
      justify-content: center;
      width: auto;
      margin: 0 auto var(--spacing-3);
    }
  }

  /* ── Pull-quote callout: serif italic sentence pulled from the body
        copy, left rule for emphasis. Sits between paragraphs to break
        rhythm and give the section a visual handhold. ── */
  .pull {
    border-inline-start: 2px solid var(--clr-border-secondary);
    padding-inline-start: var(--spacing-3);
    margin-block: var(--spacing-4);
    margin-inline: 0;
    font-family: var(--font-secondary);
    font-style: italic;
    font-size: var(--fs-body-lg);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }
</style>
