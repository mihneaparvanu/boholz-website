---
import Layout from "@/layouts/Layout.astro";
import LocationsMap from "@/features/locations/LocationsMap.vue";
import CTASection from "@/ui/sections/CTASection.astro";
import EyebrowHeadingLede from "@/ui/primitives/EyebrowHeadingLede.astro";
import VideoPlaceholder from "@/ui/primitives/VideoPlaceholder.vue";
import { Building2, Home, MapPin, Phone, Mail, ArrowRight } from "lucide-vue-next";
import { getLocations } from "@/db/loaders";
import { getMediaURL } from "@/lib/media";
import { ROUTES } from "@/features/navigation/routes";
import { musterhaeuser } from "./vor-ort-beratung.content";

const locations = await getLocations();

// Match showhouse content cards by slug to live DB locations so each card
// can render the matching location's hero image. Falls back to the existing
// VideoPlaceholder when no hero is found.
const showhouseHeroBySlug = new Map<string, string>(
  locations
    .filter((l) => l.kind === "showhouse")
    .flatMap((l) => {
      const hero = l.media.find((m) => m.isHero)?.media.path;
      return hero ? [[l.slug, hero] as const] : [];
    }),
);

// München's hero in the DB duplicates Villingen-Schwenningen. Override to a
// distinct einfamilienhaus image until the seed is corrected upstream.
const OFFICE_HERO_OVERRIDES: Record<string, string> = {
  "vertriebsbuero-muenchen":
    "/images/models/einfamilienhaus/22-162-190/gallery/einfamilienhaus-22-162-190-gallery-efh-ho-166-22-190-betonoptikfassade.webp",
};

// Vertriebsbüros + Zentrale come straight from the DB. HQ leads, the rest
// follow alphabetically by title. Offices with no phone, email, and no agent
// are dropped per the client brief (only the Eltville stub today).
const offices = locations
  .filter((l) => l.kind === "office" || l.kind === "headquarters")
  .filter((l) => l.phone || l.email || l.agents.length > 0)
  .sort((a, b) => {
    if (a.kind === "headquarters") return -1;
    if (b.kind === "headquarters") return 1;
    return a.title.localeCompare(b.title, "de");
  })
  .map((l) => {
    const heroFromDB = l.media.find((m) => m.isHero)?.media.path ?? null;
    const heroOverride = OFFICE_HERO_OVERRIDES[l.slug];
    const heroSrc = heroOverride ? getMediaURL(heroOverride) : heroFromDB;
    return {
      slug: l.slug,
      name: l.title,
      address: [l.address, [l.postalCode, l.city].filter(Boolean).join(" ")]
        .filter(Boolean)
        .join(", "),
      heroSrc,
      phone: l.phone,
      email: l.email,
      agents: l.agents.map((a) => a.agent),
    };
  });

const mapsURL = (address: string): string =>
  `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;

const telHref = (s: string): string => `tel:${s.replace(/[^\d+]/g, "")}`;
---

<Layout title="Vor-Ort-Beratung – BoHolz Haus">
  <!-- Map first — full-width hero-style -->
  <div class="map-hero full-width">
    <LocationsMap client:only="vue" locations={locations} />
  </div>

  <!-- Musterhäuser -->
  <section id="musterhaeuser" class="page-section">
    <EyebrowHeadingLede
      eyebrow="Musterhäuser"
      heading="Häuser zum"
      highlight="Anfassen."
      lede="Spüren Sie Materialien, Wandstärken und Lichtführung vor Ort."
    >
      <Fragment slot="eyebrow-icon">
        <Home :size={14} :stroke-width={2} />
      </Fragment>
    </EyebrowHeadingLede>

    <div class="card-grid musterhaus-grid">
      {
        musterhaeuser.map((h) => {
          const heroSrc = showhouseHeroBySlug.get(h.slug);
          return (
            <a class="musterhaus" href={ROUTES.musterhaus(h.slug)}>
              {heroSrc ? (
                <figure class="cover">
                  <img
                    src={heroSrc}
                    alt={`${h.name} – Außenansicht`}
                    loading="lazy"
                    width="800"
                    height="450"
                  />
                </figure>
              ) : (
                <VideoPlaceholder
                  client:visible
                  slotId={`musterhaus-${h.slug}`}
                  aspectRatio="16/9"
                  variant="film"
                  label="Bildmaterial folgt"
                />
              )}
              <header class="head">
                <h3 class="name">{h.name}</h3>
                <p class="region">{h.state}</p>
              </header>
              <p class="body">{h.address}</p>
              <span class="more">
                Musterhaus besuchen
                <ArrowRight :size={14} :stroke-width={2} aria-hidden="true" />
              </span>
            </a>
          );
        })
      }
    </div>
  </section>

  <!-- Vertriebsbüros -->
  <section id="bueros" class="page-section">
    <EyebrowHeadingLede
      eyebrow="Vertriebsbüros"
      heading="Zehn Standorte,"
      highlight="ein Anspruch."
      lede="Von Bonndorf im Schwarzwald bis München — Beratung in Wohnortnähe, mit der Zentrale in Bad Kissingen."
    >
      <Fragment slot="eyebrow-icon">
        <Building2 :size={14} :stroke-width={2} />
      </Fragment>
    </EyebrowHeadingLede>

    <ul class="card-grid office-grid" role="list">
      {
        offices.map((o) => (
          <li>
            <article class="office">
              {o.heroSrc && (
                <figure class="office-cover">
                  <img
                    src={o.heroSrc}
                    alt={`${o.name} – Hausreferenz`}
                    loading="lazy"
                    width="600"
                    height="400"
                  />
                </figure>
              )}
              <span class="office-icon" aria-hidden="true">
                <Building2 :size={18} :stroke-width={1.75} />
              </span>
              <h3 class="office-name">{o.name}</h3>
              <p class="office-address">
                <span class="address-glyph" aria-hidden="true">
                  <MapPin :size={14} :stroke-width={1.75} />
                </span>
                <span>{o.address}</span>
              </p>

              {o.agents.length > 0 && (
                <section class="agents" aria-label="Ansprechpartner">
                  <h4 class="agents-heading">Ansprechpartner</h4>
                  <ul class="agents-list" role="list">
                    {o.agents.map((a) => (
                      <li class="agent">
                        <div class="agent-name">{a.fullName}</div>
                        {a.role && <div class="agent-role">{a.role}</div>}
                        <div class="agent-contact">
                          {a.phoneNumber && (
                            <a href={telHref(a.phoneNumber)}>
                              <Phone :size={12} :stroke-width={1.75} aria-hidden="true" />
                              <span>{a.phoneNumber}</span>
                            </a>
                          )}
                          {a.email && (
                            <a href={`mailto:${a.email}`}>
                              <Mail :size={12} :stroke-width={1.75} aria-hidden="true" />
                              <span>{a.email}</span>
                            </a>
                          )}
                        </div>
                      </li>
                    ))}
                  </ul>
                </section>
              )}

              <a
                class="office-link"
                href={mapsURL(o.address)}
                target="_blank"
                rel="noopener noreferrer"
              >
                Standort öffnen
                <span class="arrow" aria-hidden="true">→</span>
              </a>
            </article>
          </li>
        ))
      }
    </ul>
  </section>

  <CTASection
    tone="surface"
    title="Termin vereinbaren —"
    highlight="auf Wunsch außerhalb der Öffnungszeiten."
    subtitle="Schreiben Sie uns kurz, wann es Ihnen passt. Wir melden uns meist binnen 24 Stunden."
  >
    <a slot="actions" class="cta-btn primary" href="/kontakt">
      Beratungstermin vereinbaren
    </a>
    <a slot="actions" class="cta-btn ghost" href="tel:+49971785557150">
      0971 / 78 55 57 15
    </a>
  </CTASection>
</Layout>

<style>
  /* ---------- Section rhythm ----------
     Each top-level section gets generous vertical breathing room and a hairline
     divider — matches the SectionNavigator sandbox pattern. */
  .page-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
    padding-block: var(--spacing-6);
    border-block-start: 1px solid var(--clr-border-secondary);
  }

  .page-section:first-of-type {
    border-block-start: none;
  }

  /* ---------- Map hero ---------- */
  .map-hero {
    width: 100%;
    padding-inline: 0;
  }

  .map-hero :global(.map-wrapper) {
    height: 70vh;
    min-height: 420px;
    border-radius: 0;
  }

  @media (--from-desktop) {
    .map-hero :global(.map-wrapper) {
      height: 82vh;
      max-height: 860px;
    }
  }

  /* ---------- Card grids ----------
     One responsive grid pattern shared by Musterhäuser and Vertriebsbüros. */
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  @media (--from-tablet) {
    .card-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (--from-desktop) {
    .office-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  /* ---------- Musterhaus card ----------
     Whole card is the link target — image, copy, and "Musterhaus besuchen"
     affordance all sit inside one <a>. */
  .musterhaus {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    text-decoration: none;
    color: inherit;
    transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .musterhaus:hover .cover img,
  .musterhaus:focus-visible .cover img {
    transform: scale(1.02);
  }

  .musterhaus:focus-visible {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 4px;
    border-radius: var(--radius-lg);
  }

  .musterhaus .more {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    margin-block-start: calc(var(--spacing-2) * -1);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
    transition: gap 200ms cubic-bezier(0.16, 1, 0.3, 1), color 160ms ease;
  }

  .musterhaus:hover .more,
  .musterhaus:focus-visible .more {
    gap: var(--spacing-2);
    color: var(--clr-accent-secondary);
  }

  /* Card cover image — matches the VideoPlaceholder it replaces (16:9,
     lg radius) so existing card rhythm/padding stays intact. */
  .musterhaus .cover {
    margin: 0;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--clr-surface-secondary);
  }

  .musterhaus .cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 600ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .musterhaus .head {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-0);
  }

  .musterhaus .name {
    margin: 0;
    font-size: var(--fs-h5);
    font-weight: var(--font-weight-medium);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }

  .musterhaus .region {
    margin: 0;
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
  }

  .musterhaus .body {
    margin: 0;
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
  }

  /* ---------- Office card ----------
     Each card: building glyph, name, address-with-pin, "Standort öffnen" link.
     Surface-secondary background, secondary-border, lg radius. The link sits
     against the bottom of the card via auto-margin-top on the flex column so
     uneven addresses don't push the affordance around. */
  .office {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    height: 100%;
    padding: var(--spacing-4);
    background: var(--clr-surface-secondary);
    border: 1px solid var(--clr-border-secondary);
    border-radius: var(--radius-lg);
  }

  /* Cover image leads the card when the office has a linked house. Negative
     margins pull the image flush to the card border so the inner padding
     wraps just the text below it. */
  .office-cover {
    margin: calc(var(--spacing-4) * -1) calc(var(--spacing-4) * -1) var(--spacing-1);
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    background: var(--clr-surface-secondary);
  }

  .office-cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .office-icon {
    display: inline-grid;
    place-items: center;
    color: var(--clr-content-tertiary);
  }

  .office-name {
    margin: 0;
    font-size: var(--fs-h6);
    font-weight: var(--font-weight-medium);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }

  .office-address {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    column-gap: var(--spacing-1);
    margin: 0;
    color: var(--clr-content-secondary);
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
  }

  .address-glyph {
    display: inline-grid;
    place-items: center;
    /* Optical alignment with first line of address text. */
    padding-block-start: 0.2em;
    color: var(--clr-content-tertiary);
  }

  /* ---------- Agents block inside office card ----------
     The agent info that used to only show in the map pin popup. One block per
     office, listed in the order returned by the loader (primary first). */
  .agents {
    margin-block-start: var(--spacing-1);
    padding-block-start: var(--spacing-3);
    border-block-start: 1px solid var(--clr-border-secondary);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .agents-heading {
    margin: 0;
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow, 0.06em);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
  }

  .agents-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .agent {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .agent-name {
    font-size: var(--fs-body);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
    line-height: var(--lh-heading);
  }

  .agent-role {
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
  }

  .agent-contact {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-block-start: var(--spacing-1);
  }

  .agent-contact a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    font-size: var(--fs-body-sm);
    color: var(--clr-content-secondary);
    text-decoration: none;
    line-height: var(--lh-body);
    width: fit-content;
    transition: color 160ms ease;
  }

  .agent-contact a:hover {
    color: var(--clr-accent-secondary);
  }

  .office-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    margin-block-start: auto;
    padding-block-start: var(--spacing-2);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
    text-decoration: none;
    transition:
      color 160ms ease,
      gap 160ms ease;
  }

  .office-link .arrow {
    transition: transform 200ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .office-link:hover {
    color: var(--clr-accent-secondary);
    opacity: 1;
  }

  .office-link:hover .arrow {
    transform: translateX(2px);
  }

  .office-link:focus-visible {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  /* ---------- CTA buttons (page-local) ----------
     Two affordances inside CTASection's `actions` slot. Primary uses the
     primary accent — it's a page-level CTA on a large surface, per the
     project accent rule. Ghost is text-only, for the secondary phone link. */
  .cta-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--control-height-md);
    padding-inline: var(--spacing-3);
    border-radius: var(--radius-md);
    font-size: var(--fs-body);
    font-weight: var(--font-weight-medium);
    line-height: 1;
    text-decoration: none;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      transform 160ms ease;
  }

  .cta-btn.primary {
    background: var(--clr-accent-primary);
    color: var(--clr-pure-white);
    border: 1px solid var(--clr-accent-primary);
  }

  .cta-btn.primary:hover {
    background: var(--clr-accent-secondary);
    border-color: var(--clr-accent-secondary);
    opacity: 1;
  }

  .cta-btn.ghost {
    background: transparent;
    color: var(--clr-content-primary);
    border: 1px solid var(--clr-border-tertiary);
  }

  .cta-btn.ghost:hover {
    border-color: var(--clr-content-primary);
    opacity: 1;
  }

  .cta-btn:focus-visible {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 2px;
  }
</style>
