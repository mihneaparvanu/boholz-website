---
import Layout from "@/layouts/Layout.astro";
import HousesPage from "@/features/HousesPage/HousesPage.vue";
import { getCategories, getModels } from "@/data/loaders";
import { BESTSELLER_CATEGORY_ID } from "@/data/constants";

const [models, categories] = await Promise.all([getModels(), getCategories()]);

// Patch Bestseller with the Family 150 hero image (fallback: first featured model)
const bestsellerSourceModel =
  models.find((m) => m.title.toLowerCase().includes("family") && m.title.includes("150")) ??
  models.find((m) => m.isFeatured);
const firstFeaturedHero = bestsellerSourceModel?.media.find((m) => m.isHero);
if (firstFeaturedHero) {
  const idx = categories.findIndex((c) => c.id === BESTSELLER_CATEGORY_ID);
  if (idx !== -1) {
    categories[idx] = {
      ...categories[idx],
      media: [{ isHero: true, isThumbnail: true, media: firstFeaturedHero.media }],
    };
  }
}
---

<Layout title="Häuser – BoHolz Haus" categories={categories}>
<h1>Unsere Häuser</h1>
   <HousesPage models={models} categories={categories} client:visible />
</Layout>

