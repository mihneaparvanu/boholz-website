---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/ui/sections/PageHero.astro";
import CTASection from "@/ui/sections/CTASection.astro";
import Block from "@/ui/sections/Block.astro";
import SectionNavigator from "@/features/section-navigator/SectionNavigator.vue";
import DefinitionList, {
  type DefinitionItem,
} from "@/ui/primitives/DefinitionList.astro";
import IconList, { type IconListItem } from "@/ui/primitives/IconList.vue";
import EditorialCard from "@/ui/primitives/EditorialCard.vue";
import Button from "@/ui/primitives/Button.vue";
import { ArrowRight, BookOpen } from "lucide-vue-next";
import { getMediaURL } from "@/lib/media";
import FeatureCardPair from "@/features/advantage/FeatureCardPair.vue";
import LiteYouTube from "@/features/advantage/LiteYouTube.vue";
import ZigZag, { type ZigZagBlock } from "@/ui/sections/ZigZag.astro";
import type { FeatureCard } from "@/features/advantage/advantage.types";
import { keitel } from "@/features/faq/keitel";

// ── Section index — drives the SectionNavigator's overview + sticky rail.
const sections = [
  { id: "tradition", eyebrow: "01", label: "Tradition & Innovation" },
  { id: "beweggruende", eyebrow: "02", label: "Beweggründe" },
  { id: "gruende", eyebrow: "03", label: "16 gute Gründe" },
  { id: "nachhaltigkeit", eyebrow: "04", label: "Nachhaltigkeit" },
  { id: "holzfaserdaemmung", eyebrow: "05", label: "Holzfaserdämmung" },
  { id: "wandaufbau", eyebrow: "06", label: "Wandaufbau" },
  { id: "technik", eyebrow: "07", label: "Energietechnik" },
];

// ── R2 image URLs for the advantage subsections.
// PageHero, Section 3 media-hero, and Section 4 hero-image previously all
// resolved to the same forest webp (identical R2 etag) — three identical
// "sun-through-trees" frames on one page. They're now diversified: the page
// keeps the forest at the top, then transitions to craftsmanship and material
// detail as the reader descends.
const nachhaltigkeitHero = getMediaURL(
  "/images/stock/lifestyle/house-planning-office.webp",
);
const nachhaltigkeitManufaktur = getMediaURL(
  "/images/stock/lifestyle/craftsmanship-factory.webp",
);
const nachhaltigkeitVideoPoster = getMediaURL(
  "/images/content/advantage/nachhaltigkeit/video-poster.webp",
);
const holzfaserHero = getMediaURL("/images/photography/timber-grain.webp");
const holzfaserFlyerCover = getMediaURL(
  "/images/pages/bauen-mit-boholz/flyer-holzfaserdaemmung-cover.webp",
);
const holzfaserFlyerPDF = getMediaURL(
  "/images/pages/bauen-mit-boholz/flyer-holzfaserdaemmung.pdf",
);
const wandaufbauHero = getMediaURL(
  "/images/content/advantage/wandaufbau/hero.webp",
);

// ── Section 5 — Holzfaserdämmung side-by-side (Sommer vs Winter).
const sommer: FeatureCard = {
  eyebrow: "Sommer",
  title: "Hitzeschutz bis in die Nacht",
  lede:
    "Die Holzfaserdämmplatte verzögert sommerliche Hitze um Stunden — Schlafräume bleiben kühl, wenn die Außentemperatur kippt.",
  bullets: [
    "11 Stunden Phasenverschiebung — die Hitze kommt erst nachts an, wenn es draußen längst kühl ist",
    "92 % Temperaturpuffer gegenüber außen — der Innenraum schwingt kaum mit",
    "Hohe spezifische Wärmekapazität (2100 J/(kg·K)) — die Wand speichert, gibt langsam ab",
  ],
  icon: "sun",
  imageURL: getMediaURL(
    "/images/content/advantage/holzfaserdaemmung/sommer.webp",
  ),
  imageAlt:
    "Sommerlicher Hitzeschutz dank Holzfaserdämmung — kühles Innenklima trotz hoher Außentemperaturen",
};

const winter: FeatureCard = {
  eyebrow: "Winter",
  title: "Wärme bleibt, wo sie hingehört",
  lede:
    "Diffusionsoffen und dämmstark zugleich — die Holzfaser hält die Heizenergie im Haus und reguliert dabei die Raumfeuchte ganz natürlich.",
  bullets: [
    "Lambda-Nennwert 0,036 W/(mK) — exzellenter Dämmwert für KfW 40 / KfW 55",
    "Diffusionsoffen — Feuchtigkeit kann nach außen, ohne dass Wärme entweicht",
    "Baubiologisch hervorragend — gesundes Raumklima ohne Mineralfaser",
  ],
  icon: "thermometer",
  imageURL: getMediaURL(
    "/images/content/advantage/holzfaserdaemmung/winter.webp",
  ),
  imageAlt:
    "Winterlicher Wärmeerhalt — Holzfaserdämmung hält die Heizenergie im Haus",
};

// ── Zig-zag editorial block — copy lifted from the old boholz-haus.de
// "Bauen mit uns" page per client request. Six alternating image / text
// rows with a "Mehr erfahren" CTA each. Reuses existing R2 imagery for
// thematic fit; client can swap images later.
const zigzagBlocks: ZigZagBlock[] = [
  {
    eyebrow: "Holz rettet Klima – aktiver Klimaschutz mit Wohlfühlfaktor",
    title: "Nachhaltigkeit bei BoHolz-Haus",
    body: [
      "Lebendigkeit – das ist es, was Holz für uns als Rohstoff für den Bau Ihres Eigenheims so besonders macht. Schon seit Jahrhunderten wird Holz auch aufgrund seiner Beständigkeit verwendet.",
    ],
    closing: "Ein Baustoff, der Generationen überdauert.",
    image: getMediaURL("/images/content/advantage/nachhaltigkeit/hero.webp"),
    imageAlt: "Junger Trieb im Boden — nachhaltiger Holzbau bei BoHolz-Haus",
    cta: { href: "#nachhaltigkeit" },
  },
  {
    eyebrow: "Mit gutem Gewissen gefördert",
    title: "Ihre Förderung für den Hausbau",
    body: [
      "Staatliche Förderungen durch die Kreditanstalt für Wiederaufbau (kurz: KfW) sind immer wieder Thema. Besonders familienfreundliche Förderprogramme erfahren wachsende Beliebtheit bei künftigen Bauherrinnen und Bauherren.",
    ],
    closing: "Wir begleiten Sie durch den Antragsdschungel.",
    image: getMediaURL("/images/stock/lifestyle/smart-living.webp"),
    imageAlt:
      "Familienleben in einem modernen, energieeffizienten BoHolz-Zuhause",
    cta: { href: "/kontakt" },
  },
  {
    eyebrow: "Vier Ausbaustufen für jeden Bedarf",
    title: "Ausbaustufen für Ihr BoHolz-Haus",
    body: [
      "Jeder Bauherr ist anders. Eine Familie möchte am liebsten in ein schlüsselfertiges Haus einziehen, andere können und möchten den Innenausbau ganz oder teilweise selbst vornehmen.",
    ],
    closing: "Vom Ausbauhaus bis schlüsselfertig — Sie entscheiden.",
    image: getMediaURL("/images/stock/lifestyle/house-planning-office.webp"),
    imageAlt:
      "Schlüsselübergabe — schlüsselfertiges BoHolz-Haus nach Wunsch",
    cta: { href: "/kontakt" },
  },
  {
    eyebrow: "Von außen gut gedämmt",
    title: "Innovativer Wandaufbau mit hervorragenden Dämmeigenschaften",
    body: [
      "Die Gebäudehülle hat einen entscheidenden Einfluss auf den Energieverbrauch eines Hauses. Eine hochwertige Dämmung reduziert Wärmeverluste, senkt den Heizwärmebedarf und sorgt für dauerhaft niedrigere Energiekosten.",
      "Deshalb setzt BoHolz-Haus konsequent auf Holz als natürlichen, nachwachsenden Baustoff. In Kombination mit modernen Wandaufbauten entstehen energieeffiziente Häuser, die Nachhaltigkeit, Wohnkomfort und Wirtschaftlichkeit optimal miteinander verbinden.",
    ],
    closing: "Diffusionsoffen, leise, dauerhaft.",
    image: getMediaURL("/images/content/advantage/wandaufbau/hero.webp"),
    imageAlt:
      "ECO Nature Wandaufbau — diffusionsoffener Mehrschichtaufbau für KfW-Effizienzhäuser",
    cta: { href: "#wandaufbau" },
  },
  {
    eyebrow: "Unser oberstes Ziel ist die Zufriedenheit",
    title: "Qualität bei BoHolz-Haus",
    body: [
      "Dicht gefolgt von unserem hohen Qualitätsstandard, den wir Ihnen bieten können.",
      "Unser starker Partner Keitel-Haus greift auf jahrelanges und generationenübergreifendes Wissen rund um den Fertighausbau zurück und gewährleistet handwerkliche Wertarbeit im traditionellen Sinne.",
    ],
    closing: "Wertarbeit, die man fühlt — vom ersten Span bis zur Schlüsselübergabe.",
    image: getMediaURL("/images/stock/lifestyle/wooden-logs.webp"),
    imageAlt: "Massive Holzbalken im BoHolz Werk — traditionelle Handwerksqualität",
    cta: { href: "/uber-uns" },
  },
  {
    title: "Gute Gründe für ein BoHolz Fertighaus",
    body: [],
    bullets: [
      "Individualität als oberstes Maß",
      "Energiesparend in die Zukunft starten",
      "Ausbaustufen genau nach Ihren Bedürfnissen",
      "Gut für Ihren Geldbeutel",
      "Zeitersparnis",
      "Ihr Traumhaus made in Germany",
      "Sicherheit für Sie und Ihr Bauprojekt",
      "Unser wichtigstes Ziel: Ihre Zufriedenheit",
    ],
    image: getMediaURL("/images/stock/lifestyle/craftsmanship-factory.webp"),
    imageAlt:
      "Junges Paar entspannt im eigenen BoHolz-Wohnzimmer — gute Gründe für ein BoHolz-Fertighaus",
    cta: { label: "Beratung vereinbaren", href: "/kontakt" },
  },
];

// ── Section 6 — Wandaufbau editorial copy + Vorteile bullets.
//
// Per client brief: long block of body copy broken into bite-sized
// blocks with icons. The intro + sub-paragraph each lead with body
// colour (secondary) and finish with a highlighted last sentence in
// primary — gives the eye a beat to land on the most important line.
const wandaufbauVorteile: IconListItem[] = [
  { icon: "layers", label: "Diffusionsoffener Wandaufbau" },
  { icon: "leaf", label: "Natürliche und nachhaltige Materialien" },
  { icon: "thermometer", label: "Angenehmes Raumklima zu jeder Jahreszeit" },
  { icon: "shield", label: "Effektiver Schutz vor Feuchtigkeit und Schimmelbildung" },
];

// ── Section 6 — Wandaufbau Vergleich (ECO Nature vs ECO Nature Plus).
const ecoNature: FeatureCard = {
  eyebrow: "KfW 55",
  title: "ECO Nature",
  lede:
    "Unser Standard-Wandaufbau — diffusionsoffen, ökologisch gedämmt, Grundlage für ein KfW-Effizienzhaus 55.",
  bullets: [
    "60 mm Holzfaserdämmplatte plus 200 mm Holzrahmen mit Knauf Insulation (WLG 035)",
    "U-Wert 0,164 W/(m²K) — bereits im Standard auf KfW-55-Niveau",
    "Brandschutz F30-B, vollflächige OSB4-Beplankung, Luftdichtheitsebene",
  ],
  icon: "layers",
  imageURL: getMediaURL(
    "/images/content/advantage/wandaufbau/wandaufbau-links.webp",
