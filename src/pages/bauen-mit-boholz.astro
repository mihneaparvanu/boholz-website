---

<Layout title="Bauen mit BoHolz — BoHolz Haus">
  <!-- 0. Hero ----------------------------------------------------------- -->
  <div class="full-width">
    <PageHero
      eyebrow="Bauen mit BoHolz"
      title="Mit Vertrauen bauen, mit Qualität"
      highlight="wohnen."
      subtitle="Höchste Bauqualität. Gelebte Nachhaltigkeit. Persönliche Begleitung — vom ersten Entwurf bis zum Einzug."
      image={nachhaltigkeitHero}
      imageAlt="BoHolz Holzbau in der Manufaktur — gelebter Qualitätsanspruch"
      align="center"
    />
  </div>

  <!-- 1. Section overview + sticky rail -------------------------------- -->
  <SectionNavigator client:load pageTitle="Bauen mit BoHolz" sections={sections} stickyOffset={64} />

  <!-- 2. Tradition trifft Innovation ----------------------------------- -->
  <Block
    id="tradition"
    tone="band"
    eyebrow="01 — Tradition & Innovation"
    heading="Generationen-Handwerk, moderne"
    highlight="Fertigung."
    lede="Langjährige Erfahrung, handwerkliche Präzision und moderne Fertigungstechnologien bilden die
Grundlage unserer Häuser. So verbinden wir traditionelle Wertarbeit mit innovativen Bauweisen
– für hochwertige, nachhaltige und zukunftssichere Zuhause."
  >
    <div class="steps">
      <EditorialCard
        client:visible
        step={1}
        title="Tradition"
        icon="hammer"
        description={keitel("versprechenTraditionCard")}
      />
      <EditorialCard
        client:visible
        step={2}
        title="Moderne Fertigung"
        icon="wrench"
        description="Innovative CNC-Maschinen für präzise Fertigung, automatisierte Anlagen für effiziente Produktion und kontinuierliche Weiterentwicklung unserer Baumethoden."
      />
      <EditorialCard
        client:visible
        step={3}
        title="Zertifizierungen"
        icon="award"
        description="Mitglied der Qualitätsgemeinschaft Deutscher Fertigbau (QDF) und der Gemeinschaft Deutscher Fertigbau (GDF) — ständige Qualitätssicherung der Materialien, regelmäßige Kontrollen, Eigen- und Fremdüberwachung durch unabhängige Prüfinstitute."
      />
    </div>
  </Block>

  <!-- 2b. Sechs Beweggründe (zig-zag) — copy from the legacy WP "Bauen
       mit uns" page, redesigned with our editorial language. Lives between
       Tradition and "16 gute Gründe" so the page reads:
         01 Tradition → 02 Sechs Beweggründe (zig-zag) → 03 16 gute Gründe →
         04 Nachhaltigkeit → 05 Holzfaserdämmung → 06 Wandaufbau → 07 Technik. -->
  <Block id="beweggruende" eyebrow="02 — Sechs Beweggründe" heading="Was BoHolz-Haus" highlight="für Sie tut." lede="Sechs editoriale Beweggründe — von Nachhaltigkeit über Förderung bis zur Qualität, die hinter jedem unserer Häuser steht.">
    <ZigZag blocks={zigzagBlocks} />
  </Block>

  <!-- 3. 16 gute Gründe ------------------------------------------------ -->
  <Block
    id="gruende"
    eyebrow="03 — 16 gute Gründe"
    heading="Was in jedem BoHolz Fertighaus"
    highlight="serienmäßig steckt."
    lede="Vom diffusionsoffenen Wandaufbau bis zur barrierefreien Dusche — sechzehn Details, die wir bereits im Standard liefern."
  >
    <IconList
      client:visible
      items={sechzehnGruende}
      columns={4}
      collapsible
      moreLabel="Alle 16 Gründe anzeigen"
      lessLabel="Weniger anzeigen"
    />
  </Block>

  <!-- 4. Nachhaltigkeit — Hero + Video + Stats -------------------------- -->
  <Block
    id="nachhaltigkeit"
    tone="band"
    eyebrow="04 — Nachhaltigkeit"
    heading="Wohnträume mit aktivem"
    highlight="Umweltschutz."
    lede="Bei BoHolz Haus verbinden wir Ihre Wohnträume mit aktivem Umweltschutz. Unsere individuellen Fertighäuser aus Holz sind nicht nur Ihr persönliches Zuhause, sondern auch ein Beitrag zu einer besseren Zukunft."
  >
    <p class="editorial-prose">
      Wir bauen mit Holz, weil es der einzige Baustoff ist, der CO₂ über die
      gesamte Lebensdauer des Hauses speichert. Vom Dachstuhl bis zur
      Holzfaserdämmung — jeder Quadratmeter unserer Häuser bindet aktiv
      Kohlenstoff.
      <span class="primary">
        Ein Zuhause, das das Klima schützt, statt es zu belasten.
      </span>
    </p>

    <div class="media-pair">
      <figure class="media-hero">
        <img
          src={nachhaltigkeitManufaktur}
          alt="Nachhaltige Holzbauweise im BoHolz Werk — gelebter Umweltschutz von der Materialwahl bis zur Fertigung"
          loading="lazy"
        />
      </figure>
      <LiteYouTube
        client:visible
        videoId="0abnY3Re-tU"
        posterURL={nachhaltigkeitVideoPoster}
        label="BoHolz — Nachhaltigkeit erleben"
        caption="Wie wir bauen und warum — drei Minuten Werksrundgang."
      />
    </div>
  </Block>

  <!-- 5. Holzfaserdämmung ─ Sommer / Winter ---------------------------- -->
  <Block
    id="holzfaserdaemmung"
    eyebrow="05 — Holzfaserdämmung"
    heading="Wärmeschutz im Winter. Hitzeschutz im Sommer."
    lede="Unsere diffusionsoffene Holzfaserdämmung sorgt ganzjährig für ein angenehmes Raumklima.
Sie schützt im Sommer zuverlässig vor Hitze, speichert im Winter die Wärme im Haus und
unterstützt gleichzeitig eine natürliche Feuchtigkeitsregulierung der Wandkonstruktion."
  >
    <figure class="hero-image">
      <img
        src={holzfaserHero}
        alt="Holzfaserdämmplatten im BoHolz Wandaufbau — natürlicher Hitze- und Kälteschutz"
        loading="lazy"
      />
    </figure>
    <FeatureCardPair client:visible left={sommer} right={winter} />

     <p class="footnote">* Optionale Ausstattung — auf Wunsch verfügbar.</p>

    <!-- Print flyer · A4 PDF with cover preview + download CTA. Placed at
         the end of the Holzfaserdämmung section because the flyer's content
         is the same subject — gives the reader a take-home version. -->
    <aside class="flyer" aria-labelledby="flyer-title">
      <a class="flyer-cover" href={holzfaserFlyerPDF} target="_blank" rel="noopener">
        <img
          src={holzfaserFlyerCover}
          alt="Vorschau auf den BoHolz-Flyer: Holzfaserdämmung im Detail"
          loading="lazy"
          width="1743"
          height="2400"
        />
      </a>
      <div class="flyer-body">
        <p class="flyer-eyebrow">Print-Flyer · PDF</p>
        <h3 id="flyer-title" class="flyer-heading">Holzfaserdämmung im Detail</h3>
        <p class="flyer-lede">
          Alle Eigenschaften kompakt im A4-Format zum Mitnehmen oder Ausdrucken
          — ideal für Ihren Beratungstermin oder zum Weitergeben an Familie und
          Bauplaner.
        </p>
        <p class="flyer-meta">PDF · A4 · ca. 4 MB</p>
        <div class="flyer-actions">
          <Button variant="primary" size="md" href={holzfaserFlyerPDF}>
            Flyer herunterladen
          </Button>
        </div>
      </div>
    </aside>

   
  </Block>

  <!-- 6. Wandaufbau ---------------------------------------------------- -->
  <Block
    id="wandaufbau"
    tone="band"
    eyebrow="06 — Wandaufbau"
    heading="Natürlich gedämmt. Ganzjährig geschützt."
    lede="Ein energieeffizientes Zuhause beginnt bei der Gebäudehülle. Deshalb setzt BoHolz-Haus
konsequent auf nachhaltige Materialien und einen durchdachten, diffusionsoffenen
Wandaufbau mit hervorragenden Dämmeigenschaften.
"
  >
    <figure class="hero-image">
      <img
        src={wandaufbauHero}
        alt="ECO Nature Wandaufbau — diffusionsoffener Mehrschichtaufbau für KfW-Effizienzhäuser"
        loading="lazy"
      />
    </figure>

    <p class="editorial-prose">
      Unsere Außenwand „ECO Nature" schützt zuverlässig vor Kälte, sommerlicher
      Hitze, Lärm und Feuchtigkeit – und schafft gleichzeitig ein gesundes und
      angenehmes Wohnklima.
      <span class="primary">
        Durch den Einsatz ökologischer Holzfaserdämmung entsteht ein
        nachhaltiges Zuhause mit hoher Energieeffizienz und natürlicher
        Wohnqualität.
      </span>
    </p>

    <FeatureCardPair
      client:visible
      left={ecoNature}
      right={ecoNaturePlus}
      accent="right"
      imageAspect="3 / 4"
    />

    <div class="wandaufbau-followups">
      <article class="follow-card">
        <h4 class="follow-heading">Diffusionsoffen &amp; wohngesund</h4>
        <p class="editorial-prose">
          Im Gegensatz zu vielen herkömmlichen Bauweisen ermöglicht unser
          Wandaufbau einen natürlichen Feuchtigkeitsaustausch.
          <span class="primary">
            Dadurch bleibt das Raumklima das ganze Jahr über angenehm und
            ausgeglichen – ohne auf moderne Energieeffizienz zu verzichten.
          </span>
        </p>
      </article>

      <article class="follow-card">
        <h4 class="follow-heading">Ihre Vorteile auf einen Blick</h4>
        <IconList client:visible items={wandaufbauVorteile} columns={2} density="comfortable" />
      </article>
    </div>

    <details class="layers-details">
      <summary>Schicht für Schicht — alle Werte im Detail</summary>
      <div class="layers-inner">
        <div class="layers-grid">
          <section class="layers-col">
            <h4 class="layers-col-title">ECO Nature <span>· KfW 55</span></h4>
            <DefinitionList items={ecoNatureLayers} layout="grid" />
          </section>
          <section class="layers-col">
            <h4 class="layers-col-title">ECO Nature Plus <span>· KfW 40</span></h4>
            <DefinitionList items={ecoNaturePlusLayers} layout="grid" />
          </section>
        </div>
      </div>
    </details>
  </Block>

  <!-- 7. Haus- & Energietechnik ---------------------------------------- -->
  <Block
    id="technik"
    eyebrow="07 — Energietechnik"
    heading="Wärmepumpen, Photovoltaik,"
    highlight="gesundes Raumklima."
    lede="Dank gut gedämmter Außenwände bieten unsere Häuser von Anfang an umweltschonende Materialien und energieeffiziente Bauweise. Drei Bausteine, die Nachhaltigkeit konkret machen."
  >
    <IconList client:visible items={technik} columns={1} density="comfortable" />
  </Block>

  <!-- 8. CTA --------------------------------------------------------- -->
  <div class="full-width">
    <CTASection
      tone="accent"
      title="Bereit für Ihr"
      highlight="BoHolz-Haus?"
      subtitle="Vereinbaren Sie eine persönliche Beratung oder bestellen Sie den Katalog mit allen Modellen und Ausstattungsdetails."
    >
      <Fragment slot="actions">
        <Button client:visible variant="secondary" size="lg" href="/kontakt">
          Beratungstermin vereinbaren
          <ArrowRight slot="trailing" :size="16" :stroke-width="2" />
        </Button>
        <Button client:visible variant="ghost" size="lg" href="/katalog">
          <BookOpen slot="leading" :size="16" :stroke-width="2" />
          Katalog bestellen
        </Button>
      </Fragment>
    </CTASection>
  </div>
</Layout>

<style>
  /* Quiet inline fine-print — used for "*Optional" notes under callouts. */
  .footnote {
    margin: var(--spacing-3) 0 0 0;
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
    line-height: var(--lh-body);
  }

  /* Tradition → Modernisierung → Zertifizierungen — three editorial cards. */
  .steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
  }

  @media (--from-tablet) {
    .steps {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-4);
    }
  }

  /* ── Editorial hero image inside an advantage section. */
  .hero-image {
    margin: 0;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--clr-surface-secondary);
  }

  @media (--from-tablet) {
    .hero-image {
      aspect-ratio: 16 / 9;
      border-radius: var(--radius-lg);
    }
  }

  .hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Nachhaltigkeit hero + video pair. */
  .media-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
    width: 100%;
  }

  @media (--from-desktop) {
    .media-pair {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-4);
      align-items: start;
    }
  }

  .media-hero {
    margin: 0;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--clr-surface-secondary);
  }

  .media-hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Progressive-disclosure: deep wandaufbau spec list. */
  .layers-details {
    border-block-start: 1px solid var(--clr-border-secondary);
    padding-block-start: var(--spacing-4);
  }

  .layers-details summary {
    cursor: pointer;
    list-style: none;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    padding-block: var(--spacing-2);
    font-size: var(--fs-body);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
  }

  .layers-details summary::-webkit-details-marker {
    display: none;
  }

  .layers-details summary::before {
    content: "+";
    display: inline-grid;
    place-items: center;
    width: 1.25em;
    height: 1.25em;
    border: 1px solid var(--clr-border-primary);
    border-radius: var(--radius-sm);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-regular);
    color: var(--clr-content-secondary);
    transition: transform 200ms ease;
  }

  .layers-details[open] summary::before {
    content: "−";
  }

  .layers-details summary:hover {
    color: var(--clr-accent-secondary);
  }

  .layers-details summary:hover::before {
    border-color: var(--clr-accent-secondary);
    color: var(--clr-accent-secondary);
  }

  .layers-details summary:focus-visible {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .layers-inner {
    padding-block-start: var(--spacing-4);
  }

  /* Two wall types side by side from desktop; stacked below. */
  .layers-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-5);
  }

  @media (--from-desktop) {
    .layers-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--spacing-6);
    }
  }

  .layers-col-title {
    margin: 0 0 var(--spacing-3);
    font-size: var(--fs-body);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
  }

  .layers-col-title span {
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-regular);
  }

  /* ── Flyer download card — lives at the foot of section 04.
        Layout: A4 cover image left, copy + CTA right. Drops to a single
        column under tablet so the cover doesn't squeeze the text. The
        cover is a clickable link to the PDF; the explicit button is the
        primary affordance so screen readers don't only hit the image. ── */
  .flyer {
    display: grid;
    grid-template-columns: minmax(180px, 220px) 1fr;
    gap: var(--spacing-5);
    align-items: start;
    margin-block-start: var(--spacing-5);
    padding: var(--spacing-4);
    border: 1px solid var(--clr-border-secondary);
    border-radius: var(--radius-lg);
    background: var(--clr-surface-primary);
  }

  @media (--below-desktop) {
    .flyer {
      grid-template-columns: 1fr;
      gap: var(--spacing-3);
    }
  }

  .flyer-cover {
    display: block;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-2);
    transition: transform 240ms ease;
  }

  .flyer-cover:hover,
  .flyer-cover:focus-visible {
    transform: translateY(-2px);
  }

  .flyer-cover img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1743 / 2400;
    object-fit: cover;
  }

  .flyer-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .flyer-eyebrow {
    margin: 0;
    text-transform: uppercase;
    font-size: var(--fs-body-sm);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
  }

  .flyer-heading {
    margin: 0;
    font-size: var(--fs-h5);
    font-weight: var(--font-weight-medium);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }

  .flyer-lede {
    margin: 0;
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
  }

  .flyer-meta {
    margin: 0;
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
  }

  .flyer-actions {
    margin-block-start: var(--spacing-2);
  }

  /* ── Editorial prose: secondary body, primary last-sentence emphasis.
        Per the client brief — adds a final-line highlight to every body
        paragraph so the eye lands on the most important claim. ── */
  .editorial-prose {
    margin: 0;
    color: var(--clr-content-secondary);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    max-width: 70ch;
  }

  .editorial-prose .primary {
    color: var(--clr-content-primary);
    font-weight: var(--font-weight-medium);
  }

  /* ── Wandaufbau follow-ups: two short cards under the comparison pair.
        "Diffusionsoffen & wohngesund" reads as a value-statement paragraph;
        "Ihre Vorteile" anchors with a 4-bullet IconList. Stacked under
        tablet, side-by-side from desktop. ── */
  .wandaufbau-followups {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    margin-block-start: var(--spacing-5);
  }

  @media (--from-desktop) {
    .wandaufbau-followups {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-5);
    }
  }

  .follow-card {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .follow-heading {
    margin: 0;
    font-size: var(--fs-h6);
    font-weight: var(--font-weight-medium);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }
</style>
