// ── Section 7 — Wandaufbau Schichten, von außen nach innen.
// Beide Wände teilen dieselbe ökologische Schichtfolge; nur Holzrahmen +
// Dämmung (200 → 240 mm) und der daraus resultierende U-Wert unterscheiden
// sich. Werte 1:1 aus dem Werksaufbau übernommen (KfW 55 / KfW 40).
const ecoNatureLayers: DefinitionItem[] = [
  {
    term: "Außenputz",
    description:
      "Hochwertiger, diffusionsoffener Silikonharz-Edelputz, helle Tönung, durchgefärbt",
  },
  {
