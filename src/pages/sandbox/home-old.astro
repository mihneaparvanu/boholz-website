---
import Layout from "@/layouts/Layout.astro";
import Section from "@/layouts/Section.astro";
import CTASection from "@/components/sections/CTASection.astro";
import ProofSection from "@/components/sections/Proof-Section.vue";

import Hero from "@/features/Home/Hero/Hero.vue";
import CategoriesShowcase from "@/features/Home/CategoriesShowcase/CategoriesShowcase.vue";
import TrustBadges from "@/features/Home/TrustBadges/TrustBadges.vue";
import Overview from "@/features/Home/Overview/Overview.vue";
import BuildingStages from "@/features/Home/BuildingStages/BuildingStages.vue";
import BauphasenStrip from "@/features/Bauphasen/BauphasenStrip.vue";
import Faq from "@/features/Home/Faq/Faq.vue";
import Button from "@/components/ui/Button.vue";

import { homeSections } from "@/features/Home/home.content";
import { buildingStages } from "@/features/Home/BuildingStages/building-stages.content";
import { buildPhases } from "@/features/Bauphasen/bauphasen.content";
import { featuredCard, overviewPillars } from "@/features/Home/Overview/overview.content";
import { trustBadges } from "@/features/Home/TrustBadges/trust-badges.content";
import { qaCategories } from "@/content/qa";

import { getCategories, getHeroSlides } from "@/data/loaders";

const categories = await getCategories();
const heroSlides = await getHeroSlides(6);

// Drop `navLabel` before forwarding to <Section> — it's a rail-only field
// kept on the content shape for pages that still surface a section rail.
const { categories: cat, trust, overview, bauphasen, finishes, qa, contact } = homeSections;
const sectionProps = {
  categories: (({ navLabel, ...rest }) => rest)(cat),
  trust: (({ navLabel, ...rest }) => rest)(trust),
  overview: (({ navLabel, ...rest }) => rest)(overview),
  bauphasen: (({ navLabel, ...rest }) => rest)(bauphasen),
  finishes: (({ navLabel, ...rest }) => rest)(finishes),
  qa: (({ navLabel, ...rest }) => rest)(qa),
  contact: (({ navLabel, ...rest }) => rest)(contact),
};
---

<Layout title="Boholz Haus" categories={categories} isHero>
  <Hero client:load slides={heroSlides} />

  <div class="proof-band">
    <ProofSection />
  </div>

  <Section {...sectionProps.trust} tone="secondary">
    <TrustBadges client:visible badges={trustBadges} />
  </Section>

  <Section {...sectionProps.overview} tone="primary">
    <Overview client:visible featured={featuredCard} pillars={overviewPillars} />
  </Section>

  <!-- Bauphasen — compact 3-step strip. Slots between "we deliver well"
       (Overview) and "your finish-level path" (Ausbaustufen) as the bridging
       "how it happens" beat. tone="secondary" so the strip's image-led
       cards lift off a tinted band; preserves the alternation primary →
       secondary → primary across the page. -->
  <Section {...sectionProps.bauphasen} tone="secondary">
    <BauphasenStrip client:visible phases={buildPhases} linkBaseHref="/dein-zuhause" />
  </Section>

  <Section {...sectionProps.finishes} tone="primary">
    <BuildingStages client:visible stages={buildingStages} />
  </Section>

  <Section {...sectionProps.qa} tone="primary">
    <Faq client:visible categories={qaCategories} />
  </Section>

  <!-- Closing CTA — kit CTASection. Its `surface` tone already uses
       `--clr-surface-secondary` so the section reads as the alternating
       tone after the FAQ above. `full-width` makes the tinted band bleed
       edge-to-edge instead of being constrained to the wrapper column. -->
  <div id={sectionProps.contact.id} class="full-width">
    <CTASection
      eyebrow={sectionProps.contact.eyebrow}
      title={`${sectionProps.contact.heading1} ${sectionProps.contact.heading2}`}
      highlight={sectionProps.contact.highlight}
      subtitle={sectionProps.contact.subheading}
      tone="surface"
    >
      <Fragment slot="actions">
        <Button client:load variant="primary" size="md" href="/vor-ort-beratung">
          Vor-Ort-Beratung
        </Button>
        <Button client:load variant="secondary" size="md" href="/kontakt">
          Kontaktformular
        </Button>
      </Fragment>
    </CTASection>
  </div>
</Layout>

<style>
  .proof-band {
    padding-block: var(--spacing-5);
    --proof-color: var(--clr-content-secondary);
  }
</style>

<!--
  Homepage-only: render every italic text in the canonical BoHolz Blau
  (`--boholz-blau` = #91ACBE, the soft slate-blue), per client request.
  Scoped to `/` because this stylesheet only ships with index.astro.
  Double-class selectors (.highlight.highlight, .index.index) bump
  specificity above Vue's `<style scoped>` `[data-v-hash]` selectors,
  which otherwise win for `.index` inside BauphasenStrip.
-->
<style is:global>
  body em,
  body i,
  body .highlight.highlight,
  body .index.index {
    color: var(--boholz-blau);
  }
</style>
