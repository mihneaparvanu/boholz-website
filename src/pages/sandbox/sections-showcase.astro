---
import "@/style/reset.css";
import "@/style/design-system.css";
import "@/style/wrapper.css";

import Divider from "@/components/ui/Divider.astro";
import Button from "@/components/ui/Button.vue";

import HeroSplit from "@/components/sections/HeroSplit.astro";
import HeroOverlayCard from "@/components/sections/HeroOverlayCard.astro";
import ImageBand from "@/components/sections/ImageBand.astro";
import AsymmetricShowcase from "@/components/sections/AsymmetricShowcase.astro";
import WindowGrid from "@/components/sections/WindowGrid.vue";

// Sandbox — bypasses Layout.astro to avoid DB calls.

// ── Imagery — Unsplash hotlinks tuned to BoHolz: timber prefab, modern
// German residential, forested settings, calm interiors with wood. We
// pin width to avoid pulling 5K originals on a sandbox page. ──
const IMG = {
  modernHouseDay:
    "https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&w=1600&q=80",
  modernHouseDusk:
    "https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?auto=format&fit=crop&w=1600&q=80",
  cabinForest:
    "https://images.unsplash.com/photo-1542718610-a1d656d1884c?auto=format&fit=crop&w=1600&q=80",
  bungalow:
    "https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1600&q=80",
  livingRoom:
    "https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&w=1600&q=80",
  kitchen:
    "https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?auto=format&fit=crop&w=1600&q=80",
  bedroom:
    "https://images.unsplash.com/photo-1505693416388-ac5ce068fe85?auto=format&fit=crop&w=1600&q=80",
  bathroom:
    "https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?auto=format&fit=crop&w=1600&q=80",
  forestPath:
    "https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=2400&q=80",
  woodFacade:
    "https://images.unsplash.com/photo-1503174971373-b1f69850bded?auto=format&fit=crop&w=1600&q=80",
  modelThumb:
    "https://images.unsplash.com/photo-1582268611958-ebfd161ef9cf?auto=format&fit=crop&w=400&q=80",
  diningRoom:
    "https://images.unsplash.com/photo-1600585154526-990dced4db0d?auto=format&fit=crop&w=1600&q=80",
  exteriorEvening:
    "https://images.unsplash.com/photo-1605276374104-dee2a0ed3cd6?auto=format&fit=crop&w=1600&q=80",
};
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sandbox — Visual Heroes & Showcase Sections</title>
  </head>
  <body>
    <header class="faux-nav">BoHolz Haus — Sections / Visual Heroes</header>

    <main class="wrapper">
      <section class="page-hero">
        <p class="page-eyebrow">Pack · Visual heroes & showcase</p>
        <h1>
          Visuelle Heroes <span class="page-highlight">und Editorial-Layouts</span>
        </h1>
        <p class="page-lede">
          Fünf Sektionen — vier aus dem Brief und ein Vorschlag aus dem Atelier.
          Jeder Block sitzt photographisch, nicht marketinghaft.
        </p>
      </section>

      <!-- ═══ HeroSplit — image-end (default) ═══ -->
      <Divider label="HeroSplit · image right (default)" />
      <HeroSplit
        eyebrow="Kampagne · Bungalow"
        heading="Ihr Bungalow als"
        highlight="Fertighaus."
        lede="Ebenerdig wohnen, ein Leben lang. Schlüsselfertige Bungalows in 8 bis 12 Wochen, mit Festpreis und KfW-40-Standard."
        image={IMG.bungalow}
        imageAlt="Moderner Bungalow mit Holzfassade vor heller Wand"
        rule
      >
        <Button slot="actions" client:load variant="primary" size="md">
          Modelle entdecken
        </Button>
        <Button slot="actions" client:load variant="tertiary" size="md">
          Beratung buchen
        </Button>
      </HeroSplit>

      <!-- ═══ HeroSplit — image-start ═══ -->
      <Divider label="HeroSplit · image left" />
      <HeroSplit
        eyebrow="Kampagne · Mehrfamilien"
        heading="Mehr Raum"
        highlight="für Familien."
        lede="Zwei- und Dreifamilienhäuser, vorgefertigt aus heimischem Holz. Mehrgenerationen-Wohnen mit klarer Trennung der Lebensbereiche."
        image={IMG.modernHouseDay}
        imageAlt="Modernes Mehrfamilienhaus mit großzügigen Fensterflächen"
        image-side="start"
      >
        <Button slot="actions" client:load variant="primary" size="md">
          Grundrisse ansehen
        </Button>
      </HeroSplit>

      <!-- ═══ HeroOverlayCard — with spec card ═══ -->
      <Divider label="HeroOverlayCard · with spec card" />
      <HeroOverlayCard
        eyebrow="Wohnraumgestaltung"
        heading="Vorgeplante Wohnräume,"
        highlight="entworfen von Architekten."
        lede="Vierzig Modelle, jeder Grundriss bewohnt gedacht. Sie wählen das Haus — die Räume bringen die Geschichte mit."
        image={IMG.livingRoom}
        imageAlt="Helles modernes Wohnzimmer mit Holzakzenten und großen Fenstern"
        spec={{
          image: IMG.modelThumb,
          imageAlt: "Modell Alpha 162.1 Außenansicht",
          name: "Alpha 162.1",
          meta: "Basismodell · 162 m²",
          href: "/haus/alpha-162-1",
        }}
      >
        <Button slot="actions" client:load variant="secondary" size="md">
          Innenräume entdecken
        </Button>
      </HeroOverlayCard>

      <!-- ═══ HeroOverlayCard — no spec card ═══ -->
      <Divider label="HeroOverlayCard · no spec card" />
      <HeroOverlayCard
        eyebrow="Über uns"
        heading="Neunzig Jahre Holzbau,"
        highlight="in vierter Generation."
        lede="Familienbetrieb seit 1934. Wir bauen keine Häuser, wir bauen Zuhause — und das spürt man bis in die Faserrichtung."
        image={IMG.cabinForest}
        imageAlt="Holzhaus eingebettet in deutschem Mischwald"
      >
        <Button slot="actions" client:load variant="secondary" size="md">
          Unsere Geschichte
        </Button>
      </HeroOverlayCard>

      <!-- ═══ ImageBand · minimal ═══ -->
      <Divider label="ImageBand · minimal" />
      <ImageBand
        heading="Planen Sie, ein Haus zu bauen?"
        highlight="Wir sind für Sie da."
        image={IMG.forestPath}
        imageAlt="Waldweg mit modernem Holzhaus am Horizont"
      />

      <!-- ═══ ImageBand · with eyebrow + lede + rule ═══ -->
      <Divider label="ImageBand · with eyebrow, lede, rule" />
      <ImageBand
        eyebrow="KfW-Förderung"
        heading="Bauen mit Förderung."
        highlight="Ohne Kompromisse."
        lede="Alle BoHolz-Häuser sind KfW-40-fähig. Auf Wunsch QNG-Plus für maximale Zuschüsse."
        image={IMG.woodFacade}
        imageAlt="Holzfassade eines KfW-40-zertifizierten Hauses im Detail"
        rule
      />

      <!-- ═══ AsymmetricShowcase ═══ -->
      <Divider label="AsymmetricShowcase" />
      <AsymmetricShowcase
        eyebrow="Wohnen bei BoHolz"
        heading="Räume, die mitwachsen —"
        highlight="für jede Lebensphase."
        lede="Von der ersten gemeinsamen Wohnung bis zum barrierefreien Alterswohnsitz. Wir entwerfen Häuser, die sich Ihnen anpassen — nicht umgekehrt."
        images={[
          {
            src: IMG.bedroom,
            alt: "Helles Schlafzimmer mit Holzdielen und gedämpften Naturtönen",
            caption:
              "Schlafräume mit Querlüftung und nordischer Lichtführung — Ruhe wird hier gebaut, nicht installiert.",
          },
          {
            src: IMG.kitchen,
            alt: "Offene Küche mit Massivholz-Arbeitsplatte und großem Fenster",
            caption:
              "Die offene Küche als Mittelpunkt: ehrliche Materialien, präzise Verarbeitung, geteilte Mahlzeiten.",
          },
          {
            src: IMG.diningRoom,
            alt: "Esszimmer mit großzügiger Glasfront zum Garten",
            caption:
              "Volle Glasfronten lösen die Grenze zum Außenraum auf. Die Tafel wird zur Verlängerung des Gartens.",
          },
        ]}
      />

      <!-- ═══ WindowGrid · stretch pattern ═══ -->
      <Divider label="WindowGrid · stretch — slow-zoom 2×2" />
      <WindowGrid
        client:visible
        eyebrow="Modell Alpha 162.1"
        heading="Vier Räume,"
        highlight="ein Zuhause."
        lede="Bewegen Sie sich durch die Räume — wie ein Spaziergang durch ein bewohntes Haus. Jedes Fenster zeigt einen anderen Moment im Tagesablauf."
        frames={[
          { src: IMG.livingRoom, alt: "Wohnzimmer im Tageslicht", label: "Wohnzimmer", meta: "32 m²" },
          { src: IMG.kitchen, alt: "Offene Küche mit Frühstücksinsel", label: "Küche", meta: "18 m²" },
          { src: IMG.bedroom, alt: "Hauptschlafzimmer mit Holzdielen", label: "Hauptschlafzimmer", meta: "22 m²" },
          { src: IMG.bathroom, alt: "Badezimmer mit Naturstein und Tageslicht", label: "Badezimmer", meta: "14 m²" },
        ]}
      />

      <!-- Spacer at end so the band/grid scroll-out feels intentional. -->
      <section class="end-spacer" aria-hidden="true"></section>
    </main>
  </body>
</html>

<style>
  .faux-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    height: 64px;
    background: var(--clr-surface-primary);
    border-block-end: 1px solid var(--clr-border-secondary);
    display: flex;
    align-items: center;
    padding-inline: var(--padding-inline);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
  }

  .page-hero {
    padding-block: var(--spacing-6) var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    max-width: 64ch;
  }

  .page-eyebrow {
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
    margin: 0 0 var(--spacing-3) 0;
  }

  .page-hero h1 {
    font-weight: var(--font-weight-light);
    margin: 0;
  }

  .page-highlight {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
  }

  .page-lede {
    font-size: var(--fs-body-lg);
    color: var(--clr-content-secondary);
    margin: 0;
  }

  .end-spacer {
    height: var(--spacing-6);
  }
</style>
