---
import "@/style/reset.css";
import "@/style/design-system.css";
import "@/style/wrapper.css";

import Divider from "@/components/ui/Divider.astro";
import Eyebrow from "@/components/ui/Eyebrow.astro";
import Button from "@/components/ui/Button.vue";
import ZigZag from "@/components/ui/ZigZag.vue";

import BenefitsRow from "@/components/sections/BenefitsRow.astro";
import type { Benefit } from "@/components/sections/BenefitsRow.astro";
import FeatureSpotlight from "@/components/sections/FeatureSpotlight.astro";
import type { SpotlightCard } from "@/components/sections/FeatureSpotlight.astro";
import AudienceBlock from "@/components/sections/AudienceBlock.astro";
import type { AudienceItem } from "@/components/sections/AudienceBlock.astro";
import PrinciplesGrid from "@/components/sections/PrinciplesGrid.astro";
import type { Principle } from "@/components/sections/PrinciplesGrid.astro";

import { getMediaURL } from "@/utils/media";

// Sandbox — bypasses Layout.astro to avoid DB calls.

const benefits: Benefit[] = [
  {
    icon: "leaf",
    title: "Nachhaltig & ökologisch",
    body: "Zertifiziertes PEFC-Holz aus heimischen Wäldern, langlebig.",
    tone: "grun",
  },
  {
    icon: "compass",
    title: "Individuelle Planung",
    body: "Architektonisch frei, auf Ihr Grundstück abgestimmt.",
    tone: "petrol",
  },
  {
    icon: "zap",
    title: "KfW 40-Standard",
    body: "Energieeffizient — förderfähig nach aktueller KfW-Richtlinie.",
    tone: "oliv",
  },
  {
    icon: "key-square",
    title: "Schlüsselfertig schnell gebaut",
    body: "Vorgefertigt im Werk, Montage in ein bis drei Tagen.",
    tone: "bg",
  },
];

const audience: AudienceItem[] = [
  {
    icon: "users",
    label: "Familien",
    description:
      "Großzügige Grundrisse, geschützte Gartenbereiche und Räume, die mit Kindern und Jugendlichen mitwachsen.",
  },
  {
    icon: "heart-handshake",
    label: "Senioren",
    description:
      "Barrierefrei durchdacht, ebenerdig wohnbar, fürs Leben geplant. Komfort, der bleibt.",
  },
  {
    icon: "building-2",
    label: "Mehrgenerationen",
    description:
      "Zwei autarke Wohneinheiten unter einem Dach — gemeinsam wohnen, getrennt leben.",
  },
  {
    icon: "trending-up",
    label: "Investoren",
    description:
      "Langlebige Substanz, KfW-konform, klare Renditeperspektive. Werterhalt über Generationen.",
  },
];

const principles: Principle[] = [
  {
    label: "Holz vor Beton",
    body: "Jedes BoHolz-Haus speichert rund 30 Tonnen CO₂ über seinen Lebenszyklus.",
  },
  {
    label: "Festpreis ab Vertrag",
    body: "Keine Nachträge, keine Überraschungen — Sie wissen, was Sie bauen.",
  },
  {
    label: "Werksgefertigt",
    body: "Industrielle Präzision bei Witterungsunabhängigkeit und gleichbleibender Qualität.",
  },
  {
    label: "Familiengeführt seit 1934",
    body: "Vierte Generation im Familienbesitz. Verantwortung über Quartalszahlen.",
  },
  {
    label: "Persönlich beraten",
    body: "Ein Ansprechpartner von der Skizze bis zur Schlüsselübergabe — nie eine Nummer.",
  },
  {
    label: "Schnell montiert",
    body: "Aufstellung in ein bis drei Tagen. Ihr Zuhause steht, bevor andere Keller gießen.",
  },
];

const spotlightMain = {
  image: getMediaURL("/images/pages/uber-uns/value-1.jpg"),
  imageAlt: "BoHolz Premiumhaus aus heimischem Holz",
  heading: "Entdecken Sie die Vorteile des Hausbaus mit BoHolz.",
  body: "Vom ersten Entwurf bis zur Schlüsselübergabe begleiten wir Ihren Hausbau — präzise, planbar, persönlich.",
  href: "/dein-zuhause",
};

const spotlightSmall: [SpotlightCard, SpotlightCard] = [
  {
    image: getMediaURL("/images/pages/uber-uns/value-2.jpg"),
    imageAlt: "Energieeffizientes BoHolz-Haus",
    heading: "Energieeffizienzhaus",
    body: "Klimafreundlich bauen für die Zukunft unserer Kinder.",
    href: "/dein-zuhause",
  },
  {
    image: getMediaURL("/images/pages/uber-uns/value-1.jpg"),
    imageAlt: "KfW-gefördertes BoHolz-Haus",
    heading: "KfW-Förderung",
    body: "Nutzen Sie die attraktive KfW-Förderung für Ihr Bauvorhaben.",
    href: "/dein-zuhause",
  },
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sandbox — Content Sections</title>
  </head>
  <body>
    <header class="faux-nav">BoHolz Haus — Content Sections</header>

    <main class="wrapper">
      <section class="page-hero">
        <p class="page-eyebrow">Phase 2 · Build kit</p>
        <h1>Content-Sections</h1>
        <p class="page-lede">
          Vier wiederverwendbare Sektionen für Inhalt — Vorteile,
          Spotlight, Zielgruppen, Prinzipien — plus ein polierter ZigZag.
        </p>
      </section>

      <!-- ════ 1 · BenefitsRow ════ -->
      <section class="group" id="benefits">
        <Divider index={1} label="BenefitsRow" />
        <div class="lede-block">
          <h2 class="lede-head">
            Ihre Vorteile <span class="highlight">auf einen Blick.</span>
          </h2>
          <p class="lede-body">
            Nachhaltig, energieeffizient, individuell planbar.
          </p>
        </div>
        <BenefitsRow items={benefits} />
      </section>

      <!-- ════ 2 · FeatureSpotlight ════ -->
      <section class="group" id="spotlight">
        <Divider index={2} label="FeatureSpotlight" />
        <div class="lede-block">
          <h2 class="lede-head">
            Entdecken Sie die Vorteile{" "}
            <span class="highlight">des Hausbaus mit BoHolz.</span>
          </h2>
        </div>
        <FeatureSpotlight main={spotlightMain} small={spotlightSmall} />
      </section>

      <!-- ════ 3 · AudienceBlock ════ -->
      <section class="group" id="audience">
        <Divider index={3} label="AudienceBlock" />
        <div class="lede-block centered">
          <Eyebrow>Größe und Passform</Eyebrow>
          <h2 class="lede-head">
            Für wen <span class="highlight">geeignet?</span>
          </h2>
          <p class="lede-body">
            Egal, in welcher Lebensphase Sie sind — wir haben das passende
            Haus.
          </p>
        </div>
        <AudienceBlock items={audience} />
      </section>

      <!-- ════ 4 · PrinciplesGrid (stretch pattern) ════ -->
      <section class="group" id="principles">
        <Divider index={4} label="PrinciplesGrid · stretch pattern" />
        <div class="lede-block">
          <Eyebrow>Unsere Haltung</Eyebrow>
          <h2 class="lede-head">
            Sechs Prinzipien, <span class="highlight">die wir nicht verhandeln.</span>
          </h2>
          <p class="lede-body">
            Was uns als Hersteller ausmacht — kurz und ohne Lyrik.
          </p>
        </div>
        <PrinciplesGrid items={principles} />
      </section>

      <!-- ════ 5 · ZigZag (polished) ════ -->
      <section class="group" id="zigzag">
        <Divider index={5} label="ZigZag · polished (heading/eyebrow slots, dense, wide, media-first)" />

        <!-- Default — back-compat: copy/actions/media slots still work. -->
        <ZigZag>
          <Fragment slot="copy">
            <Eyebrow>01 · Architektur</Eyebrow>
            <h3 class="zz-head">
              Jedes Haus erzählt seine{" "}
              <span class="highlight">eigene Geschichte.</span>
            </h3>
            <p class="zz-body">
              Von der Grundrissgestaltung bis zur Fassadenauswahl — bei uns
              haben Sie die Freiheit, Ihren Hausentwurf zu individualisieren.
            </p>
          </Fragment>
          <img
            slot="media"
            src={getMediaURL("/images/pages/uber-uns/value-1.jpg")}
            alt="BoHolz Architektur"
            class="zz-img"
          />
          <Button slot="actions" client:load variant="secondary" size="sm" href="/dein-zuhause">
            Mehr erfahren
          </Button>
        </ZigZag>

        <!-- New slots: #eyebrow + #heading, mediaSide=start, split=tablet, wide gap. -->
        <ZigZag media-side="start" split="tablet" gap="wide">
          <Eyebrow slot="eyebrow" tone="accent">02 · Material</Eyebrow>
          <h3 slot="heading" class="zz-head">
            Holz, das CO₂ speichert — <span class="highlight">ein Leben lang.</span>
          </h3>
          <Fragment slot="copy">
            <p class="zz-body">
              Wir bauen mit zertifiziertem PEFC-Holz aus heimischen Wäldern.
              Jedes Haus speichert rund 30 Tonnen CO₂ über seinen Lebenszyklus.
            </p>
          </Fragment>
          <img
            slot="media"
            src={getMediaURL("/images/pages/uber-uns/value-2.jpg")}
            alt="Massivholz aus heimischen Wäldern"
            class="zz-img"
          />
        </ZigZag>

        <!-- Dense + mobile-media-first variant. -->
        <ZigZag dense mobile-media-first split="tablet">
          <Eyebrow slot="eyebrow">03 · Fertigung</Eyebrow>
          <h3 slot="heading" class="zz-head">
            Werksgefertigt, vor Ort{" "}
            <span class="highlight">in drei Tagen montiert.</span>
          </h3>
          <Fragment slot="copy">
            <p class="zz-body">
              Industrielle Präzision unabhängig vom Wetter. Kürzere
              Bauzeit, planbarer Termin, festgeschriebene Qualität.
            </p>
          </Fragment>
          <img
            slot="media"
            src={getMediaURL("/images/pages/uber-uns/value-1.jpg")}
            alt="Werksfertigung"
            class="zz-img"
          />
        </ZigZag>
      </section>
    </main>
  </body>
</html>

<style>
  .faux-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    height: 64px;
    background: var(--clr-surface-primary);
    border-block-end: 1px solid var(--clr-border-secondary);
    display: flex;
    align-items: center;
    padding-inline: var(--padding-inline);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
  }

  .page-hero {
    padding-block: var(--spacing-6) var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    max-width: 64ch;
  }

  .page-eyebrow {
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
    margin: 0;
    margin-block-end: calc(var(--spacing-4) - var(--spacing-3));
  }

  .page-hero h1 {
    font-weight: var(--font-weight-light);
    margin: 0;
  }

  .page-lede {
    font-size: var(--fs-body-lg);
    color: var(--clr-content-secondary);
    margin: 0;
  }

  .group {
    padding-block: var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .lede-block {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    max-width: 72ch;
  }
  .lede-block.centered {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }

  .lede-head {
    margin: 0;
    font-size: var(--fs-h3);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--ls-heading);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }

  .lede-body {
    margin: 0;
    font-size: var(--fs-body);
    color: var(--clr-content-secondary);
    max-width: 60ch;
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
  }

  .zz-img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    border-radius: var(--radius-md);
    display: block;
  }

  .zz-head {
    margin: 0;
    font-size: var(--fs-h4);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--ls-heading);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
  }

  .zz-body {
    margin: 0;
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    color: var(--clr-content-secondary);
    max-width: 60ch;
  }
</style>
