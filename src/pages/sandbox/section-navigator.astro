---
import "@/style/reset.css";
import "@/style/design-system.css";
import "@/style/wrapper.css";
import SectionNavigator from "@/components/ui/SectionNavigator.vue";

// Sandbox page — bypasses Layout.astro so no DB calls happen.
// Delete this directory (src/pages/sandbox/) before shipping, or guard it.

const sections = [
  { id: "qualitaet", eyebrow: "01", label: "Qualität & Zertifikate" },
  { id: "gruende", eyebrow: "02", label: "16 gute Gründe" },
  { id: "nachhaltigkeit", eyebrow: "03", label: "Nachhaltigkeit" },
  { id: "wandaufbau", eyebrow: "04", label: "Wandaufbau" },
  { id: "energie", eyebrow: "05", label: "Energie & Technik" },
  { id: "beratung", eyebrow: "06", label: "Beratung" },
  { id: "kontakt", eyebrow: "07", label: "Kontakt" },
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sandbox — SectionNavigator</title>
  </head>
  <body>
    <!-- A faux-navbar so the sticky offset is real -->
    <header class="faux-nav">BoHolz Haus</header>

    <main class="wrapper">
      <section class="hero" data-section-heading>
        <h1>Das BoHolz Versprechen</h1>
        <p class="lede">
          Ein langer, ehrlicher Sandbox-Hero, damit der sticky Pill-Rail seinen
          Schwellenwert erst nach realem Scrollen erreicht.
        </p>
      </section>

      <SectionNavigator client:load pageTitle="Unser Versprechen" sections={sections} stickyOffset={64} />

      {
        sections.map((s, i) => (
          <section id={s.id} class="page-section">
            <p class="eyebrow">{s.eyebrow}</p>
            <h2>{s.label}</h2>
            <p>
              Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus
              rhoncus tortor sit amet purus interdum, et vehicula sapien
              fringilla. Etiam vitae libero risus. Sed at tortor at lacus
              tincidunt ullamcorper eu eget sapien. Pellentesque habitant morbi
              tristique senectus et netus et malesuada fames ac turpis egestas.
            </p>
            <p>
              Vestibulum sed dictum tortor, in volutpat enim. Curabitur sit amet
              fringilla nisi. Aliquam sit amet ipsum eget nisl iaculis pulvinar.
              Suspendisse euismod, mi vel placerat tincidunt, libero dui
              dignissim arcu, in posuere arcu nibh in lectus. Praesent dictum,
              justo at dictum porttitor, dolor sapien lacinia turpis, eu
              hendrerit ligula augue at libero.
            </p>
            {i % 2 === 0 && (
              <p>
                Mauris efficitur eros vel arcu rutrum, a fringilla orci
                consequat. Aenean vitae sapien tempor, tincidunt nisi sit amet,
                dapibus ipsum. Vivamus tristique enim quis arcu mattis lacinia.
                Cras at neque eu urna posuere posuere. Nullam blandit feugiat
                ligula a tempus.
              </p>
            )}
          </section>
        ))
      }
    </main>
  </body>
</html>

<style>
  .faux-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    height: 64px;
    background: var(--clr-surface-primary);
    border-block-end: 1px solid var(--clr-border-secondary);
    display: flex;
    align-items: center;
    padding-inline: var(--padding-inline);
    font-weight: var(--font-weight-medium);
  }

  .hero {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    justify-content: end;
    gap: var(--spacing-3);
    padding-block: var(--spacing-6);
  }

  .hero h1 {
    max-width: 16ch;
  }

  .hero .lede {
    color: var(--clr-content-secondary);
    max-width: 50ch;
    font-size: var(--fs-body-lg);
  }

  .page-section {
    padding-block: var(--spacing-6);
    border-block-start: 1px solid var(--clr-border-secondary);
  }

  .page-section:first-of-type {
    border-block-start: none;
    padding-block-start: var(--spacing-5);
  }

  .page-section .eyebrow {
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
    margin-block-end: var(--spacing-1);
  }

  .page-section h2 {
    margin-block-end: var(--spacing-3);
    max-width: 22ch;
  }

  .page-section p {
    color: var(--clr-content-secondary);
    max-width: 64ch;
    margin-block-end: var(--spacing-2);
  }
</style>
