---
import Layout from "@/layouts/Layout.astro";
import { getModelBySlug } from "@/db/loaders";

import HausPageNav from "@/features/house-page/components/HausPageNav.vue";
import HeroGallery from "@/features/house-page/components/HeroGallery.vue";
import SideCard from "@/features/house-page/components/SideCard.vue";
import FloorPlanTabs from "@/features/house-page/components/FloorPlanTabs.vue";
import StatsGrid from "@/features/house-page/components/StatsGrid.vue";
import AccordionItem from "@/features/house-page/components/AccordionItem.vue";
import DetailsGrid from "@/features/house-page/components/DetailsGrid.vue";
import CTASection from "@/ui/sections/CTASection.astro";
import Button from "@/ui/primitives/Button.vue";

const { slug } = Astro.params;
const model = await getModelBySlug(slug!);
if (!model) return Astro.redirect("/hauser");

const sections = [
  { id: "hausansichten", label: "Hausansichten" },
  { id: "informationen", label: "Informationen" },
  { id: "grundrisse", label: "Grundrisse" },
  { id: "kontakt", label: "Kontakt" },
];

// Use the model's own description; if it's empty, show nothing rather than
// a generic placeholder shared across every house page.
const description = model.description?.trim() || null;
// First-sentence summary for the narrow SideCard.
const lede = description ? (description.match(/^[^.!?]+[.!?]/)?.[0] ?? description) : null;
const hasCategoryDescription = Boolean(model.category?.description);

// Client copy (2026-05): a single advisory paragraph instead of a bulleted
// hard-coded spec list — the actual Leistungsumfang is determined per
// project together with the Fachberater.
const leistungenCopy =
  "Je nach Ihren individuellen Bedürfnissen können wir verschiedene Gewerke und Leistungsumfänge anbieten. Gerne berät Sie unser Fachberater hierzu ausführlich und erstellt gemeinsam mit Ihnen ein passendes Konzept.";
---

<Layout title={`${model.title} – BoHolz Haus`}>
  <HausPageNav client:load sections={sections} />

  <section id="hausansichten" class="hero-zone">
    <div class="hero-grid">
      <HeroGallery client:load model={model} />
      <SideCard client:load model={model} lede={lede} />
    </div>
  </section>

  <section class="stats">
    <StatsGrid model={model} />
  </section>

  <section id="informationen" class="info">
    <h2 class="section-title">Informationen</h2>
    {(description || hasCategoryDescription) && (
      <AccordionItem client:visible label="Beschreibung">
        {description && <p class="prose">{description}</p>}
        {hasCategoryDescription && (
          <p class="prose" set:html={model.category?.description} />
        )}
      </AccordionItem>
    )}
    <AccordionItem client:visible label="Details">
      <DetailsGrid model={model} />
    </AccordionItem>
    <AccordionItem client:visible label="Leistungsumfang">
      <p class="prose">{leistungenCopy}</p>
    </AccordionItem>
  </section>

  <section id="grundrisse" class="floors">
    <h2 class="section-title">Grundrisse</h2>
    {model.floors.length > 0 ? (
      <FloorPlanTabs client:visible floors={model.floors} />
    ) : (
      <p class="empty">Grundrisse folgen in Kürze.</p>
    )}
  </section>

  <section id="kontakt">
    <CTASection
      title="Interesse an"
      highlight="diesem Haus?"
      subtitle="Vereinbaren Sie ein Beratungsgespräch oder lassen Sie sich den Katalog kostenlos zusenden."
    >
      <Fragment slot="actions">
        <Button variant="primary" size="lg" href="/kontakt">
          Beratungstermin
        </Button>
        <Button variant="tertiary" size="lg" href="/katalog">
          Katalog bestellen
        </Button>
      </Fragment>
    </CTASection>
  </section>
</Layout>

<style>
  .hero-zone {
    padding-block-start: var(--spacing-4);
    padding-block-end: var(--spacing-5);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--spacing-4);
    align-items: start;
  }

  @media (--from-desktop) {
    .hero-grid {
      grid-template-columns: minmax(0, 1fr) 360px;
    }

    .hero-grid > astro-island:last-child {
      position: sticky;
      top: calc(var(--navbar-height) + var(--spacing-5));
    }
  }

  .stats {
    padding-block: var(--spacing-4);
  }

  .info,
  .floors {
    padding-block: var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .section-title {
    margin: 0 0 var(--spacing-3);
    font-size: var(--fs-h4);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--ls-heading);
  }

  .prose {
    margin: 0 0 var(--spacing-2);
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
    /* Preserve `\n` paragraph breaks + bullet rows authored in the DB
       description column without forcing markdown parsing on the server. */
    white-space: pre-line;
  }

  .prose:last-child {
    margin-bottom: 0;
  }

  .empty {
    margin: 0;
    color: var(--clr-content-tertiary);
  }

  /* Mobile gets bottom padding so the floating nav never overlaps content. */
  @media (--below-desktop) {
    :global(main.wrapper) {
      padding-block-end: var(--spacing-6);
    }
  }
</style>
