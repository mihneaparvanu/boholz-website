---
import Layout from "@/layouts/Layout.astro";
import { getLocations } from "@/db/loaders";

import PageHero from "@/ui/sections/PageHero.astro";
import EyebrowHeadingLede from "@/ui/primitives/EyebrowHeadingLede.astro";
import CTASection from "@/ui/sections/CTASection.astro";
import Button from "@/ui/primitives/Button.vue";
import { ROUTES } from "@/features/navigation/routes";
import { ArrowLeft, MapPin, Phone, Mail } from "lucide-vue-next";

const { slug } = Astro.params;
const showhouses = await getLocations({ kind: "showhouse" });
const showhouse = showhouses.find((s) => s.slug === slug);

if (!showhouse) return Astro.redirect(ROUTES.onsite);

const hero = showhouse.media.find((m) => m.isHero)?.media ?? showhouse.media[0]?.media;
const gallery = showhouse.media
  .filter((m) => !m.isHero)
  .slice(0, 8)
  .map((m) => m.media);

// Vertriebspartner for this Musterhaus — already ordered by sortOrder in the
// loader. Strips the pivot wrapper down to the agent record.
const agents = showhouse.agents.map((a) => a.agent);
const telHref = (s: string): string => `tel:${s.replace(/[^\d+]/g, "")}`;
---

<Layout title={`${showhouse.title} – BoHolz Haus`}>
  <div class="full-width">
    <PageHero
      eyebrow="Musterhaus"
      title={showhouse.title.replace("Musterhaus ", "")}
      highlight="erleben."
      subtitle={showhouse.address ?? `Musterhaus in ${showhouse.city}`}
      image={hero?.path}
      imageAlt={hero?.alt ?? showhouse.title}
      align="center"
    />
  </div>

  <section class="back">
    <a class="back-link" href={ROUTES.onsite}>
      <ArrowLeft :size={14} :stroke-width={2} aria-hidden="true" />
      <span>Alle Musterhäuser</span>
    </a>
  </section>

  <section id="kontakt" class="info">
    <EyebrowHeadingLede
      eyebrow="Adresse & Anfahrt"
      heading="Wir freuen uns auf Ihren"
      highlight="Besuch."
    />
    <ul class="meta">
      <li>
        <MapPin :size={16} :stroke-width={1.75} aria-hidden="true" />
        <span>{showhouse.address ?? `${showhouse.city}, ${showhouse.country}`}</span>
      </li>
      {showhouse.phone && (
        <li>
          <Phone :size={16} :stroke-width={1.75} aria-hidden="true" />
          <a href={`tel:${showhouse.phone}`}>{showhouse.phone}</a>
        </li>
      )}
      {showhouse.email && (
        <li>
          <Mail :size={16} :stroke-width={1.75} aria-hidden="true" />
          <a href={`mailto:${showhouse.email}`}>{showhouse.email}</a>
        </li>
      )}
    </ul>
  </section>

  {agents.length > 0 && (
    <section id="vertrieb" class="vertrieb">
      <EyebrowHeadingLede
        eyebrow="Beratung & Verkauf"
        heading="Jetzt live erleben &"
        highlight="beraten lassen."
      />
      <ul class="agents" role="list">
        {agents.map((a) => (
          <li class="agent">
            <div class="agent-name">{a.fullName}</div>
            {a.role && <div class="agent-role">{a.role}</div>}
            <div class="agent-contact">
              {a.phoneNumber && (
                <a href={telHref(a.phoneNumber)}>
                  <Phone :size={14} :stroke-width={1.75} aria-hidden="true" />
                  <span>{a.phoneNumber}</span>
                </a>
              )}
              {a.phoneSecondary && (
                <a href={telHref(a.phoneSecondary)}>
                  <Phone :size={14} :stroke-width={1.75} aria-hidden="true" />
                  <span>{a.phoneSecondary}</span>
                </a>
              )}
              {a.email && (
                <a href={`mailto:${a.email}`}>
                  <Mail :size={14} :stroke-width={1.75} aria-hidden="true" />
                  <span>{a.email}</span>
                </a>
              )}
            </div>
          </li>
        ))}
      </ul>
    </section>
  )}

  {gallery.length > 0 && (
    <section id="impressionen" class="gallery-section">
      <EyebrowHeadingLede
        eyebrow="Impressionen"
        heading="Ein Blick"
        highlight="ins Haus."
      />
      <div class="gallery">
        {gallery.map((m) => (
          <figure>
            <img src={m.path} alt={m.alt ?? showhouse.title} loading="lazy" />
          </figure>
        ))}
      </div>
    </section>
  )}

  <div class="full-width">
    <CTASection
      title="Lust auf einen"
      highlight="Termin?"
      subtitle="Sprechen Sie mit uns — Beratung im Musterhaus oder Vor-Ort-Termin auf Ihrem Bauplatz."
    >
      <Fragment slot="actions">
        <Button variant="primary" size="lg" href="/kontakt">Termin vereinbaren</Button>
        <Button variant="tertiary" size="lg" href={ROUTES.onsite}>
          Alle Musterhäuser
        </Button>
      </Fragment>
    </CTASection>
  </div>
</Layout>

<style>
  .back {
    padding-block: var(--spacing-3) 0;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
    transition: color 160ms ease;
  }

  .back-link:hover,
  .back-link:focus-visible {
    color: var(--clr-accent-secondary);
  }

  .info {
    padding-block: var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .meta {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    color: var(--clr-content-secondary);
  }

  .meta li {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
  }

  .meta a {
    color: inherit;
    text-decoration-line: underline;
    text-decoration-color: color-mix(in srgb, currentColor 30%, transparent);
    text-underline-offset: 3px;
    transition: color 160ms ease;
  }

  .meta a:hover {
    color: var(--clr-accent-secondary);
  }

  .vertrieb {
    padding-block: var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .agents {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
  }

  @media (--from-tablet) {
    .agents {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .agent {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    padding: var(--spacing-4);
    border: 1px solid var(--clr-border-secondary);
    border-radius: var(--radius-md);
    background: var(--clr-surface-primary);
  }

  .agent-name {
    font-size: var(--fs-body);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
    line-height: var(--lh-heading);
  }

  .agent-role {
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
  }

  .agent-contact {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    margin-block-start: var(--spacing-2);
  }

  .agent-contact a {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-2);
    font-size: var(--fs-body-sm);
    color: var(--clr-content-secondary);
    text-decoration: none;
    line-height: var(--lh-body);
    width: fit-content;
    transition: color 160ms ease;
  }

  .agent-contact a:hover {
    color: var(--clr-accent-secondary);
  }

  .gallery-section {
    padding-block: var(--spacing-5);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  .gallery {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-2);
  }

  @media (--from-tablet) {
    .gallery {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--spacing-3);
    }
  }

  @media (--from-desktop) {
    .gallery {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .gallery figure {
    margin: 0;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    background: var(--clr-surface-secondary);
  }

  .gallery img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>
