---
import "@/style/reset.css";
import "@/style/design-system.css";
import "@/style/wrapper.css";
import Button from "@/components/ui/Button.vue";
import IconButton from "@/components/ui/IconButton.vue";
import PrivacyBtn from "@/components/ui/PrivacyBtn.vue";
import { ArrowRight, Download, Home, Layers, Phone } from "lucide-vue-next";
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>UI Preview – BoHolz</title>
  </head>
  <body>
    <article class="preview wrapper">
      <header class="preview-head">
        <h1>UI Preview</h1>
        <p>Reusable primitives in the BoHolz style. Token-driven, a11y-wired via Reka where needed.</p>
      </header>

      <section class="preview-section">
        <h2>Button</h2>

        <div class="row-label">Large — page-level CTAs</div>
        <div class="row">
          <Button size="lg" variant="secondary" client:load>
            Katalog anfordern
            <ArrowRight :size="18" slot="trailing" />
          </Button>
          <Button size="lg" variant="primary" client:load>
            Angebot anfragen
            <ArrowRight :size="18" slot="trailing" />
          </Button>
        </div>

        <div class="row-label">Medium — default</div>
        <div class="row">
          <Button variant="primary" client:load>Primary</Button>
          <Button variant="secondary" client:load>Secondary</Button>
          <Button variant="ghost" client:load>Ghost</Button>
          <Button variant="primary" disabled client:load>Disabled</Button>
        </div>

        <div class="row-label">Small — inline / dense</div>
        <div class="row">
          <Button size="sm" variant="primary" client:load>Text</Button>
          <Button size="sm" variant="secondary" client:load>Text</Button>
          <Button size="sm" variant="ghost" client:load>Text</Button>
        </div>

        <div class="row-label">With icons</div>
        <div class="row">
          <Button variant="primary" client:load>
            <Download :size="16" slot="leading" />
            Download
          </Button>
          <Button variant="secondary" client:load>
            Anrufen
            <Phone :size="16" slot="trailing" />
          </Button>
        </div>

        <div class="row-label">Anchor mode (renders &lt;a&gt;)</div>
        <div class="row">
          <Button href="/hauser" variant="primary" client:load>
            Unsere Häuser
            <ArrowRight :size="16" slot="trailing" />
          </Button>
        </div>
      </section>

      <section class="preview-section">
        <h2>IconButton</h2>
        <p class="hint">Vertical icon + label tiles, for filters and toolbars.</p>
        <div class="row">
          <IconButton label="Hausansichten" client:load>
            <Home slot="icon" />
          </IconButton>
          <IconButton label="Grundrisse" selected client:load>
            <Layers slot="icon" />
          </IconButton>
          <IconButton label="Kontakt" client:load>
            <Phone slot="icon" />
          </IconButton>
        </div>
      </section>

      <section class="preview-section">
        <h2>Privacy badge</h2>
        <p class="hint">Inline SVG, color via CSS <code>color</code> (currentColor).</p>
        <div class="col">
          <PrivacyBtn />
          <PrivacyBtn size={48} />
          <span style="color: var(--clr-content-tertiary)"><PrivacyBtn /></span>
        </div>
      </section>
    </article>
  </body>
</html>

<style>
  body {
    padding-block: var(--spacing-5);
  }

  .preview {
    max-width: 64rem;
    margin-inline: auto;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .preview-head h1 {
    margin-block-end: var(--spacing-2);
  }

  .preview-head p {
    color: var(--clr-content-secondary);
    max-width: 42rem;
  }

  .preview-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    padding-block-end: var(--spacing-5);
    border-bottom: 1px solid var(--clr-border-secondary);
  }

  .preview-section:last-child {
    border-bottom: none;
  }

  .preview-section h2 {
    font-size: var(--fs-h3);
    margin-block-end: var(--spacing-2);
  }

  .hint {
    color: var(--clr-content-tertiary);
    font-size: var(--fs-body-sm);
    margin: 0;
  }

  .row-label {
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
    margin-block-start: var(--spacing-2);
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--spacing-3);
  }

  .col {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    align-items: start;
  }
</style>
