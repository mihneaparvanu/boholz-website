---
import Layout from "@/layouts/Layout.astro";
import PageHero from "@/components/sections/PageHero.astro";
import CTASection from "@/components/sections/CTASection.astro";
import Block from "@/components/sections/Block.astro";
import SectionNavigator from "@/components/ui/SectionNavigator.vue";
import DefinitionList, {
  type DefinitionItem,
} from "@/components/ui/DefinitionList.astro";
import StatBlock from "@/components/ui/StatBlock.vue";
import IconList, { type IconListItem } from "@/components/ui/IconList.vue";
import EditorialCard from "@/components/ui/EditorialCard.vue";
import ComparisonBlock, {
  type ComparisonSide,
} from "@/components/ui/ComparisonBlock.vue";
import VideoPlaceholder from "@/components/ui/VideoPlaceholder.vue";
import Button from "@/components/ui/Button.vue";
import { ArrowRight, Phone } from "lucide-vue-next";
import { getMediaURL } from "@/utils/media";
import FeatureCardPair from "@/features/Advantage/FeatureCardPair.vue";
import LiteYouTube from "@/features/Advantage/LiteYouTube.vue";
import type { FeatureCard } from "@/features/Advantage/advantage.types";
import ProofSection from "@/components/sections/Proof-Section.vue";

// ── Section index — drives the SectionNavigator's overview + sticky rail.
const sections = [
  { id: "qualitaet", eyebrow: "01", label: "Qualität & Zertifikate" },
  { id: "tradition", eyebrow: "02", label: "Tradition & Innovation" },
  { id: "gruende", eyebrow: "03", label: "16 gute Gründe" },
  { id: "nachhaltigkeit", eyebrow: "04", label: "Nachhaltigkeit" },
  { id: "holzfaserdaemmung", eyebrow: "05", label: "Holzfaserdämmung" },
  { id: "wandaufbau", eyebrow: "06", label: "Wandaufbau" },
  { id: "technik", eyebrow: "07", label: "Energietechnik" },
];

// ── R2 image URLs for the advantage subsections.
const nachhaltigkeitHero = getMediaURL(
  "/images/content/advantage/nachhaltigkeit/hero.webp",
);
const nachhaltigkeitVideoPoster = getMediaURL(
  "/images/content/advantage/nachhaltigkeit/video-poster.webp",
);
const holzfaserHero = getMediaURL(
  "/images/content/advantage/holzfaserdaemmung/hero.webp",
);
const wandaufbauHero = getMediaURL(
  "/images/content/advantage/wandaufbau/hero.webp",
);

// ── Section 5 — Holzfaserdämmung side-by-side (Sommer vs Winter).
// The two seasons frame the same material's value from two angles — summer
// heat shielded by the dense fibre, winter warmth retained by it. Bullet
// copy stays anchored to the existing page numbers (11h, 92%, λ 0,036).
const sommer: FeatureCard = {
  eyebrow: "Sommer",
  title: "Hitzeschutz bis in die Nacht",
  lede:
    "Die Holzfaserdämmplatte verzögert sommerliche Hitze um Stunden — Schlafräume bleiben kühl, wenn die Außentemperatur kippt.",
  bullets: [
    "11 Stunden Phasenverschiebung — die Hitze kommt erst nachts an, wenn es draußen längst kühl ist",
    "92 % Temperaturpuffer gegenüber außen — der Innenraum schwingt kaum mit",
    "Hohe spezifische Wärmekapazität (2100 J/(kg·K)) — die Wand speichert, gibt langsam ab",
  ],
  icon: "sun",
  imageURL: getMediaURL(
    "/images/content/advantage/holzfaserdaemmung/sommer.webp",
  ),
  imageAlt:
    "Sommerlicher Hitzeschutz dank Holzfaserdämmung — kühles Innenklima trotz hoher Außentemperaturen",
};

const winter: FeatureCard = {
  eyebrow: "Winter",
  title: "Wärme bleibt, wo sie hingehört",
  lede:
    "Diffusionsoffen und dämmstark zugleich — die Holzfaser hält die Heizenergie im Haus und reguliert dabei die Raumfeuchte ganz natürlich.",
  bullets: [
    "Lambda-Nennwert 0,036 W/(mK) — exzellenter Dämmwert für KfW 40 / KfW 55",
    "Diffusionsoffen — Feuchtigkeit kann nach außen, ohne dass Wärme entweicht",
    "Baubiologisch hervorragend — gesundes Raumklima ohne Mineralfaser",
  ],
  icon: "thermometer",
  imageURL: getMediaURL(
    "/images/content/advantage/holzfaserdaemmung/winter.webp",
  ),
  imageAlt:
    "Winterlicher Wärmeerhalt — Holzfaserdämmung hält die Heizenergie im Haus",
};

// ── Section 6 — Wandaufbau Vergleich (ECO Nature vs ECO Nature Plus).
// Two cards side by side; ECO Nature Plus carries the accent as the
// recommended KfW 40 upgrade. Bullet copy preserves the technical
// differentiators (KfW class, U-Wert, Dämmstärke) without duplicating
// the DefinitionList below.
const ecoNature: FeatureCard = {
  eyebrow: "KfW 55",
  title: "ECO Nature",
  lede:
    "Unser Standard-Wandaufbau — diffusionsoffen, ökologisch gedämmt, Grundlage für ein KfW-Effizienzhaus 55.",
  bullets: [
    "60 mm Holzfaserdämmplatte plus 200 mm Holzrahmen mit Knauf Insulation (WLG 035)",
    "U-Wert 0,164 W/(m²K) — bereits im Standard auf KfW-55-Niveau",
    "Brandschutz F30-B, vollflächige OSB4-Beplankung, Luftdichtheitsebene",
  ],
  icon: "layers",
  imageURL: getMediaURL(
    "/images/content/advantage/wandaufbau/wandaufbau-links.webp",
  ),
  imageAlt: "Schichtaufbau ECO Nature — KfW 55 Standardwand der BoHolz Häuser",
};

const ecoNaturePlus: FeatureCard = {
  eyebrow: "KfW 40",
  title: "ECO Nature Plus",
  lede:
    "Der erweiterte Wandaufbau für noch höhere Energieeffizienz — Grundlage für ein KfW-Effizienzhaus 40 mit maximaler Förderfähigkeit.",
  bullets: [
    "Verstärkter Aufbau mit zusätzlicher Dämmebene — höhere Energieeinsparung",
    "Grundlage für KfW 40 — Anspruch auf die höchste Neubau-Förderstufe",
    "Identisch ökologische Materialien — kein Kompromiss bei Diffusionsoffenheit oder Wohngesundheit",
  ],
  icon: "shield",
  imageURL: getMediaURL(
    "/images/content/advantage/wandaufbau/wandaufbau-rechts.webp",
  ),
  imageAlt:
    "Schichtaufbau ECO Nature Plus — erweiterte Dämmung für KfW 40 Effizienzhäuser",
};

const qualityStats: Array<{
  value: string;
  label: string;
  caption: string;
  icon: "shield" | "award" | "users";
}> = [
  {
    value: "Qualität",
    label: "ständig überwacht",
    caption:
      "Unsere Güter werden ständig überwacht — eigene Qualitätskontrollen plus unabhängige Fremdüberwachung.",
    icon: "shield",
  },
  {
    value: "18 Monate",
    label: "Festpreisgarantie",
    caption:
      "Bei uns haben Sie 18 Monate Festpreisgarantie auf Ihr Bauprojekt.",
    icon: "award",
  },
  {
    value: "Deutschland",
    label: "Made in Germany",
    caption: "Jedes Haus wird in Deutschland produziert.",
    icon: "users",
  },
];

// ── Section 4 — 16 gute Gründe.
// All sixteen original list items preserved verbatim; icons chosen per item
// from the existing IconName union in src/utils/icons.ts.
const sechzehnGruende: IconListItem[] = [
  {
    icon: "leaf",
    label:
      "Nachhaltige diffusionsoffene ausgedämmte Außenwände — optional mit Holzfaserdämmplatte für sommerlichen Hitzeschutz und besten Wohnkomfort",
  },
  {
    icon: "layers",
    label: "Hochwertiger Wandaufbau für Effizienzhaus KfW 40 und KfW 55",
  },
  {
    icon: "shield",
    label:
      "Optional gedämmte Bodenplatte zur Einhaltung klimafreundlicher KfW-Vorgaben",
  },
  {
    icon: "home",
    label:
      "Dachkonstruktion mit einer Schneelast von 2,5 kN/m² bereits im Standard enthalten",
  },
  {
    icon: "thermometer",
    label:
      "Dämmung der Dachflächen bis in den letzten Winkel Ihres Hauses spart wertvolle Energie",
  },
  {
    icon: "messages-square",
    label:
      "Schallreduzierung durch innovative PhoneStrip-Entkopplungsstreifen zwischen Erdgeschoss und Dachgeschoss",
  },
  {
    icon: "lock",
    label:
      "Sicherheitsgeprüfte massive Holzhaustüre (RCN2 Verriegelung) mit barrierefreiem Zugang",
  },
  {
    icon: "sun",
    label: "Gedämmte Rollläden und effektiver Sonnenschutz dank Alulamellen",
  },
  {
    icon: "shield",
    label: "Fenster mit Dreifachverglasung für optimalen Rundum-Schutz",
  },
  {
    icon: "ruler",
    label: "Granitfensterbänke mit hochwertiger zweiter Dichtungsebene",
  },
  {
    icon: "layers",
    label:
      "Innenwände zusätzlich beidseitig mit OSB 4 beplankt und voll ausgedämmt",
  },
  {
    icon: "tree-deciduous",
    label: "Massive Echtholztreppe — perfekt in Optik und Qualität",
  },
  {
    icon: "home",
    label:
      "Barrierefreie und bodengleich geflieste Dusche mit Edelstahlablaufrinne",
  },
  {
    icon: "zap",
    label: "Effiziente Wärmepumpenkonzepte namhafter Hersteller",
  },
  {
    icon: "thermometer",
    label:
      "Individuelle Temperaturregelung dank intelligenter Wärmepumpenkonzepte",
  },
  {
    icon: "hammer",
    label:
      "Made in Germany — Fertighaus-Manufaktur mit hoher Qualität, großer Flexibilität und traditioneller Handwerksleistung",
  },
];

// ── Section 5 — Holzbau vs konventionell.
// Both sides derived from the existing six "feature-card" entries plus the
// Holzfaserdämmung block — the original sustainability claims, restructured
// as a side-by-side so the contrast is legible at a glance.
const konventionell: ComparisonSide = {
  title: "Konventioneller Hausbau",
  caption: "Beton, Ziegel, mineralische Dämmstoffe",
  items: [
    "Hohe CO₂-Emissionen schon beim Bau",
    "Energieintensive, oft fossile Heizsysteme",
    "Plastik- oder mineralfaserbasierte Dämmstoffe",
    "Lange Transportwege für Baustoffe",
    "Schwer recyclebare Materialkombinationen",
    "Trockene, träge regulierte Raumluft",
  ],
};

const holzbau: ComparisonSide = {
  title: "BoHolz Holzbau",
  caption: "Holz aus regionaler nachhaltiger Forstwirtschaft",
  items: [
    "Ein Haus bindet durchschnittlich 30 Tonnen CO₂",
    "KfW 55 / KfW 40 Standard mit staatlicher Förderung",
    "Diffusionsoffene Holzfaserdämmung, λ 0,036 W/(mK)",
    "Regionale Wertschöpfung, kurze Wege",
    "Am Ende der Lebensdauer recycelbar oder thermisch verwertbar",
    "Natürlich feuchteregulierendes, gesundes Raumklima",
  ],
};

// ── Section 7 — ECO Nature Wandaufbau (KfW 55).
// Verbatim from the original "ECO Nature" list; the U-Wert and Brandschutz
// kicker survives as the final two rows so all numeric specs stay grouped.
const ecoNatureLayers: DefinitionItem[] = [
  {
    term: "Außenputz",
    description:
      "Hochwertiger, diffusionsoffener Silikonharz-Edelputz, helle Tönung",
  },
  {
    term: "Armierung",
    description:
      "Grundputz aus Armierungsmasse und vollflächiges Gittergewebe",
  },
  {
    term: "Holzfaserdämmplatte",
    description: "60 mm — sommerlicher Hitzeschutz, diffusionsoffen",
  },
  {
    term: "Holzrahmen",
    description:
      "200 mm Holzrahmenkonstruktion mit ökologischer Knauf Insulation (WLG 035)",
  },
  {
    term: "OSB4-Platte",
    description: "12 mm — aussteifende Beplankung",
  },
  {
    term: "Luftdichtheitsebene",
    description: "0,2 mm — kontrolliert den Feuchteübergang",
  },
  {
    term: "Innenbeplankung",
    description: "12,5 mm Gipskarton Feuerschutzplatte",
  },
  {
    term: "U-Wert",
    description: "0,164 W/(m²K)",
  },
  {
    term: "Brandschutz",
    description: "F30-B",
  },
];

// ── Section 8 — Haus- & Energietechnik.
// Three IconList items, each preserves the original paragraph as description.
const technik: IconListItem[] = [
  {
    icon: "zap",
    label: "Wärmepumpen",
    description:
      "Verschiedene Wärmepumpenlösungen ab der technikfertigen Ausbaustufe — renommierte Hersteller wie Nibe und Tecalor sorgen von Anfang an für geringere Energiekosten.",
  },
  {
    icon: "sun",
    label: "Photovoltaik",
    description:
      "Beratung zur passenden PV-Anlage inklusive Stromspeichersystem — nahezu unabhängig werden und Energiekosten weiter senken.",
  },
  {
    icon: "leaf",
    label: "Gesundes Raumklima",
    description:
      "Diffusionsoffene Wände sorgen für einen natürlichen Feuchtigkeitsausgleich und ein außerordentlich angenehmes Raumklima.",
  },
];
---

<Layout title="Das BoHolz Versprechen — BoHolz Haus">
  <!-- 0. Hero ----------------------------------------------------------- -->
  <div class="full-width">
    <PageHero
      eyebrow="Unser Versprechen"
      title="Das BoHolz"
      highlight="Versprechen"
      subtitle="Höchste Bauqualität. Gelebte Nachhaltigkeit. Persönliche Begleitung — vom ersten Entwurf bis zum Einzug."
      image={nachhaltigkeitHero}
      imageAlt="BoHolz Holzbau in der Manufaktur — gelebter Qualitätsanspruch"
      align="center"
    />
  </div>

  <!-- 0b. Zertifikate & Siegel (full-bleed band, mirrors homepage) ------ -->
  <Block tone="band">
    <ProofSection client:visible />
  </Block>

  <!-- 1. Section overview + sticky rail -------------------------------- -->
  <SectionNavigator client:load pageTitle="Unser Versprechen" sections={sections} stickyOffset={64} />

  <!-- 2. Qualität & Zertifikate ---------------------------------------- -->
  <Block
    id="qualitaet"
    eyebrow="01 — Qualität & Zertifikate"
    heading="Qualität, die sich überprüfen"
    highlight="lässt."
    lede="Unser oberstes Ziel ist die Zufriedenheit unserer Kunden, dicht gefolgt von einem hohen Qualitätsstandard. Der Bau eines Hauses ist eine der wichtigsten Entscheidungen im Leben — wir gestalten den Prozess so angenehm und erfolgreich wie möglich."
  >
    <div class="stats">
      {
        qualityStats.map((s) => (
          <StatBlock
            client:visible
            value={s.value}
            label={s.label}
            caption={s.caption}
            icon={s.icon}
          />
        ))
      }
    </div>
  </Block>

  <!-- 3. Tradition trifft Innovation ----------------------------------- -->
  <Block
    id="tradition"
    tone="band"
    eyebrow="02 — Tradition & Innovation"
    heading="Generationen-Handwerk, moderne"
    highlight="Fertigung."
    lede="BoHolz vereint jahrzehntelanges Wissen rund um den Fertighausbau mit moderner CNC-Fertigung. Das Ergebnis: handwerkliche Wertarbeit im traditionellen Sinne, getragen von einer Manufaktur, die jeden Schritt selbst verantwortet."
  >
    <div class="steps">
      <EditorialCard
        client:visible
        step={1}
        title="Tradition"
        icon="hammer"
        description="Generationsübergreifendes Wissen rund um den Fertighausbau — handwerkliche Wertarbeit im traditionellen Sinne, getragen von einer eigenständigen Manufaktur in Deutschland."
      />
      <EditorialCard
        client:visible
        step={2}
        title="Moderne Fertigung"
        icon="wrench"
        description="Innovative CNC-Maschinen für präzise Fertigung, automatisierte Anlagen für effiziente Produktion und kontinuierliche Weiterentwicklung unserer Baumethoden."
      />
      <EditorialCard
        client:visible
        step={3}
        title="Zertifizierungen"
        icon="award"
        description="Mitglied der Qualitätsgemeinschaft Deutscher Fertigbau (QDF) und der Gemeinschaft Deutscher Fertigbau (GDF) — ständige Qualitätssicherung der Materialien, regelmäßige Kontrollen, Eigen- und Fremdüberwachung durch unabhängige Prüfinstitute."
      />
    </div>
  </Block>

  <!-- 4. 16 gute Gründe ------------------------------------------------ -->
  <Block
    id="gruende"
    eyebrow="03 — 16 gute Gründe"
    heading="Was in jedem BoHolz Fertighaus"
    highlight="serienmäßig steckt."
    lede="Vom diffusionsoffenen Wandaufbau bis zur barrierefreien Dusche — sechzehn Details, die wir bereits im Standard liefern."
  >
    <IconList client:visible items={sechzehnGruende} columns={4} />
  </Block>

  <!-- 5. Nachhaltigkeit — Vergleich + Video ---------------------------- -->
  <Block
    id="nachhaltigkeit"
    tone="band"
    eyebrow="04 — Nachhaltigkeit"
    heading="Wohnträume mit aktivem"
    highlight="Umweltschutz."
    lede="Bei BoHolz Haus verbinden wir Ihre Wohnträume mit aktivem Umweltschutz. Unsere individuellen Fertighäuser aus Holz sind nicht nur Ihr persönliches Zuhause, sondern auch ein Beitrag zu einer besseren Zukunft."
  >
    <!-- Hero image + lite-YouTube. Two-up on desktop so the image sets the
         scene and the video sits as the active companion; stacks on mobile.
         The video stays idle until the user clicks — no YouTube JS loads on
         page load. -->
    <div class="media-pair">
      <figure class="media-hero">
        <img
          src={nachhaltigkeitHero}
          alt="Nachhaltige Holzbauweise im BoHolz Werk — gelebter Umweltschutz von der Materialwahl bis zur Fertigung"
          loading="lazy"
        />
      </figure>
      <LiteYouTube
        client:visible
        videoId="0abnY3Re-tU"
        posterURL={nachhaltigkeitVideoPoster}
        label="BoHolz — Nachhaltigkeit erleben"
        caption="Wie wir bauen und warum — drei Minuten Werksrundgang."
      />
    </div>

    <ComparisonBlock
      client:visible
      left={konventionell}
      right={holzbau}
      accent="right"
    />

    <!-- Three numbers that quantify the holzbau side of the comparison above. -->
    <div class="stats-trio">
      <div class="stats">
        <StatBlock
          client:visible
          value="30 t"
          label="CO₂ je Haus"
          caption="Durchschnittliche Kohlenstoffbindung im Holzbau — entlastet die Atmosphäre über die gesamte Lebensdauer."
          icon="leaf"
        />
        <StatBlock
          client:visible
          value="11 h"
          label="Phasenverschiebung"
          caption="Holzfaserdämmung verzögert sommerliche Hitze um elf Stunden — der Innenraum bleibt nachts kühl."
          icon="thermometer"
        />
        <StatBlock
          client:visible
          value="92 %"
          label="Temperaturpuffer"
          caption="Anteil der äußeren Temperaturschwankung, der dank des Wandaufbaus nicht im Inneren ankommt."
          icon="shield"
        />
      </div>
      <p class="footnote">
        Plus: Lambda-Nennwert 0,036 W/(mK), spezifische Wärmekapazität 2100 J/(kg·K),
        hoher Schallschutz, dampfdiffusionsoffen und baubiologisch hervorragend.
      </p>
    </div>
  </Block>

  <!-- 7. Holzfaserdämmung ─ Sommer / Winter ---------------------------- -->
  <Block
    id="holzfaserdaemmung"
    eyebrow="05 — Holzfaserdämmung"
    heading="Eine Wand. Zwei"
    highlight="Jahreszeiten."
    lede="Die Holzfaserdämmplatte ist das stille Bauteil hinter unserem Wandaufbau — schützt im Sommer vor Hitze, hält im Winter Wärme, das ganze Jahr diffusionsoffen."
  >
    <figure class="hero-image">
      <img
        src={holzfaserHero}
        alt="Holzfaserdämmplatten im BoHolz Wandaufbau — natürlicher Hitze- und Kälteschutz"
        loading="lazy"
      />
    </figure>
    <FeatureCardPair client:visible left={sommer} right={winter} />
  </Block>

  <!-- 8. Wandaufbau ---------------------------------------------------- -->
  <Block
    id="wandaufbau"
    tone="band"
    eyebrow="06 — Wandaufbau"
    heading="ECO Nature — die Schichten unserer"
    highlight="Gebäudehülle."
    lede="Die größten Energieverluste eines Hauses treten über seine äußere Hülle auf. ECO Nature schützt effektiv vor Hitze, Kälte, Lärm und Feuer — Schicht für Schicht."
  >
    <figure class="hero-image">
      <img
        src={wandaufbauHero}
        alt="ECO Nature Wandaufbau — diffusionsoffener Mehrschichtaufbau für KfW-Effizienzhäuser"
        loading="lazy"
      />
    </figure>

    <!-- Two-up overview: ECO Nature vs ECO Nature Plus. Sits above the
         deeper-spec DefinitionList so the user reads the high-level
         choice first, then drills into the layer-by-layer detail. -->
    <FeatureCardPair
      client:visible
      left={ecoNature}
      right={ecoNaturePlus}
      accent="right"
    />

    <details class="layers-details">
      <summary>Schicht für Schicht — alle Werte im Detail</summary>
      <div class="layers-inner">
        <DefinitionList items={ecoNatureLayers} layout="grid" />
      </div>
    </details>
  </Block>

  <!-- 9. Haus- & Energietechnik ---------------------------------------- -->
  <Block
    id="technik"
    eyebrow="07 — Energietechnik"
    heading="Wärmepumpen, Photovoltaik,"
    highlight="gesundes Raumklima."
    lede="Dank gut gedämmter Außenwände bieten unsere Häuser von Anfang an umweltschonende Materialien und energieeffiziente Bauweise. Drei Bausteine, die Nachhaltigkeit konkret machen."
  >
    <IconList client:visible items={technik} columns={1} density="comfortable" />
  </Block>

  <!-- 9b. Werksrundgang Video Slot ------------------------------------- -->
  <Block tone="band">
    <VideoPlaceholder
      client:visible
      slotId="versprechen-werksrundgang"
      aspectRatio="16/9"
      variant="film"
      label="Werksrundgang — bald verfügbar"
      caption="Ein Blick hinter die Kulissen der Manufaktur."
    />
  </Block>

  <!-- 10. CTA --------------------------------------------------------- -->
  <div class="full-width">
    <CTASection
      tone="accent"
      title="Bereit für Ihr"
      highlight="BoHolz-Haus?"
      subtitle="Vereinbaren Sie eine persönliche Beratung oder bestellen Sie den Katalog mit allen Modellen und Ausstattungsdetails."
    >
      <Fragment slot="actions">
        <Button client:visible variant="secondary" size="lg" href="/kontakt">
          Beratungstermin vereinbaren
          <ArrowRight slot="trailing" :size="16" :stroke-width="2" />
        </Button>
        <Button client:visible variant="ghost" size="lg" href="/kontakt">
          <Phone slot="leading" :size="16" :stroke-width="2" />
          Katalog bestellen
        </Button>
      </Fragment>
    </CTASection>
  </div>
</Layout>

<style>
  /* Stats trio nested inside the Nachhaltigkeit band — same visual shape
     as the prior standalone .stats-band, just lives one nesting deeper so
     the page's tonal alternation stays clean. */
  .stats-trio {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    width: 100%;
  }

  .stats-trio .footnote {
    margin: 0;
    font-size: var(--fs-body-sm);
    color: var(--clr-content-tertiary);
    max-width: 64ch;
    line-height: var(--lh-body);
  }

  /* Stats trio — three columns from tablet up. */
  .stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (--from-tablet) {
    .stats {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--spacing-5);
    }
  }

  /* Tradition → Modernisierung → Zertifizierungen — three editorial cards. */
  .steps {
    display: grid;
