---
/**
 * Homepage · `/`
 *
 * Pattern-matches the canonical landing template. Same section composition;
 * homepage-specific deltas are the ProofSection sliver above the trust band
 * and the TrustBadges full-bleed band. See
 * `design-audit/2026-05-16/LANDING-PAGES-PLAN.md`.
 *
 * Section composition (top → bottom):
 *   1. PageHero            — full-bleed photo + 2 CTAs
 *   1a. ProofSection       — sliver between hero and trust band
 *   1b. TrustBadges        — full-bleed tinted band
 *   2. BenefitsRow         — 4 pastel-tinted benefit cards
 *   3. HouseModelsCarousel — live DB models, filtered + capped
 *   4. ImageBand           — full-bleed lifestyle photo, eyebrow + heading
 *   5. AudienceBlock       — 4-row "for whom" editorial list
 *   6. TwoColumn           — sustainability narrative (image + copy)
 *   7. TestimonialBand     — dark olive band with 3 quotes + badges
 *   8. FAQAccordion        — 3–6 page-specific FAQs
 *   9. LeadFormBand        — split rail + form, pre-selected interest
 *
 * Note: the closing CTA block was removed from the homepage on 2026-05-18
 * (client feedback) — the lead form is the page's final beat. Other landing
 * pages still render `closingCta` from their content modules.
 */
import Layout from "@/layouts/Layout.astro";
import { getMediaURL } from "@/lib/media";

import HomeHero from "@/features/home/hero/HomeHero.astro";
import Block from "@/ui/sections/Block.astro";
import BenefitsRow from "@/ui/sections/BenefitsRow.astro";
import HouseModelsCarousel from "@/ui/sections/HouseModelsCarousel.vue";
import ImageBand from "@/ui/sections/ImageBand.astro";
import AudienceBlock from "@/ui/sections/AudienceBlock.astro";
import TwoColumn from "@/ui/sections/TwoColumn.astro";
import Reviews from "@/features/reviews/Reviews.astro";
import LeadFormBand from "@/ui/sections/LeadFormBand.vue";

import Button from "@/ui/primitives/Button.vue";

import { getCategories, getModels } from "@/db/loaders";
import { toHouseModelCard } from "@/lib/derive";

import { uebersichtContent as content } from "@/features/landing/uebersicht.content";
import ProofSection from "@/ui/sections/Proof-Section.vue";
import TrustBadges from "@/features/home/TrustBadges/TrustBadges.vue";
import { trustBadges } from "@/features/home/TrustBadges/trust-badges.content";
import { homeSections } from "@/features/home/home.content";
import Overview from "@/features/home/Overview/Overview.vue";
import { featuredCard, overviewCardsSecondary } from "@/features/home/Overview/overview.content";
import Faq from "@/features/faq/Faq.vue";
import { qaCategories } from "@/features/faq/qa";


const categories = await getCategories();
const houseModels = await getModels();

const houseCards = houseModels.map((m) => toHouseModelCard(m));

const heroImage = getMediaURL("/images/brand/home-hero.webp");
const heroVideoWebm = getMediaURL("/videos/home/home-hero-1080.webm");
const heroVideoMp4 = getMediaURL("/videos/home/home-hero-1080.mp4");
const heroVideoWebmMobile = getMediaURL("/videos/home/home-hero-720.webm");
const heroVideoMp4Mobile = getMediaURL("/videos/home/home-hero-720.mp4");
const imageBandImage = getMediaURL(content.imageBand.imageFallbackPath);
const sustainabilityImage = getMediaURL(content.sustainability.imageFallbackPath);
---

<Layout title={content.seo.title} categories={categories}>
  <!-- ── 01 · Hero (full-bleed) ────────────────────────────────── -->
  <div class="full-width hero-wrap">
    <HomeHero
      title={content.hero.title}
      highlight={content.hero.highlight}
      subtitle={content.hero.subtitle}
      image={heroImage}
      imageAlt={content.hero.imageAlt}
      align="left"
      context="home"
      videoWebm={heroVideoWebm}
      videoMp4={heroVideoMp4}
      videoWebmMobile={heroVideoWebmMobile}
      videoMp4Mobile={heroVideoMp4Mobile}
    >
      <Fragment slot="actions" class="actions">
        <Button variant="secondary" size="lg" href={content.hero.secondaryCta.href}>
          {content.hero.secondaryCta.label}
        </Button>
      </Fragment>
    </HomeHero>
  </div>

  <Block><ProofSection /></Block>

  <!-- ── 01b · Trust band (full-bleed) ──────────────────────────── -->
  <Block
    id={homeSections.trust.id}
    eyebrow={homeSections.trust.eyebrow}
    heading={homeSections.trust.heading1}
    highlight={homeSections.trust.highlight}
    lede={homeSections.trust.subheading}
    tone="band"
    align="center"
  >
    <TrustBadges client:visible badges={trustBadges} />
  </Block>

 
  
  <!-- ── 02 · Benefits row ─────────────────────────────────────── -->
  <Block
    id="vorteile"
    eyebrow={content.benefitsIntro.eyebrow}
    heading={content.benefitsIntro.heading}
    highlight={content.benefitsIntro.highlight}
    lede={content.benefitsIntro.lede}
  >
    <BenefitsRow items={content.benefits} />
  </Block>


  <!-- ── 03 · House showcase ───────────────────────────────────── -->
  <Block
    id="hausmodelle"
    eyebrow={content.houses.eyebrow}
    heading={content.houses.heading}
    highlight={content.houses.highlight}
    lede={content.houses.lede}
  >
    {
      houseCards.length > 0 ? (
        <HouseModelsCarousel
          categories={categories}
          client:visible
          models={houseCards}
          ariaLabel="Empfohlene Hausmodelle"
        />
      ) : (
        <p class="empty">
          Aktuell keine empfohlenen Modelle für diese Kategorie.
          Bitte sehen Sie sich
          <a href="/hauser"> die vollständige Übersicht </a>
          an.
        </p>
      )
    }
  </Block>

   <!-- ── 01c · Overview (featured + secondary cards) ────────────── -->
  <Block
    id={homeSections.overview.id}
    eyebrow={homeSections.overview.eyebrow}
    heading={homeSections.overview.heading1}
    highlight={homeSections.overview.highlight}
    lede={homeSections.overview.subheading}

  >
    <Overview client:visible featured={featuredCard} cards={overviewCardsSecondary} />
  </Block>

  <!-- ── 04 · Image band (full-bleed lifestyle) ─────────────────── -->
  <ImageBand
    eyebrow={content.imageBand.eyebrow}
    heading={content.imageBand.heading}
    highlight={content.imageBand.highlight}
    lede={content.imageBand.lede}
    image={imageBandImage}
    imageAlt={content.imageBand.imageAlt}
    rule
  />

  <!-- ── 05 · Audience block ───────────────────────────────────── -->
  <Block
    id="zielgruppen"
    eyebrow={content.audience.eyebrow}
    heading={content.audience.heading}
    highlight={content.audience.highlight}
    lede={content.audience.lede}
  >
    <AudienceBlock items={content.audience.items} />
    <Fragment slot="actions">
      <Button client:load variant="primary" size="md" href={content.hero.primaryCta.href}>
        {content.hero.primaryCta.label}
      </Button>
      <Button client:load variant="ghost" size="md" href={content.hero.secondaryCta.href}>
        {content.hero.secondaryCta.label}
      </Button>
    </Fragment>
  </Block>

  <!-- ── 06 · Sustainability (two-column) ───────────────────────── -->
  <Block id="nachhaltigkeit">
    <TwoColumn
      eyebrow={content.sustainability.eyebrow}
      title={content.sustainability.title}
      highlight={content.sustainability.highlight}
      subtitle={content.sustainability.subtitle}
      image={sustainabilityImage}
      imageAlt={content.sustainability.imageAlt}
      reverse={content.sustainability.reverse}
    >
      <div class="prose">
        {content.sustainability.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      {content.sustainability.cta && (
        <Fragment slot="actions">
          <Button client:load variant="primary" size="md" href={content.sustainability.cta.href}>
            {content.sustainability.cta.label}
          </Button>
        </Fragment>
      )}
    </TwoColumn>
  </Block>

  {/* ── 07 · Google reviews (full-bleed band) — live from Places API.
        Same "Langjährige Erfahrung im Holzfertigbau" copy as before; the
        review cards render under the subtitle. ──────────────────────── */}
  <Reviews
    eyebrow={content.trust.eyebrow}
    heading={content.trust.heading}
    highlight={content.trust.highlight}
    lede={content.trust.lede}
    tone={content.trust.tone}
    badges={content.trust.badges}
  />



  <!-- ── 08 · FAQ ──────────────────────────────────────────────── -->
  <!-- Multi-category FAQ. Framing uses `homeSections.qa` to match the
       previous home tone; data lives in `src/content/qa.ts`. -->
  <Block
    id={homeSections.qa.id}
    eyebrow={homeSections.qa.eyebrow}
    heading={homeSections.qa.heading1}
    highlight={homeSections.qa.highlight}
    lede={homeSections.qa.subheading}
  >
    <Faq client:visible categories={qaCategories} />
  </Block>

  <!-- ── 09 · Lead form (full-bleed) — last beat on the page ────── -->
  <LeadFormBand
    client:visible
    eyebrow={content.leadForm.eyebrow}
    heading={content.leadForm.heading}
    highlight={content.leadForm.highlight}
    lede={content.leadForm.lede}
    subCopy={content.leadForm.subCopy}
    contact={content.leadForm.contact}
    interestOptions={content.leadForm.interestOptions}
    tone={content.leadForm.tone}
  />
</Layout>

<style>
  /* Hero overrides — `--hero-align` inherits into PageHero's scoped CSS,
     so this one works without `:global`. Everything else has to pierce
     the scope boundary because `.hero`, `.inner`, and `.actions` live
     inside PageHero.astro. */
  .hero-wrap {
    --hero-align: end;
    /* Dark glass so the white subtitle stays legible even where the
       backdrop-filter blur doesn't render (Firefox won't blur over the
       <video> background). Blur is an enhancement on top, not a crutch. */
    --subtitle-bg: rgba(0, 0, 0, 0.4);
    --subtitle-bg-blur: 10px;
    --subtitle-padding: var(--spacing-3) var(--spacing-4);
    --subtitle-radius: var(--radius-md);
    --subtitle-border: rgba(255, 255, 255, 0.24);
    --scrim-bg: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.05) 0%,
      rgba(0, 0, 0, 0.12) 100%
    );
  }

  /* Tablet — H1 sits between mobile's emotional bump and the desktop
     scale token. Native --fs-h2 at tablet caps around 38px; nudge to
     ~46-50px so the headline still feels like a hero, not a card title. */
  @media (--tablet) {
    .hero-wrap :global(.hero h1) {
      font-size: calc(var(--fs-h1) * 1.05);
      line-height: 1.04;
      letter-spacing: -0.01em;
    }
    .hero-wrap :global(.hero .highlight) {
      font-size: calc(var(--fs-h1) * 1.05);
    }
  }

  /* Single hero CTA — cap its width so the secondary button doesn't
     stretch across the column on desktop. Mobile keeps the full-width
     stretched layout from Button.vue's mobile rules. */
  @media (--from-desktop) {
    .hero-wrap :global(.actions > .btn) {
      min-width: 220px;
    }
  }

  @media (--mobile) {
    /* Mobile hero override: copy sits at the TOP of the photo, so we flip
       the scrim — light tint up top for legibility, fades out fast so the
       house stays vivid. The glass-light subtitle card carries the readability
       load, so the scrim itself can stay very subtle. */
    .hero-wrap {
      --scrim-bg: linear-gradient(
        to bottom,
        rgba(0, 0, 0, 0.15) 0%,
        rgba(0, 0, 0, 0.05) 75%
      );
    }

    /* Trim the hero secondary CTA so it doesn't dominate the stack, but
       keep enough padding-block to feel tappable. Targets the slotted
       Button's inner `.btn`. */
    .hero-wrap :global(.actions > .btn[data-size="lg"]) {
      padding-block: var(--spacing-3);
      font-size: var(--fs-body);
      border-radius: var(--radius-md);
    }

    /* Center the hero copy on mobile even though desktop is `align="left"`.
       Selector includes `[data-align="left"]` to match PageHero's own
       specificity so we win the cascade. */
    .hero-wrap :global(.hero[data-align="left"] .inner) {
      text-align: center;
      align-items: center;
      margin-inline: auto;
    }

    .hero-wrap :global(.actions) {
      justify-content: center;
      align-items: center;
    }
  }



  /* Empty-state copy when no DB models match the page's category filter. */
  .empty {
    margin: 0;
    padding: var(--spacing-3) 0;
    color: var(--clr-content-tertiary);
    font-size: var(--fs-body);
    text-align: center;
  }

  .empty a {
    color: var(--clr-accent-secondary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--clr-accent-secondary) 40%, transparent);
    text-underline-offset: 2px;
  }

  /* Sustainability paragraphs — vertical stack inside TwoColumn's default
     slot. Width is governed by TwoColumn's content column. */
  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    max-width: 64ch;
  }

  .prose p {
    margin: 0;
    color: var(--clr-content-secondary);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  /* Premium Partner badge — small centered mark sitting between the trust
     band and the benefits row. Restrained on purpose so it reads as a
     trust signal, not a hero element. */
  .premium-partner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-2);
    text-align: center;
  }

  .premium-partner p {
    margin: 0;
    text-transform: uppercase;
    font-size: var(--fs-body-sm);
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-secondary);
  }
</style>
