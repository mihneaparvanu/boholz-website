---
// Framework Components
import { getMediaURL } from "../utils/media";

// Layout
import Layout from "../layouts/Layout.astro";
import Section from "../layouts/Section.astro";

// Components
import CategorySlider from "../features/CategorySlider/CategorySlider.vue";
import type { HouseCategory } from "../types/models";
import "../style/wrapper.css";

import { getCategories } from "../data/loaders";

const categories = await getCategories();
---

<Layout title="Boholz Haus" categories={categories}>
    <div class="hero full-width">
      <div class="hero-inner">
        <div class="hero-content">
          <div class="hero-heading">
            <h1>Einfach einkommen.</h1>
            <h2>Ihr Zuhause, meisterhaft vollendet.</h2>
          </div>
          <div class="hero-end-group">
            <div class="hero-proof"></div>
            <div class="hero-action"></div>
          </div>
        </div>
      </div>
      <div class="hero-img-bg"></div>
      <img
        src={getMediaURL("/images/brand/hero.jpg")}
        alt="A picture of the Stadtvilla on a mountain valley"
        width={1200}
        height={800}
        class="hero-img-bg"
      />
    </div>

  
    <Section
      heading="Fertighäuser in Zimmermannsqualität für Menschen mit"
      highlightWord="Anspruch."
      subheading="Unsere barrierefreien Fertighäuser aus Holz vereinen höchste Energieeffizienz mit meisterhaftem Handwerk. So sparen Sie Energiekosten und gewinnen wertvolle Lebensqualität für die ganze Familie."
    >
      <CategorySlider client:load categories={categories} />
    </Section>
    <Section
      heading="Ihr Vertrauen"
      highlightWord="fest verankert."
      subheading="Wir bauen nicht nur Häuser, wir bauen Sicherheit. Mit zertifizierter Qualität aus Deutschland und Garantien, auf die Sie sich verlassen können."
    />
  </Layout>

  <style>
    .hero {
      height: 100dvh;
      position: relative;
      color: var(--clr-surface-primary);
    }

    .hero-inner {
      display: flex;
      flex-direction: column;
      justify-content: end;
      align-items: start;
      width: 100%;
      height: 100%;
    }

    .hero-heading {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-2);
      padding-block-end: var(--spacing-5);
      padding-inline-start: var(--spacing-5);

      h2 {
        font-size: var(--fs-h4);
      }
    }

    .hero-img-bg {
      background-color: var(--clr-content-secondary);
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: -1;
    }
  </style>

