---
import Layout from "@/layouts/Layout.astro";

import PageHero from "@/components/sections/PageHero.astro";
import EyebrowHeadingLede from "@/components/ui/EyebrowHeadingLede.astro";
import Divider from "@/components/ui/Divider.astro";
import StatBlock from "@/components/ui/StatBlock.vue";

import ContactForm from "@/features/ContactForms/ContactForm.vue";
import LocationsMap from "@/features/Locations/LocationsMap.vue";
import { getLocations } from "@/data/loaders";

import { MessagesSquare, Home, MapPin } from "lucide-vue-next";

const locations = await getLocations({ exceptKind: "showhouse" });
---

<Layout title="Kontakt – BoHolz Haus">

  <section id="erreichbar" class="section contact-hero">

    <div class="contact-details">
      <EyebrowHeadingLede
        eyebrow="Direkt erreichbar" 
        heading="Telefon, E-Mail —"
        highlight="oder persönlich."
        lede="Das persönliche Gespräch kann nichts ersetzen. Rufen Sie uns an oder schreiben Sie kurz, wann wir uns am besten zurückmelden."
      >
        <Fragment slot="eyebrow-icon">
          <MessagesSquare :size={14} :stroke-width={2} />
        </Fragment>
      </EyebrowHeadingLede>

      <div class="info-box">
        <p><strong>BoHolz-Haus GmbH</strong></p>
        <p>Ostring 1<br />97688 Bad Kissingen</p>
        <p>
          Telefon: <a href="tel:+49971785557150">0971 / 78 55 57 15</a><br />
          E-Mail: <a href="mailto:info@boholz-haus.de">info@boholz-haus.de</a>
        </p>
        <p><strong>Öffnungszeiten</strong></p>
        <p>
          Mo – Fr: 08:00 – 17:00 Uhr<br />
          Sa &amp; So: Geschlossen
        </p>
        <p class="muted">
          <em>An gesetzlichen Feiertagen können Öffnungszeiten abweichen.</em>
        </p>
      </div>
    </div>

    <div class="form-col">
      <EyebrowHeadingLede
        eyebrow="Bauanfrage"
        heading="Sprechen Sie mit uns über Ihr"
        highlight="Bauvorhaben."
        lede="Erzählen Sie uns kurz, wie Sie wohnen möchten — wir melden uns mit einem passenden Vorschlag und allen Unterlagen zurück."
      >
        <Fragment slot="eyebrow-icon">
          <Home :size={14} :stroke-width={2} />
        </Fragment>
      </EyebrowHeadingLede>

      <div class="form-wrap">
        <ContactForm client:visible />
      </div>
    </div>
  </section>

  <!-- Service-promise trio — page-level, sits between the contact split
       and the rest of the page so the promise reads as a closing beat. -->
  <section class="section stats-band" aria-label="Service auf einen Blick">
    <StatBlock
      client:visible
      value="24 h"
      label="Antwortzeit"
      caption="Werktagsanfragen beantworten wir meist noch am selben Tag."
      icon="messages-square"
      align="center"
    />
    <StatBlock
      client:visible
      value="0 €"
      label="Beratung kostenfrei"
      caption="Erstgespräch, Hauskatalog und Bedarfsanalyse — ohne Verpflichtung."
      icon="heart-handshake"
align="center"
    />
    <StatBlock
      client:visible
      value="5"
      label="Standorte"
      caption="Vertriebsbüros, Musterhäuser und Zentrale in Bad Kissingen."
      icon="map-pin"
align="center"
    />
  </section>

</Layout>

<style>
  /* ============================================================
     Section rhythm — mirrors `uber-uns.astro` / `unser-versprechen.astro`.
     `<main class="wrapper">` lands children in the content column unless
     they declare `.full-width` and re-establish their own width via
     `.band-inner`.
     ============================================================ */
  .section {
    padding-block: var(--spacing-5);
  }

  .contact-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-6);
    align-items: start;
  }

  @media (--below-desktop) {
    .contact-hero {
      grid-template-columns: 1fr;
      gap: var(--spacing-5);
    }
  }

  .contact-details {
    position: sticky;
    top: var(--spacing-5);
  }

  @media (--below-desktop) {
    .contact-details {
      position: static;
    }
  }

  /* Alternating-tone band — wraps every other content section in a tinted
     full-width surface. */
  .band {
    background: var(--clr-surface-secondary);
    padding-inline: var(--padding-inline);
  }

  .band-inner {
    max-width: var(--content-max-width);
    margin-inline: auto;
    width: 100%;
  }

  /* Service-promise trio — horizontal three-up band sitting between the
     two-column hero and the rest of the page. Stacks on mobile. */
  .stats-band {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--spacing-5);
    padding-block-start: var(--spacing-6);
    border-block-start: 1px solid var(--clr-border-secondary);
    margin-block-start: var(--spacing-6);
  }

  @media (--below-desktop) {
    .stats-band {
      grid-template-columns: 1fr;
      gap: var(--spacing-4);
    }
  }

  /* Contact details card — typographic, not chrome-heavy.
     Bounded measure so the address block holds a comfortable shape on
     wide screens. */
  .info-box {
    max-width: 38rem;
    margin-block-start: var(--spacing-4);
    padding: var(--spacing-4);
    background: var(--clr-surface-primary);
    border: 1px solid var(--clr-border-secondary);
    border-radius: var(--radius-md);
    color: var(--clr-content-primary);
    line-height: var(--lh-body);
  }

  .info-box p {
    margin: 0;
  }

  .info-box p + p {
    margin-block-start: var(--spacing-2);
  }

  .info-box a {
    color: var(--clr-content-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
  }

  .info-box a:hover {
    color: var(--clr-accent-primary);
  }

  .info-box .muted {
    color: var(--clr-content-tertiary);
    font-size: var(--fs-body-sm);
  }

  /* Bauanfrage column — anchored to the right edge of its grid cell so
     the form reads as the primary action. Bounded measure keeps inputs
     at a comfortable reading width. */
  .form-col {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    min-width: 0;
    max-width: 36rem;
    margin-inline-start: auto;
  }

  /* Form wrapper — adds breathing room between the EyebrowHeadingLede
     and the form itself. */
  .form-wrap {
    margin-block-start: var(--spacing-3);
  }

  /* Map wrapper — full-width bleed within the section, so the map
     reads as a primary surface rather than a contained widget. */
  .map-wrap {
    margin-block-start: var(--spacing-4);
    width: 100%;
  }
</style>
