---
import Layout from "@/layouts/Layout.astro";
import { getMediaURL } from "@/utils/media";

import PageHero from "@/components/sections/PageHero.astro";
import CTASection from "@/components/sections/CTASection.astro";
import Block from "@/components/sections/Block.astro";

import SectionNavigator from "@/components/ui/SectionNavigator.vue";
import type { Section } from "@/components/ui/SectionNavigator.vue";
import EditorialCard from "@/components/ui/EditorialCard.vue";
import IconList from "@/components/ui/IconList.vue";
import type { IconListItem } from "@/components/ui/IconList.vue";
import Callout from "@/components/ui/Callout.vue";
import BuildingStagesCarousel from "@/features/Home/BuildingStages/BuildingStagesCarousel.vue";
import { buildingStages } from "@/features/Home/BuildingStages/building-stages.content";
import {
  buildPhases,
  bauphasenHeroImageURL,
} from "@/features/Bauphasen/bauphasen.content";

const sections: Section[] = [
  { id: "ablauf",         eyebrow: "01", label: "Der Ablauf" },
  { id: "architektur",    eyebrow: "02", label: "Architektur" },
  { id: "smart-home",     eyebrow: "03", label: "Smart Home" },
  { id: "finanzierung",   eyebrow: "04", label: "Finanzierung" },
  { id: "ausbaustufen",   eyebrow: "05", label: "Ausbaustufen" },
  { id: "nachhaltigkeit", eyebrow: "06", label: "Nachhaltigkeit" },
];

const smartHomeFeatures: IconListItem[] = [
  {
    icon: "smartphone-nfc",
    label: "Intuitive Steuerung",
    description:
      "Steuern Sie Ihr BoHolz-Haus bequem über Tablet oder Wandpanel mit einer benutzerfreundlichen Oberfläche.",
  },
  {
    icon: "thermometer",
    label: "Individueller Komfort",
    description:
      "Regulieren Sie Raumtemperaturen individuell, steuern Sie Rollläden und sehen Sie, wer an der Haustür klingelt.",
  },
  {
    icon: "shield",
    label: "Erhöhte Sicherheit",
    description:
      "Mit integrierten Sicherheitssystemen behalten Sie die Kontrolle über Ihr Zuhause, auch wenn Sie nicht da sind.",
  },
  {
    icon: "sparkles",
    label: "Maßgeschneidert",
    description:
      "Von Beleuchtungssteuerung bis Lichtszenen — wir entwickeln ein individuelles Konzept für Ihr intelligentes Zuhause.",
  },
];

// ── Architektur — three editorial beats, alternating image/text. The
// fallback images live under /landing/uebersicht/ (already cropped for
// editorial use) and /content/advantage/ for variety.
type ArchBeat = {
  eyebrow: string;
  heading: string;
  body: string;
  imageURL: string;
  imageAlt: string;
};

const architekturBeats: ArchBeat[] = [
  {
    eyebrow: "Grundriss",
    heading: "Frei gestalten — bis zur letzten Wand.",
    body:
      "Offener Wohnbereich, separates Homeoffice, Einliegerwohnung oder großzügige Terrasse — Ihr Grundriss folgt Ihrem Leben, nicht einem Katalog. Wir planen die Räume so, wie Sie sie täglich nutzen werden.",
    imageURL: getMediaURL("/images/landing/uebersicht/lifestyle-01.webp"),
    imageAlt:
      "Offener Wohnbereich mit großzügiger Tageslichtführung — individuell geplanter Grundriss",
  },
  {
    eyebrow: "Fassade",
    heading: "Außen, wie Sie es sich vorstellen.",
    body:
      "Klassisch verputzt, mit Holzakzenten oder vollflächig in Holz — die Fassade definiert den ersten Eindruck. Aus einer abgestimmten Palette wählen Sie Materialien, Farben und Proportionen, die zum Ort passen.",
    imageURL: getMediaURL("/images/landing/uebersicht/lifestyle-04.webp"),
    imageAlt:
      "Moderne Holzfassade eines BoHolz-Hauses — wählbare Materialität für die Außenwirkung",
  },
  {
    eyebrow: "Innen & außen",
    heading: "Aus einer Hand, ohne Übergabeverluste.",
    body:
      "Wer plant, baut. Vom ersten Skizzenstrich bis zur fertigen Innenraumgestaltung bleibt das Projekt in einer Hand — keine Schnittstellen zwischen Architekt, Generalunternehmer und Innenausbau, keine Reibungsverluste in Detail und Termin.",
    imageURL: getMediaURL("/images/landing/uebersicht/lifestyle-05.webp"),
    imageAlt:
      "Detailliert ausgestalteter Wohnraum — Innenausbau und Architektur aus einer Hand",
  },
];

const heroImage = bauphasenHeroImageURL;
const ctaImage = getMediaURL("/images/pages/dein-zuhause/foerderung.jpg");

// Nachhaltigkeit — two side-by-side editorial images. The first carries the
// `badge-holz-klima-color` sigil from the global sprite (injected by
// Layout.astro) as an absolutely-positioned overlay.
const nachhaltigkeitImageA = getMediaURL(
  "/images/content/advantage/nachhaltigkeit/hero.webp",
);
const nachhaltigkeitImageB = getMediaURL(
  "/images/content/advantage/holzfaserdaemmung/hero.webp",
);
---

<Layout title="Ihr Neues Zuhause – BoHolz Haus">
  <div class="full-width">
    <PageHero
      eyebrow="Ihr Neues Zuhause"
      title="Von der ersten Idee bis zur"
      highlight="Schlüsselübergabe."
      subtitle="So entsteht Ihr individuelles BoHolz Fertighaus — gegliedert in klare Phasen, begleitet von einem festen Ansprechpartner."
      image={heroImage}
      imageAlt="Bauen mit BoHolz Haus"
      align="left"
    />
  </div>

  <SectionNavigator client:load pageTitle="Ihr Neues Zuhause" sections={sections} />

  <!-- 01 · Ablauf ───────────────────────────────────────── -->
  <Block
    id="ablauf"
    eyebrow="01 · Der Ablauf"
    heading="In drei Phasen ins"
    highlight="eigene Zuhause."
    lede="In übersichtliche Schritte gegliedert, mit klaren Deadlines und einem Ansprechpartner, der Sie von Anfang bis Ende begleitet."
  >
    <div class="cards three">
      <article id={`phase-${buildPhases[0].slug}`} class="phase">
        <figure class="phase-frame">
          <img
            src={buildPhases[0].imageURL}
            alt={buildPhases[0].title}
            loading="lazy"
          />
        </figure>
        <EditorialCard
          client:visible
          step={1}
          title="Der Grundstein wird gelegt"
          icon="compass"
          description="Planung, Grundstück, Finanzierung — wir legen die Basis für Ihr Projekt."
        >
          <ul class="lined">
            <li>Planen Ihres Traumhauses mit unseren Bauberatern</li>
            <li>Hilfestellung bei der Grundstückssuche</li>
            <li>Sicherung der Finanzierung</li>
            <li>Abschluss des Hausvertrages</li>
          </ul>
        </EditorialCard>
      </article>

      <article id={`phase-${buildPhases[1].slug}`} class="phase">
        <figure class="phase-frame">
          <img
            src={buildPhases[1].imageURL}
            alt={buildPhases[1].title}
            loading="lazy"
          />
        </figure>
        <EditorialCard
          client:visible
          step={2}
          title="Träume in Realität verwandeln"
          icon="pencil"
          description="Architektur, Bauantrag und Bemusterung — Ihr Haus nimmt Form an."
        >
          <ul class="lined">
            <li>Ihr Baubegleiter steht zu Ihrer Verfügung</li>
            <li>Vorlage der Baufinanzierung</li>
            <li>Kauf des Grundstücks ist erfolgt</li>
            <li>Planungsgespräch mit Architektinnen und Architekten</li>
            <li>Erstellung und Einreichung des Bauantrages</li>
            <li>Vorlage der Baugenehmigung</li>
            <li>Bemusterung mit Ausstattung und Haustechnik</li>
            <li>Planung der Baustelleneinrichtung und Produktion</li>
          </ul>
        </EditorialCard>
      </article>

      <article id={`phase-${buildPhases[2].slug}`} class="phase">
        <figure class="phase-frame">
          <img
            src={buildPhases[2].imageURL}
            alt={buildPhases[2].title}
            loading="lazy"
          />
        </figure>
        <EditorialCard
          client:visible
          step={3}
          title="Die heiße Bauphase beginnt"
          icon="hammer"
          description="Vom Keller bis zur Schlüsselübergabe — Vorfertigung, Montage, Innenausbau."
        >
          <ul class="lined">
            <li>Schaffung der Bauvoraussetzungen</li>
            <li>Beginn der Fertigung des Hauses</li>
            <li>Bau des Kellers oder der Bodenplatte</li>
            <li>Aufbau des Hauses durch das Montageteam</li>
            <li>Richtfest</li>
            <li>Innenausbau und Haustechnik</li>
            <li>Hausübergabe</li>
          </ul>
        </EditorialCard>
      </article>
    </div>
  </Block>

  <!-- 02 · Architektur — zigzag editorial ─────────────────── -->
  <Block
    id="architektur"
    eyebrow="02 · Architektur"
    heading="Jedes Haus erzählt seine"
    highlight="eigene Geschichte."
    lede="Von der Grundrissgestaltung bis zur Fassadenauswahl — bei uns haben Sie die Freiheit, Ihren Hausentwurf mit eigenen Ideen und Gestaltungswünschen zu individualisieren."
  >
    <div class="zigzag">
      {architekturBeats.map((beat) => (
        <article class="beat">
          <figure class="beat-frame">
            <img src={beat.imageURL} alt={beat.imageAlt} loading="lazy" />
          </figure>
          <div class="beat-body">
            <span class="beat-eyebrow">{beat.eyebrow}</span>
            <h3 class="beat-heading">{beat.heading}</h3>
            <p class="beat-text">{beat.body}</p>
          </div>
        </article>
      ))}
    </div>
  </Block>

  <!-- 03 · Smart Home ────────────────────────────────────── -->
  <Block
    id="smart-home"
    eyebrow="03 · Smart Home"
    heading="Komfort, auf Ihre Bedürfnisse"
    highlight="zugeschnitten."
    lede="Tauchen Sie ein in den ultimativen Komfort einer Smart-Home-Installation, die ab Werk mitgeplant und sauber integriert wird."
  >
    <IconList client:visible items={smartHomeFeatures} columns={2} />
  </Block>

  <!-- 04 · Finanzierung & Förderung ─────────────────────── -->
  <Block
    id="finanzierung"
    eyebrow="04 · Finanzierung"
    heading="Staatliche Förderungen,"
    highlight="klar erklärt."
    lede="Förderkredite der Kreditanstalt für Wiederaufbau (KfW) sind eine attraktive Möglichkeit, Ihren Hausbau finanziell zu unterstützen — gut kombinierbar untereinander."
  >
    <div class="cards three stack-below-desktop">
      <EditorialCard
        client:visible
        step={1}
        title="Wohneigentumsprogramm"
        icon="home"
        description="Förderkredit bis zu 100.000 € für alle, die Wohnraum kaufen oder bauen und selbst darin wohnen wollen. Gut kombinierbar mit anderen KfW-Förderprodukten."
      >
        <p class="meta">Kredit 124</p>
      </EditorialCard>

      <EditorialCard
        client:visible
        step={2}
        title="Klimafreundlicher Neubau"
        icon="leaf"
        description="Förderkredit für energieeffizientes und nachhaltiges Bauen — bis zu 150.000 € je Wohneinheit, bis zu 35 Jahre Laufzeit und bis zu 10 Jahre Zinsbindung."
      >
        <p class="meta">Kredit 297 / 298</p>
      </EditorialCard>

      <EditorialCard
        client:visible
        step={3}
        title="Wohneigentum für Familien"
        icon="heart-handshake"
        description="Für Familien mit Kindern und Alleinerziehende mit niedrigem bis mittlerem Einkommen. Kredithöchstbeträge von 170.000 € bis 270.000 € für klimafreundlichen Neubau."
      >
        <p class="meta">Kredit 300</p>
      </EditorialCard>
    </div>

    <div class="callout-slot">
      <Callout client:visible tone="note" title="Hinweis zur Förderung">
        <p>
          Die Zinskonditionen orientieren sich am Kapitalmarkt und werden
          laufend angepasst. Ein Rechtsanspruch auf die Förderung besteht nicht.
        </p>
        <p>
          Förderbedingungen ändern sich laufend. Die jeweils aktuellen
          Konditionen finden Sie auf
          <a href="https://www.kfw.de" rel="noopener noreferrer" target="_blank">www.kfw.de</a>.
        </p>
      </Callout>
    </div>
  </Block>

  <!-- 05 · Ausbaustufen ──────────────────────────────────── -->
  <Block
    id="ausbaustufen"
    eyebrow="05 · Ausbaustufen"
    heading="Wählen Sie, wie weit"
    highlight="wir gehen."
    lede="Jeder Bauherr ist anders. Wählen Sie die Ausbaustufe, die am besten zu Ihren Fähigkeiten und Ihrem Budget passt — vom Rohbau bis schlüsselfertig."
  >
    <BuildingStagesCarousel client:visible stages={buildingStages} />
  </Block>

  <!-- 06 · Nachhaltigkeit ───────────────────────────────── -->
  <Block
    id="nachhaltigkeit"
    tone="band"
    eyebrow="06 · Nachhaltigkeit"
    heading="Gebaut für"
    highlight="Generationen."
    lede="Jedes BoHolz-Haus bindet im Schnitt rund 30 Tonnen CO₂ in seinen Wänden — als KfW 40 oder KfW 55 ausgelegt, Schicht für Schicht aus regional gewachsenem Holz. Nachhaltigkeit ist hier kein Etikett, sondern Bauweise."
  >
    <div class="sustain-pair">
      <figure class="sustain-frame">
        <img
          src={nachhaltigkeitImageA}
          alt="Holzbauweise als gelebter Klimaschutz — BoHolz Manufaktur"
          loading="lazy"
        />
        <svg class="sustain-badge" aria-label="Holz rettet Klima 2030">
          <use href="#badge-holz-klima-color" />
        </svg>
      </figure>
      <figure class="sustain-frame">
        <img
          src={nachhaltigkeitImageB}
          alt="Holzfaserdämmung als ökologische Gebäudehülle — diffusionsoffen, baubiologisch hervorragend"
          loading="lazy"
        />
      </figure>
    </div>
  </Block>

  <!-- 07 · CTA ────────────────────────────────────────────── -->
  <div class="full-width">
    <CTASection
      title="Bereit für Ihr"
      highlight="BoHolz-Zuhause?"
      subtitle="Sprechen Sie mit unseren Bauberatern oder fordern Sie den Katalog an — unverbindlich und kostenfrei."
      image={ctaImage}
      imageAlt="Persönliche Beratung zum BoHolz-Hausbau"
    >
      <a slot="actions" class="cta-link primary" href="/kontakt">
        Beratungstermin vereinbaren
      </a>
      <a slot="actions" class="cta-link ghost" href="/kontakt">
        Katalog bestellen
      </a>
    </CTASection>
  </div>
</Layout>

<style>
  /* ── Card row ── */
  .cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  /* ── Phase composite (image stacked above EditorialCard) ── */
  .phase {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    min-width: 0;
    scroll-margin-block-start: var(--navbar-height);
  }

  .phase-frame {
    position: relative;
    margin: 0;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--clr-surface-secondary);
  }

  .phase-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (--from-tablet) {
    .cards.three:not(.stack-below-desktop) {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (--from-desktop) {
    .cards.three {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      align-items: stretch;
    }
  }

  /* ── Architektur — zigzag editorial. Three beats alternate image-left/
     text-right and image-right/text-left from tablet up. On mobile, every
     beat stacks (image above text). The image holds a 4:3 frame so it
     reads as editorial weight, not as a card thumbnail. ── */
  .zigzag {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-5);
  }

  .beat {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
    align-items: center;
  }

  .beat-frame {
    margin: 0;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--clr-surface-secondary);
  }

  .beat-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .beat-body {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    max-width: 56ch;
  }

  .beat-eyebrow {
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-tertiary);
  }

  .beat-heading {
    margin: 0;
    font-size: var(--fs-h5);
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-heading);
    color: var(--clr-content-primary);
    font-weight: var(--font-weight-regular);
  }

  .beat-text {
    margin: 0;
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
  }

  @media (--from-tablet) {
    .beat {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-5);
    }

    /* Alternate every second beat: image on the right, text on the left. */
    .beat:nth-child(even) .beat-frame {
      order: 2;
    }

    .beat:nth-child(even) .beat-body {
      order: 1;
    }
  }

  /* ── Lists inside EditorialCards (Phase 1/2/3 detail bullets) ── */
  .lined {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    font-size: var(--fs-body-sm);
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
  }

  .lined li {
    position: relative;
    padding-inline-start: var(--spacing-3);
  }

  .lined li::before {
    content: "";
    position: absolute;
    inset-inline-start: 0;
    inset-block-start: 0.7em;
    width: var(--spacing-1);
    height: 1px;
    background: var(--clr-border-tertiary);
  }

  /* KfW programme code sits as a quiet eyebrow under the description. */
  .meta {
    margin: 0;
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--clr-content-tertiary);
    font-weight: var(--font-weight-medium);
  }

  .callout-slot {
    max-width: 56rem;
  }

  .callout-slot :global(a) {
    color: var(--clr-accent-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    text-decoration-thickness: 1px;
    font-weight: var(--font-weight-medium);
    transition: color 160ms ease;
  }

  .callout-slot :global(a:hover) {
    color: var(--clr-accent-secondary);
  }

  .callout-slot :global(a:focus-visible) {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  /* ── Nachhaltigkeit pair — two editorial images side-by-side with a
     `Holz rettet Klima 2030` badge overlaid on the first frame. The badge
     sits as a square overlay anchored to the top-right corner, sized so it
     reads as a sigil — not as decoration. Mobile shrinks both the frame
     gap and the badge so it can't overflow the image. ── */
  .sustain-pair {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
  }

  @media (--from-tablet) {
    .sustain-pair {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-4);
    }
  }

  .sustain-frame {
    position: relative;
    margin: 0;
    width: 100%;
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--clr-surface-primary);
  }

  .sustain-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sustain-badge {
    position: absolute;
    inset-block-start: var(--spacing-3);
    inset-inline-end: var(--spacing-3);
    /* Sized in absolute px (not a scale token) so the badge never grows
       larger than the frame on small viewports; aspect 1/1 from the
       symbol's viewBox. */
    width: clamp(64px, 18vw, 112px);
    height: clamp(64px, 18vw, 112px);
    filter: drop-shadow(0 4px 16px color-mix(in srgb, #000 28%, transparent));
  }

  /* ── CTA inline links ──
     CTASection ships layout + tone but no buttons. Primary accent on the
     larger CTA surface; ghost for the secondary action. */
  .cta-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: var(--control-height-md);
    padding-inline: var(--spacing-4) var(--spacing-3);
    border-radius: var(--radius-md);
    font-weight: var(--font-weight-medium);
    font-size: var(--fs-body);
    text-decoration: none;
    border: 1px solid transparent;
    transition:
      background-color 160ms ease,
      color 160ms ease,
      border-color 160ms ease;
  }

  .cta-link.primary {
    background: var(--clr-accent-primary);
    color: var(--clr-pure-white);
  }

  .cta-link.primary:hover {
    background: var(--clr-accent-secondary);
    opacity: 1;
  }

  .cta-link.ghost {
    background: transparent;
    color: var(--clr-pure-white);
    border-color: var(--clr-pure-white-soft);
  }

  .cta-link.ghost:hover {
    background: var(--clr-pure-white);
    color: var(--clr-content-primary);
    opacity: 1;
  }

  .cta-link:focus-visible {
    outline: 2px solid var(--clr-pure-white);
    outline-offset: 2px;
  }
</style>
