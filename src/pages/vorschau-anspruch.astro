---
/**
 * Hero-headline preview variant of `/`.
 *
 * Identical to `index.astro` in every section except the PageHero
 * title/highlight, plus a thin dev banner at the very top so the client
 * can toggle between the two variants. Not linked from the navbar.
 *
 * Title:     "Fertighäuser in Zimmermannsqualität für Menschen mit"
 * Highlight: "Anspruch."   (italic-blue per PageHero contract)
 */
import Layout from "@/layouts/Layout.astro";
import { getMediaURL } from "@/lib/media";

import PageHero from "@/ui/sections/PageHero.astro";
import Block from "@/ui/sections/Block.astro";
import BenefitsRow from "@/ui/sections/BenefitsRow.astro";
import HouseModelsCarousel from "@/ui/sections/HouseModelsCarousel.vue";
import ImageBand from "@/ui/sections/ImageBand.astro";
import AudienceBlock from "@/ui/sections/AudienceBlock.astro";
import TwoColumn from "@/ui/sections/TwoColumn.astro";
import TestimonialBand from "@/ui/sections/TestimonialBand.astro";
import ContactForm from "@/features/contact-forms/ContactForm.vue";
import CTASection from "@/ui/sections/CTASection.astro";

import FAQAccordion from "@/ui/primitives/FAQAccordion.vue";
import Button from "@/ui/primitives/Button.vue";

import { getCategories, getModels } from "@/db/loaders";
import { toHouseModelCard } from "@/lib/derive";

import { uebersichtContent as content } from "@/features/landing/uebersicht.content";
import ProofSection from "@/ui/sections/Proof-Section.vue";
import TrustBadges from "@/features/home/TrustBadges/TrustBadges.vue";
import { trustBadges } from "@/features/home/TrustBadges/trust-badges.content";
import { homeSections } from "@/features/home/home.content";

const heroOverride = {
  title: "Fertighäuser in Zimmermannsqualität für Menschen mit",
  highlight: "Anspruch.",
};

const categories = await getCategories();
const allModels = await getModels();

const featuredOnly = content.houses.featuredOnly ?? true;
const filteredModels = allModels
  .filter((m) => (featuredOnly ? m.isFeatured : true))
  .filter((m) =>
    content.houses.categorySlugs === null
      ? true
      : content.houses.categorySlugs.includes(m.category?.slug ?? ""),
  )
  .slice(0, content.houses.maxItems);

const houseCards = filteredModels.map((m) => toHouseModelCard(m));

const heroImage = getMediaURL(content.hero.imageFallbackPath);
const imageBandImage = getMediaURL(content.imageBand.imageFallbackPath);
const sustainabilityImage = getMediaURL(content.sustainability.imageFallbackPath);
---

<Layout title={`${heroOverride.title} ${heroOverride.highlight}`} categories={categories}>
  <!-- Dev-only preview banner. Sits above the hero so the client can flip
       back to the standard variant without clearing the URL. -->
  <aside class="preview-banner full-width">
    <span>Vorschau · Alternative Hero-Headline</span>
    <a href="/">← Zur Standard-Variante</a>
  </aside>

  <div class="full-width">
    <PageHero
      eyebrow={content.hero.eyebrow}
      title={heroOverride.title}
      highlight={heroOverride.highlight}
      subtitle={content.hero.subtitle}
      image={heroImage}
      imageAlt={content.hero.imageAlt}
      align="center"
    >
      <Fragment slot="actions">
        <Button variant="primary" size="lg" href={content.hero.primaryCta.href}>
          {content.hero.primaryCta.label}
        </Button>
        <Button variant="secondary" size="lg" href={content.hero.secondaryCta.href}>
          {content.hero.secondaryCta.label}
        </Button>
      </Fragment>
    </PageHero>
  </div>

  <Block><ProofSection /></Block>

  <Block
    id={homeSections.trust.id}
    tone="band"
    eyebrow={homeSections.trust.eyebrow}
    heading={homeSections.trust.heading1}
    highlight={homeSections.trust.highlight}
    lede={homeSections.trust.subheading}
    align="center"
  >
    <TrustBadges client:visible badges={trustBadges} />
  </Block>

  <Block
    id="vorteile"
    eyebrow={content.benefitsIntro.eyebrow}
    heading={content.benefitsIntro.heading}
    highlight={content.benefitsIntro.highlight}
    lede={content.benefitsIntro.lede}
  >
    <BenefitsRow items={content.benefits} />
  </Block>

  <Block
    id="hausmodelle"
    eyebrow={content.houses.eyebrow}
    heading={content.houses.heading}
    highlight={content.houses.highlight}
    lede={content.houses.lede}
  >
    {
      houseCards.length > 0 ? (
        <HouseModelsCarousel
          client:visible
          models={houseCards}
          ariaLabel="Empfohlene Hausmodelle"
        />
      ) : (
        <p class="empty">
          Aktuell keine empfohlenen Modelle für diese Kategorie.
          Bitte sehen Sie sich
          <a href="/hauser"> die vollständige Übersicht </a>
          an.
        </p>
      )
    }
  </Block>

  <ImageBand
    eyebrow={content.imageBand.eyebrow}
    heading={content.imageBand.heading}
    highlight={content.imageBand.highlight}
    lede={content.imageBand.lede}
    image={imageBandImage}
    imageAlt={content.imageBand.imageAlt}
    rule
  />

  <Block
    id="zielgruppen"
    eyebrow={content.audience.eyebrow}
    heading={content.audience.heading}
    highlight={content.audience.highlight}
    lede={content.audience.lede}
  >
    <AudienceBlock items={content.audience.items} />
    <Fragment slot="actions">
      <Button client:load variant="primary" size="md" href={content.hero.primaryCta.href}>
        {content.hero.primaryCta.label}
      </Button>
      <Button client:load variant="ghost" size="md" href={content.hero.secondaryCta.href}>
        {content.hero.secondaryCta.label}
      </Button>
    </Fragment>
  </Block>

  <Block id="nachhaltigkeit">
    <TwoColumn
      eyebrow={content.sustainability.eyebrow}
      title={content.sustainability.title}
      highlight={content.sustainability.highlight}
      subtitle={content.sustainability.subtitle}
      image={sustainabilityImage}
      imageAlt={content.sustainability.imageAlt}
      reverse={content.sustainability.reverse}
    >
      <div class="prose">
        {content.sustainability.paragraphs.map((p) => <p>{p}</p>)}
      </div>
      {content.sustainability.cta && (
        <Fragment slot="actions">
          <Button client:load variant="primary" size="md" href={content.sustainability.cta.href}>
            {content.sustainability.cta.label}
          </Button>
        </Fragment>
      )}
    </TwoColumn>
  </Block>

  <TestimonialBand
    eyebrow={content.trust.eyebrow}
    heading={content.trust.heading}
    highlight={content.trust.highlight}
    lede={content.trust.lede}
    tone={content.trust.tone}
    badges={content.trust.badges}
    testimonials={content.trust.testimonials}
  />

  <Block
    id="faq"
    eyebrow={content.faq.eyebrow}
    heading={content.faq.heading}
    highlight={content.faq.highlight}
  >
    <div class="faq-wrap">
      <FAQAccordion
        client:visible
        items={content.faq.items}
        defaultOpen={content.faq.defaultOpen}
      />
    </div>
  </Block>

  <Block
    id="anfordern"
    tone="band"
    eyebrow={content.leadForm.eyebrow}
    heading={content.leadForm.heading}
    highlight={content.leadForm.highlight}
    lede={content.leadForm.lede}
  >
    <div class="form-wrap">
      <ContactForm client:visible />
    </div>
  </Block>

  <div class="full-width">
    <CTASection
      eyebrow={content.closingCta.eyebrow}
      title={content.closingCta.title}
      highlight={content.closingCta.highlight}
      subtitle={content.closingCta.subtitle}
      tone={content.closingCta.tone}
      image={content.closingCta.imageFallbackPath ? getMediaURL(content.closingCta.imageFallbackPath) : undefined}
      imageAlt={content.closingCta.imageAlt ?? ""}
    >
      <Fragment slot="actions">
        <Button client:load variant="primary" size="lg" href={content.closingCta.primaryCta.href}>
          {content.closingCta.primaryCta.label}
        </Button>
        {content.closingCta.secondaryCta && (
          <Button client:load variant="secondary" size="lg" href={content.closingCta.secondaryCta.href}>
            {content.closingCta.secondaryCta.label}
          </Button>
        )}
      </Fragment>
    </CTASection>
  </div>
</Layout>

<style>
  /* Thin preview banner — full-bleed via the wrapper grid escape
     (`.full-width`). Sits above the sticky navbar so it scrolls away
     naturally with the hero. Uses accent-secondary for the link (small
     element, per the project accent-tier rule). */
  .preview-banner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-3);
    padding-block: var(--spacing-1);
    padding-inline: var(--padding-inline);
    background: var(--clr-surface-secondary);
    border-block-end: 1px solid var(--clr-border-secondary);
    font-size: var(--fs-body-sm);
    color: var(--clr-content-secondary);
    text-align: center;
  }

  .preview-banner span {
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    font-weight: var(--font-weight-medium);
  }

  .preview-banner a {
    color: var(--clr-accent-secondary);
    font-weight: var(--font-weight-medium);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--clr-accent-secondary) 40%, transparent);
    text-underline-offset: 2px;
    transition: text-decoration-color 160ms ease;
  }

  .preview-banner a:hover,
  .preview-banner a:focus-visible {
    text-decoration-color: var(--clr-accent-secondary);
  }

  .empty {
    margin: 0;
    padding: var(--spacing-3) 0;
    color: var(--clr-content-tertiary);
    font-size: var(--fs-body);
    text-align: center;
  }

  .empty a {
    color: var(--clr-accent-secondary);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--clr-accent-secondary) 40%, transparent);
    text-underline-offset: 2px;
  }

  .prose {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    max-width: 64ch;
  }

  .prose p {
    margin: 0;
    color: var(--clr-content-secondary);
    font-size: var(--fs-body);
    line-height: var(--lh-body);
  }

  .faq-wrap {
    max-width: 56rem;
    width: 100%;
    margin-inline: auto;
  }

  /* Lead-form wrapper — constrain the ContactForm to a comfortable measure
     inside the centered band. */
  .form-wrap {
    max-width: 36rem;
    width: 100%;
    margin-inline: auto;
    margin-block-start: var(--spacing-4);
  }
</style>
