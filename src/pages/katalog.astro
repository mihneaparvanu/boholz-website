---
import Layout from "@/layouts/Layout.astro";

import EyebrowHeadingLede from "@/components/ui/EyebrowHeadingLede.astro";

import CatalogForm from "@/features/ContactForms/CatalogForm.vue";

import { BookOpen, Mail } from "lucide-vue-next";

import { benefits } from "./katalog.content";
---

<Layout title="Hauskatalog bestellen – BoHolz Haus">
  <!--
    Pattern mirrors kontakt.astro: no PageHero, no numeric step dividers.
    Form sits at the top of the page (primary action), then the "what you
    get" supporting copy sits below as the closing beat.
  -->

  <section id="anfordern" class="section form-section">
    <div class="form-col">
      <EyebrowHeadingLede
        eyebrow="Bestellen"
        heading="Hauskatalog"
        highlight="kostenfrei anfordern."
        lede="Wenige Angaben genügen — wir senden Ihnen den Katalog per E-Mail oder Post. Werktags meist binnen 24 Stunden."
      >
        <Fragment slot="eyebrow-icon">
          <Mail :size={14} :stroke-width={2} />
        </Fragment>
      </EyebrowHeadingLede>

      <div class="form-wrap">
        <CatalogForm client:visible />
      </div>
    </div>
  </section>

  <section id="inhalt" class="section benefits-section">
    <EyebrowHeadingLede
      eyebrow="Was Sie erhalten"
      heading="Alles, was Sie für Ihre"
      highlight="Entscheidung brauchen."
      lede="Der Katalog ist kein Werbeprospekt — er ist eine sachliche Grundlage. Sie blättern in Ruhe, vergleichen, planen. Ohne Anruf, ohne Verkaufsdruck."
    >
      <Fragment slot="eyebrow-icon">
        <BookOpen :size={14} :stroke-width={2} />
      </Fragment>
    </EyebrowHeadingLede>

    <ul class="benefits" role="list">
      {
        benefits.map((b) => (
          <li class="item">
            <span class="icon" aria-hidden="true">
              <b.icon size={18} stroke-width={1.75} />
            </span>
            <div class="copy">
              <h3 class="title">{b.title}</h3>
              <p class="body">{b.body}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</Layout>

<style>
  /* ============================================================
     Section rhythm — mirrors kontakt.astro. Form-first, supporting
     content below, no numeric step dividers.
     ============================================================ */
  .section {
    padding-block: var(--spacing-5);
  }

  /* Form column — bounded measure so the fields hold a comfortable
     reading width on wide screens. Centered within the content column. */
  .form-col {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    min-width: 0;
    max-width: 56rem;
    margin-inline: auto;
  }

  .form-wrap {
    margin-block-start: var(--spacing-3);
  }

  /* Benefits below — sits on a hairline-separated band so the supporting
     copy reads as a closing beat, not a peer of the form. Mirrors
     kontakt's stats-band treatment without the toned background. */
  .benefits-section {
    padding-block-start: var(--spacing-6);
    border-block-start: 1px solid var(--clr-border-secondary);
    margin-block-start: var(--spacing-4);
  }

  /* "What you get" list — calm two-column grid from tablet up,
     stacked on mobile. Icon + copy pair, no chrome, just rhythm. */
  .benefits {
    list-style: none;
    margin: var(--spacing-4) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (--from-tablet) {
    .benefits {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--spacing-5);
    }
  }

  .item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--spacing-3);
    align-items: start;
  }

  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: var(--radius-md);
    background: var(--clr-surface-secondary);
    color: var(--clr-content-primary);
    flex-shrink: 0;
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    min-width: 0;
  }

  .title {
    margin: 0;
    font-size: var(--fs-body-lg);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
    line-height: var(--lh-heading);
  }

  .body {
    margin: 0;
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
  }
</style>
