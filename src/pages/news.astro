---
import Layout from "../layouts/Layout.astro";
import NewsPage from "../features/NewsPage/NewsPage.vue";
import { getNews, getCategories } from "../data/loaders";

const [articles, categories] = await Promise.all([getNews(), getCategories()]);
---

<Layout title="News – BoHolz Haus" categories={categories}>
  <NewsPage articles={articles} client:visible />
</Layout>
