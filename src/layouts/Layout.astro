---
import "@/style/reset.css";
import "@/style/design-system.css";
import "@/style/wrapper.css";

import qualityBadgesSprite from "@/icons/qualityBadges.svg?raw";
import qualityBadgesColorSprite from "@/icons/qualityBadgesColor.svg?raw";

import Navbar from "./Navbar/Navbar.vue";
import Footer from "./Footer/Footer.astro";
import CookieConsent from "../features/CookieConsent/CookieConsent.vue";

import { getCategories, getLocations, getHeroSlides } from "@/data/loaders";
import type { HouseCategory } from "@/types/models";

interface Props {
  title: string;
  categories?: HouseCategory[];
  isHero?: boolean;
}

const { title, categories: categoriesProp, isHero = false } = Astro.props;
const categories = categoriesProp ?? (await getCategories());
const showhouses = await getLocations({ kind: "showhouse" });

// Pick a fallback hero image for the virtual Bestseller category — it has
// no media of its own, so we surface the first featured model's hero so
// the NavbarDrop showcase doesn't render blank when Bestseller is hovered.
const [topFeatured] = await getHeroSlides(1);
const bestsellerHero = topFeatured?.heroImgURL ?? null;
---

<html lang="de" data-hero={isHero ? "true" : "false"}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <Fragment set:html={qualityBadgesSprite} />
    <Fragment set:html={qualityBadgesColorSprite} />
    <Navbar
      client:load
      categories={categories}
      showhouses={showhouses}
      bestsellerHero={bestsellerHero}
    />
    <main class="wrapper">
      <CookieConsent client:visible/>
      <slot />
      <Footer />
    </main>
  </body>
</html>
