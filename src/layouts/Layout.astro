---
import "@/style/reset.css";
import "@/style/design-system.css"
import "@/style/wrapper.css"

import Navbar from "./Navbar/Navbar.vue";
import Footer from "./Footer/Footer.astro";
import PrivacyPopup from "@/features/PrivacyPopup/PrivacyPopup.vue";

import { getCategories, getLocations } from "@/data/loaders";
import type { HouseCategory } from "@/types/models";

interface Props {
  title: string;
  categories?: HouseCategory[];
}

const { title, categories: categoriesProp } = Astro.props;
const categories = categoriesProp ?? await getCategories();
const showhouses = await getLocations({ kind: "showhouse" });
---
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      href="/favicon.ico"
    />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <title>{title}</title>
  </head>
  <body>
    <Navbar client:load categories={categories} showhouses={showhouses} currentPath={Astro.url.pathname}/>
    <main class="wrapper">
       <PrivacyPopup/>
      <slot />
     
      <Footer />
      
    </main>
  </body>
</html>


<style>
  main {
    padding-top: calc(var(--navbar-height) + var(--navbar-offset) * 2);
  }


</style>