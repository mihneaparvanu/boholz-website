---
import "../style/reset.css";
import "../style/design-system.css"
import "../style/wrapper.css"

import Navbar from "./Navbar/Navbar.vue";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon.svg"
    />
    <link
      rel="icon"
      href="/favicon.ico"
    />
    <meta
      name="viewport"
      content="width=device-width"
    />
    <title>{title}</title>
  </head>
  <body>
    <main class="wrapper">
      <Navbar client:load />
      <slot />
    </main>
  </body>
</html>


<style>


</style>