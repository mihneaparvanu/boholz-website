---
import "@/ui/style/reset.css";
import "@/ui/style/design-system.css";
import "@/ui/style/wrapper.css";

import certificationsSprite from "@/features/certifications/certifications.svg?raw";

import Navbar from "@/features/navigation/navbar/Navbar.vue";
import Footer from "@/features/navigation/footer/Footer.astro";
import ConsentBanner from "@/features/consent/ConsentBanner.vue";
import { readConsent, COOKIE_NAME } from "@/features/consent/consent";

import { getCategories, getLocations } from "@/db/loaders";
import type { HouseCategory } from "@/db/models";

interface Props {
  title: string;
  categories?: HouseCategory[];
  isHero?: boolean;
}

const { title, categories: categoriesProp, isHero = false } = Astro.props;
const categories = categoriesProp ?? (await getCategories());
const showhouses = await getLocations({ kind: "showhouse" });

const rawConsent = Astro.cookies.get(COOKIE_NAME)?.value ?? null;
const consent = readConsent(rawConsent);
// Consent banner disabled for now (was a dev-only feature). Re-enable by
// restoring: const showBanner = consent === null;
const showBanner = false;
const loadGTM = consent !== null && (consent.analytics || consent.marketing);
const GTM_ID = import.meta.env.PUBLIC_GTM_ID;
---

<html lang="de" data-hero={isHero ? "true" : "false"}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    {loadGTM && GTM_ID && (
      <>
        <script is:inline set:html={`window.dataLayer=window.dataLayer||[];window.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});`} />
        <script is:inline async src={`https://www.googletagmanager.com/gtm.js?id=${GTM_ID}`} />
      </>
    )}
  </head>
  <body>
    <Fragment set:html={certificationsSprite} />
    <Navbar
      client:load
      categories={categories}
      showhouses={showhouses}
    />
    <main class="wrapper">
      {showBanner && <ConsentBanner client:visible />}
      <slot />
      <Footer />
    </main>
  </body>
</html>
