---
import type { SectionContent } from "./section.types";
import Eyebrow from "@/components/ui/Eyebrow.astro";

type Tone = "primary" | "secondary";
type Align = "start" | "center";

type Props = SectionContent & {
  /**
   * Optional anchor id rendered on the outer `<section>` element. Use when a
   * sticky rail or deep-link target needs to scroll to this section.
   */
  id?: string;
  /**
   * Optional small-caps label rendered above the headings via the kit
   * `<Eyebrow>` component. Composes with the heading rhythm.
   */
  eyebrow?: string;
  /**
   * `primary` (default) renders the section in the content column of the
   * page wrapper — back-compat.
   *
   * `secondary` flips the surface to `--clr-surface-secondary` and escapes
   * the wrapper grid via `.full-width` so the tinted background goes
   * edge-to-edge. Internal content re-pads to the wrapper's
   * `--padding-inline`, then centres up to `--content-max-width`.
   *
   * Use to alternate section backgrounds within a long page.
   */
  tone?: Tone;
  /**
   * Heading-region alignment. `center` (default) preserves existing
   * behavior. `start` left-aligns the eyebrow + heading + lede group —
   * use for editorial sections where the heading wants to sit above an
   * asymmetric grid rather than crown a symmetric one.
   */
  align?: Align;
};

const {
  id,
  eyebrow,
  heading1,
  heading2,
  highlight,
  subheading,
  tone = "primary",
  align = "center",
} = Astro.props;

const isSecondary = tone === "secondary";
const wrapperClass = isSecondary ? "section full-width" : "section";
---

<section id={id} class={wrapperClass} data-tone={tone} data-align={align}>
  <div class="inner">
    <div class="heading-group">
      {eyebrow && <Eyebrow>{eyebrow}</Eyebrow>}
      <div class="headings">
        {
          heading2 ? (
            <>
              <h2>{heading1}</h2>
              <h2>
                {heading2}
                {highlight && <span class="highlight"> {highlight}</span>}
              </h2>
            </>
          ) : (
            <h2>
              {heading1}
              {highlight && <span class="highlight"> {highlight}</span>}
            </h2>
          )
        }
      </div>
      {subheading && <p>{subheading}</p>}
    </div>
    <slot />
  </div>
</section>

<style>
  .section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: var(--spacing-6);
    gap: var(--spacing-5);
    /* Scroll-margin so deep-link / nav-rail jumps don't tuck the heading
       under the sticky navbar + rail. */
    scroll-margin-block-start: calc(var(--navbar-height) + var(--spacing-4));
  }

  /* Secondary-tone section escapes the wrapper grid to span full-width,
     then re-pads internally — alternating section backgrounds. */
  .section[data-tone="secondary"] {
    background: var(--clr-surface-secondary);
    padding-inline: var(--padding-inline);
    /* The section now owns its own edge padding; .inner re-centres. */
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-5);
    width: 100%;
    /* Primary tone inherits the wrapper's content column, so the inner
       can stretch freely. Secondary tone is full-width, so we cap the
       inner at the same content max-width and re-centre. */
    --proof-color: var(--clr-content-secondary);
  }

  .section[data-tone="secondary"] .inner {
    max-width: var(--content-max-width);
    margin-inline: auto;
  }

  .heading-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-3);
    text-align: center;
    width: 100%;
    max-width: 90ch;
    margin-inline: auto;
  }

  /* Editorial alignment — left-aligns the heading region so it can sit
     above an asymmetric grid (AsymmetricShowcase, FeatureSpotlight)
     without being recentred by the wrapper. ProofSection lives outside
     this group and keeps its own centring. */
  .section[data-align="start"] .heading-group {
    align-items: flex-start;
    text-align: start;
    margin-inline: 0;
  }

  .section[data-align="start"] .headings {
    align-items: flex-start;
  }

  /* Eyebrow → heading rhythm — composes with the .heading-group flex
     gap (spacing-3) to give ~spacing-6 of breathing room. Polish wave 1
     bumped this generously — small-caps demands real space below it. */
  .heading-group :global(.eyebrow) {
    margin-block-end: var(--spacing-3);
  }

  .headings {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .headings h2 {
    font-weight: var(--font-weight-medium);
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-medium);
  }

  .heading-group p {
    color: var(--clr-content-secondary);
    max-width: 56rem;
    font-weight: var(--font-weight-regular);
  }
</style>
