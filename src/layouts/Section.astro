---
interface Props {
  heading: string;
  highlightWord?: string;
  subheading: string;
}

const { heading, subheading, highlightWord } = Astro.props;
---

<section class="section">
  <div class="heading-group">
    <h2>{heading} <span>{highlightWord}</span></h2>
    <p>{subheading}</p>
  </div>
  <slot />
</section>
<style>
  section {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-block: var(--spacing-8);
    overflow-x: hidden;
  }

  .heading-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-3);
    text-align: center;

    h2 {
      font-weight: 400;
    }

    span {
      font-family: "Instrument Sans";
      font-style: italic;
    }

    p {
      color: var(--clr-content-secondary);
      max-width: 1000px;
      font-weight: 400;
    }
    max-width: 1400px;
  }
</style>
