---
interface Props {
  quote: string;
  author?: string;
  role?: string;
  align?: "start" | "center";
}

const { quote, author, role, align = "start" } = Astro.props;
---

<figure class="pq" data-align={align}>
  <blockquote class="quote">
    <span class="mark" aria-hidden="true">&ldquo;</span>{quote}<span
      class="mark"
      aria-hidden="true">&rdquo;</span
    >
  </blockquote>
  {(author || role) && (
    <figcaption class="attr">
      {author && <span class="author">{author}</span>}
      {author && role && <span class="sep" aria-hidden="true"> · </span>}
      {role && <span class="role">{role}</span>}
    </figcaption>
  )}
</figure>

<style>
  .pq {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
    max-width: 42rem;
    margin: 0;
    padding-block: var(--spacing-3);
  }

  .pq[data-align="center"] {
    margin-inline: auto;
    text-align: center;
  }

  .quote {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
    font-size: var(--fs-h4);
    line-height: 1.3;
    color: var(--clr-content-primary);
    margin: 0;
    /* Hanging quote — pull the opening quote into the margin only at desktop. */
    text-indent: 0;
  }

  .mark {
    /* Slightly larger opening/closing quote glyph; baseline-aligned. */
    font-family: var(--font-secondary);
    color: var(--clr-content-tertiary);
  }

  .attr {
    font-size: var(--fs-body-sm);
    color: var(--clr-content-secondary);
    line-height: var(--lh-heading);
  }

  .author {
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-primary);
  }

  .sep {
    color: var(--clr-content-tertiary);
  }
</style>
