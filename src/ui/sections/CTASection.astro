---
type Tone = "surface" | "accent" | "image";

interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
  tone?: Tone;
  image?: string;
  imageAlt?: string;
  /** Optional small-caps label above the heading. Matches EyebrowHeadingLede rhythm. */
  eyebrow?: string;
}

const {
  title,
  highlight,
  subtitle,
  tone = "surface",
  image,
  imageAlt = "",
  eyebrow,
} = Astro.props;

const resolvedTone: Tone = image ? "image" : tone;
---

<section class="cta full-width" data-tone={resolvedTone}>
  {
    resolvedTone === "image" && image && (
      <div class="bg">
        <img src={image} alt={imageAlt} loading="lazy" />
        <div class="scrim" />
      </div>
    )
  }

  <div class="inner">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>
      {title}
      {highlight && <span class="highlight"> {highlight}</span>}
    </h2>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    {
      Astro.slots.has("actions") && (
        <div class="actions">
          <slot name="actions" />
        </div>
      )
    }
  </div>
</section>

<style>
  .cta {
    position: relative;
    isolation: isolate;
    padding-block: var(--spacing-7);
    padding-inline: var(--padding-inline, var(--spacing-4));
    overflow: hidden;
  }

  .cta[data-tone="surface"] {
    background: var(--clr-surface-secondary);
    color: var(--clr-content-primary);
  }

  .cta[data-tone="accent"] {
    background: var(--clr-accent-primary);
    color: var(--clr-pure-white);
  }

  .cta[data-tone="image"] {
    color: var(--clr-pure-white);
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: var(--clr-overlay-strong);
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-3);
    max-width: 64rem;
    margin-inline: auto;
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-tertiary);
    margin: 0;
    /* Eyebrow → heading rhythm is wider than heading → subtitle.
       Adds to parent flex `gap`. Mirrors PageHero + EyebrowHeadingLede. */
    margin-block-end: calc(var(--spacing-4) - var(--spacing-3));
  }

  /* Eyebrow over dark surfaces — keep it readable. */
  .cta[data-tone="accent"] .eyebrow,
  .cta[data-tone="image"] .eyebrow {
    color: var(--clr-pure-white-soft);
  }

  h2 {
    margin: 0;
    font-weight: var(--font-weight-regular);
    /* CTA closer carries the page's final beat — sized larger than the
       default h2 (--fs-h3) and rendered with no tracking so the headline
       reads open and confident, not condensed. */
    letter-spacing: 0;
    font-size: var(--fs-h2);
  }

  @media (--mobile) {
    h2 {
      font-size: var(--fs-h3);
    }
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
  }

  /* On the accent-tone CTA, the background IS accent-primary — the global
     `.highlight` rule colours the italic word in the same accent, making it
     vanish. Promote it to white so the headline reads as two parts again.
     The double-class selector matches the global rule's specificity. */
  .cta[data-tone="accent"] .highlight.highlight,
  .cta[data-tone="image"] .highlight.highlight {
    color: var(--clr-pure-white);
  }

  .subtitle {
    font-size: var(--fs-body-lg);
    max-width: 56rem;
    margin: 0;
  }

  .cta[data-tone="surface"] .subtitle {
    color: var(--clr-content-secondary);
  }

  .cta[data-tone="accent"] .subtitle,
  .cta[data-tone="image"] .subtitle {
    color: var(--clr-pure-white-soft);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-2);
    margin-top: var(--spacing-2);
  }

  @media (--mobile) {
    .actions {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
    }
  }

  /* On accent/image tones the page background IS the accent, so a `ghost`
     Button (transparent bg + accent-primary text + transparent border) is
     invisible. Promote its label and outline to white-soft so the secondary
     action reads against the saturated surface. `:global` lets the rule
     reach the scoped Button.vue internals. */
  .cta[data-tone="accent"] :global(.btn[data-variant="ghost"]),
  .cta[data-tone="image"] :global(.btn[data-variant="ghost"]) {
    color: var(--clr-pure-white);
    border-color: var(--clr-pure-white-soft);
  }

  .cta[data-tone="accent"] :global(.btn[data-variant="ghost"]:hover),
  .cta[data-tone="image"] :global(.btn[data-variant="ghost"]:hover) {
    background: var(--clr-pure-white);
    color: var(--clr-content-primary);
    border-color: var(--clr-pure-white);
  }
</style>
