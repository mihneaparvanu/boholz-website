---
/**
 * BenefitsRow — 4-up row of brand benefits ("Ihre Vorteile auf einen Blick").
 * Each card carries a Lucide icon, short title, one-line body, and a
 * full-saturation brand colour drawn from the print campaign palette.
 *
 * Tones (used left-to-right in the landing content):
 *   forest  — deep brand green (light text)
 *   sage    — pale sage (dark text)
 *   leaf    — pale yellow-green (dark text)
 *   surface — page surface, hairline-bordered (dark text)
 *
 * The legacy pastel tones (bg/petrol/grun/oliv) are kept for any older
 * consumer, but the three landing pages all run on the new four-tone scale.
 *
 * Breakpoints: 1-up < 500 → 2x2 tablet → 4-up desktop.
 */
import { getIcon, type IconName } from "@/lib/icons";

// Tones: forest/sage/leaf/surface drive the current full-saturation
// palette; bg/petrol/grun/oliv are kept for legacy diluted-pastel callers.
export type BenefitTone = "forest" | "sage" | "leaf" | "surface" | "accent" | "bg" | "petrol" | "grun" | "oliv";

export interface Benefit {
  icon: IconName;
  title: string;
  body: string;
  /** Brand colour key. */
  tone: BenefitTone;
}

interface Props {
  items: Benefit[];
}

const { items } = Astro.props as Props;
---

<ul class="row" role="list">
  {
    items.map((b: Benefit) => {
      const Icon = getIcon(b.icon);
      return (
        <li class="card" data-tone={b.tone}>
          <span class="icon" aria-hidden="true">
            <Icon size={20} strokeWidth={1.75} />
          </span>
          <h3 class="title">{b.title}</h3>
          <p class="body">{b.body}</p>
        </li>
      );
    })
  }
</ul>

<style>
  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-3);
    padding: 0;
    margin: 0;
    list-style: none;
    width: 100%;
  }

  @media (--from-tablet) {
    .row {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--spacing-3);
    }
  }

  @media (--from-desktop) {
    .row {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  .card {
    padding: var(--spacing-4) var(--spacing-3) var(--spacing-3);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    border-radius: var(--radius-lg);
    background: var(--card-bg);
    color: var(--card-fg);
    border: 1px solid var(--card-border);
    min-width: 0;
    height: 100%;
  }

  /* ── New full-saturation palette ───────────────────────────────────── */

  .card[data-tone="forest"] {
    --card-bg: var(--vorteil-forest);
    --card-fg: var(--clr-pure-white);
    --card-fg-soft: rgba(255, 255, 255, 0.78);
    --card-border: rgba(255, 255, 255, 0.08);
    --card-icon-bg: rgba(255, 255, 255, 0.14);
  }

  .card[data-tone="sage"] {
    --card-bg: var(--vorteil-sage);
    --card-fg: var(--vorteil-forest);
    --card-fg-soft: color-mix(in srgb, var(--vorteil-forest) 78%, transparent);
    --card-border: color-mix(in srgb, var(--vorteil-forest) 14%, transparent);
    --card-icon-bg: color-mix(in srgb, var(--vorteil-forest) 10%, transparent);
  }

  .card[data-tone="leaf"] {
    --card-bg: var(--vorteil-leaf);
    --card-fg: var(--vorteil-forest);
    --card-fg-soft: color-mix(in srgb, var(--vorteil-forest) 78%, transparent);
    --card-border: color-mix(in srgb, var(--vorteil-forest) 18%, transparent);
    --card-icon-bg: color-mix(in srgb, var(--vorteil-forest) 12%, transparent);
  }

  .card[data-tone="surface"] {
    --card-bg: var(--clr-surface-primary);
    --card-fg: var(--clr-content-primary);
    --card-fg-soft: var(--clr-content-secondary);
    --card-border: var(--clr-border-secondary);
    --card-icon-bg: var(--clr-surface-secondary);
  }

  /* Accent — brand accent-primary fill (light dusty blue) with near-black
     text per client direction. Black on accent-primary clears WCAG AA
     comfortably (~8.9:1); white would have failed (~2.4:1), so text is dark. */
  .card[data-tone="accent"] {
    --card-bg: var(--clr-accent-primary);
    --card-fg: rgba(0, 0, 0, 0.92);
    --card-fg-soft: rgba(0, 0, 0, 0.72);
    --card-border: rgba(0, 0, 0, 0.12);
    --card-icon-bg: rgba(0, 0, 0, 0.08);
  }

  /* ── Legacy diluted pastel tones (older callers) ───────────────────── */

  .card[data-tone="bg"],
  .card[data-tone="petrol"],
  .card[data-tone="grun"],
  .card[data-tone="oliv"] {
    --card-fg: var(--clr-content-primary);
    --card-fg-soft: var(--clr-content-secondary);
    --card-border: color-mix(in srgb, var(--card-tint) 42%, transparent);
    --card-bg: color-mix(in srgb, var(--card-tint) 22%, var(--clr-surface-primary));
    --card-icon-bg: color-mix(in srgb, var(--card-tint) 55%, var(--clr-surface-primary));
  }

  .card[data-tone="bg"]      { --card-tint: var(--pastell-bg); }
  .card[data-tone="petrol"]  { --card-tint: var(--pastell-petrol); }
  .card[data-tone="grun"]    { --card-tint: var(--pastell-grün); }
  .card[data-tone="oliv"]    { --card-tint: var(--pastell-oliv); }

  /* ── Inner pieces ──────────────────────────────────────────────────── */

  .icon {
    width: var(--control-height-md);
    height: var(--control-height-md);
    display: inline-grid;
    place-items: center;
    border-radius: var(--radius-md);
    background: var(--card-icon-bg);
    color: var(--card-fg);
    margin-block-end: var(--spacing-1);
  }

  .title {
    margin: 0;
    font-size: var(--fs-h6);
    font-weight: var(--font-weight-medium);
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-heading);
    color: var(--card-fg);
  }

  .body {
    margin: 0;
    font-size: var(--fs-body-sm);
    line-height: var(--lh-body);
    color: var(--card-fg-soft);
    max-width: 28ch;
  }
</style>
