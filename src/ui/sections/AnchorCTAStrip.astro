---
import Button from "@/ui/primitives/Button.vue";

export interface CTAAction {
  label: string;
  href: string;
  /** Defaults to "primary". On dark tones the strip swaps in light-on-dark variants. */
  variant?: "primary" | "secondary";
}

interface Props {
  heading: string;
  /** Optional italic-serif highlight appended to the heading. */
  highlight?: string;
  /** Optional short subline. Keep under ~80 chars. */
  subline?: string;
  /** Surface tone — defaults to deep olive. */
  tone?: "olive" | "graphite" | "stone" | "accent";
  primary: CTAAction;
  secondary?: CTAAction;
}

const {
  heading,
  highlight,
  subline,
  tone = "olive",
  primary,
  secondary,
} = Astro.props;
---

<aside class="strip full-width" data-tone={tone} aria-label={heading}>
  <div class="inner">
    <div class="copy">
      <h2 class="heading">
        {heading}
        {highlight && <span class="highlight"> {highlight}</span>}
      </h2>
      {subline && <p class="subline">{subline}</p>}
    </div>

    <div class="actions">
      <Button
        client:load
        variant="secondary"
        size="lg"
        href={primary.href}
        data-strip-btn="primary"
      >
        {primary.label}
      </Button>
      {secondary && (
        <Button
          client:load
          variant="ghost"
          size="lg"
          href={secondary.href}
          data-strip-btn="secondary"
        >
          {secondary.label}
        </Button>
      )}
    </div>
  </div>
</aside>

<style>
  .strip {
    padding-block: var(--spacing-6);
    padding-inline: var(--padding-inline);
    color: var(--clr-pure-white);
  }

  .strip[data-tone="olive"] {
    background: var(--pastell-oliv-alt);
  }
  .strip[data-tone="graphite"] {
    background: var(--cold-gray-200);
  }
  .strip[data-tone="stone"] {
    background: var(--dark-stone);
  }
  .strip[data-tone="accent"] {
    background: var(--clr-accent-secondary);
  }

  .inner {
    max-width: var(--content-max-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    align-items: center;
  }
  @media (--from-tablet) {
    .inner {
      /* Heading takes the left two-thirds; actions sit right and bottom-aligned. */
      grid-template-columns: 1fr auto;
      gap: var(--spacing-5);
    }
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    max-width: 36ch;
  }

  .heading {
    margin: 0;
    font-size: var(--fs-h3);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--ls-heading);
    line-height: var(--lh-heading);
    color: var(--clr-pure-white);
    text-wrap: balance;
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
  }

  .subline {
    margin: 0;
    font-size: var(--fs-body);
    color: var(--clr-pure-white-soft);
    line-height: var(--lh-body);
  }

  .actions {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
    align-items: stretch;
  }
  @media (--from-tablet) {
    .actions {
      flex-direction: row;
      align-items: center;
      gap: var(--spacing-3);
      flex-wrap: wrap;
      justify-content: flex-end;
    }
  }

  /* On dark tinted strips the project's Button variants need a light-on-dark
     repaint. We scope this here (rather than adding new variants to the
     Button component) because the strip is the only surface with this exact
     contrast inversion need.
     - "secondary" → primary CTA, but rendered as white pill on dark band.
     - "ghost" → secondary CTA, rendered as soft-outlined white text. */
  .strip :global(.btn[data-strip-btn="primary"]) {
    background: var(--clr-pure-white);
    color: var(--neutral-gray-100);
    border-color: var(--clr-pure-white);
  }
  .strip :global(.btn[data-strip-btn="primary"]:hover:not([disabled], [aria-disabled="true"])) {
    background: color-mix(in srgb, var(--clr-pure-white) 88%, transparent);
    color: var(--neutral-gray-100);
    border-color: transparent;
  }

  .strip :global(.btn[data-strip-btn="secondary"]) {
    background: transparent;
    color: var(--clr-pure-white);
    border-color: color-mix(in srgb, var(--clr-pure-white) 36%, transparent);
  }
  .strip :global(.btn[data-strip-btn="secondary"]:hover:not([disabled], [aria-disabled="true"])) {
    background: color-mix(in srgb, var(--clr-pure-white) 10%, transparent);
    border-color: color-mix(in srgb, var(--clr-pure-white) 60%, transparent);
    color: var(--clr-pure-white);
  }

  @media (--mobile) {
    .strip {
      padding-block: var(--spacing-5);
    }
    .heading {
      font-size: var(--fs-h4);
    }
    /* Full-width buttons on mobile — they stretch the column. */
    .actions {
      align-items: stretch;
    }
    .strip :global(.actions .btn) {
      width: 100%;
      justify-content: center;
    }
  }
</style>
