---
interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
  image: string;
  imageAlt: string;
  reverse?: boolean;
  eyebrow?: string;
}

const {
  title,
  highlight,
  subtitle,
  image,
  imageAlt,
  reverse = false,
  eyebrow,
} = Astro.props;
---

<section class="two-col" data-reverse={reverse}>
  <div class="media">
    <img src={image} alt={imageAlt} loading="lazy" />
  </div>

  <div class="content">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <h2>
      {title}
      {highlight && <span class="highlight"> {highlight}</span>}
    </h2>
    {subtitle && <p class="subtitle">{subtitle}</p>}
    {
      Astro.slots.has("default") && (
        <div class="body">
          <slot />
        </div>
      )
    }
    {
      Astro.slots.has("actions") && (
        <div class="actions">
          <slot name="actions" />
        </div>
      )
    }
  </div>
</section>

<style>
  .two-col {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    align-items: center;
    padding-block: var(--spacing-5);
  }

  @media (--from-desktop) {
    .two-col {
      grid-template-columns: 1fr 1fr;
      gap: var(--spacing-6);
    }

    .two-col[data-reverse="true"] .media {
      order: 2;
    }
  }

  .media {
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 4 / 3;
  }

  .media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--fs-body-sm);
    color: var(--clr-accent-primary);
    margin: 0;
  }

  h2 {
    margin: 0;
    font-weight: 400;
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
  }

  .subtitle {
    color: var(--clr-content-secondary);
    font-size: var(--fs-body-lg);
    margin: 0;
  }

  .body {
    color: var(--clr-content-primary);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-2);
    margin-top: var(--spacing-2);
  }
</style>
