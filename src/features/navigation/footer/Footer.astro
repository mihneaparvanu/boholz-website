---

import { ROUTES } from "@/features/navigation/routes";
import { FOOTER_NAV } from "./footer.content";
import { CERTIFICATIONS } from "@/features/certifications/certifications";

import BoholzLogo from "@/ui/icons/BoholzLogo.vue";
import GermanyFlag from "@/ui/icons/GermanyFlag.vue";
import PrivacyBtn from "@/ui/primitives/PrivacyBtn.vue";
import Separator from "@/features/house-page/components/Separator.vue";

const currentYear = new Date().getFullYear();
---

<footer class="footer subgrid">
  <Separator />

  <div class="content">
    <a class="logo" href={ROUTES.home} aria-label="BoHolz Haus – Startseite">
      <BoholzLogo tone="brand" aria-hidden="true" />
    </a>

    <nav class="nav" aria-label="Footer">
      <ul class="list main">
        {
          FOOTER_NAV.map((l) => (
            <li>
              <a href={l.path}>{l.label}</a>
            </li>
          ))
        }
      </ul>

      <ul class="list privacy">
        <li><a href={ROUTES.impressum}>Impressum</a></li>
        <li><a href={ROUTES.datenschutz}>Datenschutz</a></li>
        <li><a href={ROUTES.cookies}>Cookies</a></li>
        <li>
          <a href="">
            <span class="privacy-icon"><PrivacyBtn /></span>
            Ihre Privatsphäre-Einstellungen
          </a>
        </li>
      </ul>
    </nav>

    <section class="certs" aria-labelledby="certs-label">
      <span class="eyebrow" id="certs-label">Geprüfte Qualität</span>
      <ul class="badges">
        {
          CERTIFICATIONS.map((c) => (
            <li data-size={c.size ?? "default"}>
              <svg
                class="badge"
                style={`aspect-ratio: ${c.aspect};`}
                role="img"
                aria-label={c.label}
              >
                <use href={`#${c.id}`} />
              </svg>
            </li>
          ))
        }
      </ul>
    </section>

    <div class="trailing">
      <div class="meta">
        <p class="copyright">© {currentYear} Boholz Haus GmbH</p>
        <p class="origin" aria-label="100 Prozent in Deutschland gefertigt">
          <GermanyFlag aria-hidden="true" />
          <span>Made in Germany</span>
        </p>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding-block: var(--spacing-6) var(--spacing-3);
  }

  .content {
    padding-block-start: var(--spacing-4);
    display: grid;
    grid-template-columns: 1fr;
    grid-template-areas:
      "logo"
      "nav"
      "certs"
      "trailing";
    row-gap: var(--spacing-5);
    column-gap: var(--spacing-5);
  }

  @media (--from-desktop) {
    .content {
      grid-template-columns: minmax(auto, 1fr) auto;
      grid-template-areas:
        "logo nav"
        "certs certs"
        "trailing trailing";
      row-gap: var(--spacing-5);
      column-gap: var(--spacing-5);
      align-items: start;
    }
  }

  /* --- Logo ----------------------------------------------------------- */

  .logo {
    grid-area: logo;
    display: inline-flex;
    width: clamp(72px, 8vw, 96px);
    color: inherit;
    transition: opacity 160ms ease;
  }
  .logo:hover {
    opacity: 0.85;
  }

  /* --- Nav ----------------------------------------------------------- */

  .nav {
    grid-area: nav;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (--from-tablet) {
    .nav {
      grid-template-columns: repeat(2, minmax(0, max-content));
      gap: var(--spacing-5);
    }
  }

  @media (--from-desktop) {
    .nav {
      justify-content: end;
      column-gap: var(--spacing-6);
    }
  }

  .list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
  }

  .list a {
    transition: color 160ms ease;
  }
  .list a:hover {
    color: var(--clr-accent-secondary);
    opacity: 1;
  }
  .list a:focus-visible {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 3px;
    border-radius: var(--radius-sm);
  }

  .list.main a {
    font-weight: var(--font-weight-medium);
  }

  .list.privacy a {
    font-weight: var(--font-weight-regular);
    color: var(--clr-content-secondary);
  }

  .privacy-icon {
    padding-inline-end: var(--spacing-0);
  }

  /* --- Certifications row -------------------------------------------- */

  .certs {
    grid-area: certs;
    padding-block-start: var(--spacing-4);
    border-block-start: 1px solid var(--clr-border-secondary);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-3);
  }

  .eyebrow {
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-tertiary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
  }

  .badges {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    column-gap: var(--spacing-3);
    row-gap: var(--spacing-3);
  }

  .badges li {
    display: inline-flex;
  }

  .badge {
    /* Color sprite carries its own fills; no currentColor styling here.
       Height is driven by the parent <li>'s data-size so re-ordering the
       certifications list never depends on nth-child arithmetic. */
    height: var(--badge-h, 40px);
    width: auto;
    transition: opacity 200ms ease;
  }

  /* Per-badge visual mass — each tier ships mobile / tablet / desktop
     heights so a "wide" mark (narrow-aspect, e.g. RAL or Creditreform)
     reads at the same perceived weight as a square neighbour, and the
     oversized Holz-Rettet-Klima mark stays the section's anchor. */
  .badges li[data-size="default"] { --badge-h: 32px; }
  .badges li[data-size="wide"]    { --badge-h: 48px; }
  .badges li[data-size="tall"]    { --badge-h: 40px; }

  @media (--from-tablet) {
    .badges li[data-size="default"] { --badge-h: 40px; }
    .badges li[data-size="wide"]    { --badge-h: 56px; }
    .badges li[data-size="tall"]    { --badge-h: 60px; }
  }

  @media (--from-desktop) {
    .badges li[data-size="default"] { --badge-h: 48px; }
    .badges li[data-size="wide"]    { --badge-h: 68px; }
    .badges li[data-size="tall"]    { --badge-h: 72px; }

    .badges {
      column-gap: var(--spacing-3);
    }
  }

  /* Quiet by default, brighten on hover to confirm interactivity would be
     available if we ever wire each badge to a detail page. */
  .badges li .badge {
    opacity: 0.85;
  }
  .badges li:hover .badge {
    opacity: 1;
  }

  /* Mobile: keep all certs on a single horizontal row. Tighter gaps and
     the data-size mobile heights above already keep the rhythm honest. */
  @media (--mobile) {
    .badges {
      flex-wrap: nowrap;
      column-gap: var(--spacing-1);
      justify-content: space-between;
      width: 100%;
    }
    .badges li {
      flex-shrink: 1;
      min-width: 0;
    }
  }

  /* --- Trailing: copyright + socials --------------------------------- */

  .trailing {
    grid-area: trailing;
    padding-block-start: var(--spacing-3);
    border-block-start: 1px solid var(--clr-border-secondary);
    display: flex;
    flex-direction: column-reverse;
    gap: var(--spacing-3);
    align-items: center;
  }

  .copyright {
    color: var(--clr-content-tertiary);
    font-size: var(--fs-body-sm);
    margin: 0;
  }

  .meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
     width: 100%;
  }

  @media (--from-desktop) {
    .meta {
       width: fit-content;
      align-items: center;
      gap: var(--spacing-3);
    }
  }

  .origin {
    margin: 0;
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-1);
    color: var(--clr-content-tertiary);
    font-size: var(--fs-body-sm);
    text-transform: uppercase;
  }

  .socials {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: var(--spacing-2);
  }

  .socials a {
    display: grid;
    place-items: center;
    width: var(--control-height-sm);
    height: var(--control-height-sm);
    border-radius: var(--radius-sm);
    color: var(--clr-content-tertiary);
    transition:
      color 160ms ease,
      background 160ms ease;
  }

  .socials a:hover {
    color: var(--clr-content-primary);
    background: var(--clr-surface-secondary);
    opacity: 1;
  }
  .socials a:focus-visible {
    outline: 2px solid var(--clr-accent-primary);
    outline-offset: 2px;
  }

  .socials svg {
    width: var(--fs-body);
    height: var(--fs-body);
  }

  @media (--from-desktop) {
    .trailing {
      flex-direction: row;
      justify-content: space-between;
    }
  }
</style>
