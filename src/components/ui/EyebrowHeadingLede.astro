---
import Eyebrow from "./Eyebrow.astro";

interface Props {
  eyebrow?: string;
  heading: string;
  /** Optional italic-serif highlight appended to the heading. */
  highlight?: string;
  lede?: string;
  align?: "start" | "center";
  level?: "h1" | "h2";
}

const {
  eyebrow,
  heading,
  highlight,
  lede,
  align = "start",
  level = "h2",
} = Astro.props;

const Heading = level;
---

<header class="ehl" data-align={align} data-has-eyebrow={Boolean(eyebrow)}>
  {eyebrow && (
    <Eyebrow>
      {Astro.slots.has("eyebrow-icon") && (
        <Fragment slot="icon">
          <slot name="eyebrow-icon" />
        </Fragment>
      )}
      {eyebrow}
    </Eyebrow>
  )}
  <Heading class="heading">
    {heading}
    {highlight && <span class="highlight"> {highlight}</span>}
  </Heading>
  {lede && <p class="lede">{lede}</p>}
</header>

<style>
  .ehl {
    display: flex;
    flex-direction: column;
    /* Default rhythm — heading ↔ lede sit close. */
    gap: var(--spacing-3);
    max-width: 70ch;
  }

  /* Eyebrow → heading rhythm is wider than heading → lede. The eyebrow's
     small-caps tracking needs room to feel un-cramped; the lede following
     the heading does not. We target the first-child (Eyebrow renders a
     <p class="eyebrow">) via :global() because Astro's scoped CSS would
     otherwise add a data-attribute that doesn't reach the child component. */
  .ehl[data-has-eyebrow="true"] > :global(.eyebrow) {
    margin-block-end: calc(var(--spacing-4) - var(--spacing-3));
  }

  .ehl[data-align="center"] {
    align-items: center;
    text-align: center;
    margin-inline: auto;
  }

  .heading {
    margin: 0;
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--ls-heading);
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
  }

  .lede {
    font-size: var(--fs-body-lg);
    color: var(--clr-content-secondary);
    max-width: 60ch;
    margin: 0;
    line-height: var(--lh-body);
  }

  .ehl[data-align="center"] .lede {
    margin-inline: auto;
  }
</style>
