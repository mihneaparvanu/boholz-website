---
interface Props {
  title: string;
  align?: "left" | "center";
}

const { title, align = "left" } = Astro.props;
---

<article class="item" data-align={align}>
  {
    Astro.slots.has("icon") && (
      <div class="icon">
        <slot name="icon" />
      </div>
    )
  }
  <h3>{title}</h3>
  {
    Astro.slots.has("default") && (
      <div class="body">
        <slot />
      </div>
    )
  }
</article>

<style>
  .item {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .item[data-align="center"] {
    text-align: center;
    align-items: center;
  }

  .icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--spacing-unit) * 11);
    height: calc(var(--spacing-unit) * 11);
    color: var(--clr-accent-primary);
  }

  .icon :global(svg) {
    width: 100%;
    height: 100%;
  }

  h3 {
    font-size: var(--fs-h5);
    font-weight: 500;
    margin: 0;
  }

  .body {
    color: var(--clr-content-secondary);
  }
</style>
