---
interface Props {
  columns?: 2 | 3 | 4;
}

const { columns = 3 } = Astro.props;
---

<div class="grid" data-cols={columns}>
  <slot />
</div>

<style>
  .grid {
    display: grid;
    width: 100%;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
  }

  @media (--from-tablet) {
    .grid[data-cols="2"],
    .grid[data-cols="3"],
    .grid[data-cols="4"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (--from-desktop) {
    .grid[data-cols="3"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    .grid[data-cols="4"] {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }
</style>
