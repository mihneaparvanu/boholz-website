---
/**
 * ZigZag — alternating image-left/right narrative blocks.
 *
 * Replicates the editorial "feature list" pattern from the old WP site
 * (see todo/building-w-boholz screenshot): each block carries an
 * eyebrow subtitle, a heading, a short prose paragraph (with optional
 * last-sentence emphasis in content-primary), and a CTA.
 *
 * The image side alternates with the block index — first block image-left,
 * second image-right, and so on. Single column on mobile, side-by-side from
 * tablet up.
 */
import Button from "@/components/ui/Button.vue";
import { ArrowRight } from "lucide-vue-next";

export interface ZigZagBlock {
  /** Sub-headline above the title (e.g. "Holz rettet Klima"). */
  eyebrow?: string;
  /** Main block title. */
  title: string;
  /** Optional opener sentence rendered before the body — content-primary
      so the eye lands here first. */
  opener?: string;
  /** Body paragraph(s). Each entry renders as its own <p>. */
  body: string[];
  /** Final sentence highlighted in content-primary as the editorial
      "punch line" beneath the body. Optional. */
  closing?: string;
  /** R2 image URL. */
  image: string;
  imageAlt: string;
  /** Optional CTA — { label, href }. Default "Mehr erfahren". */
  cta?: { label?: string; href: string };
  /** Optional ordered list (used by the "Gute Gründe" block). */
  bullets?: string[];
}

interface Props {
  blocks: ZigZagBlock[];
}

const { blocks } = Astro.props;
---

<div class="zigzag">
  {
    blocks.map((b, i) => (
      <article class="row" data-reverse={i % 2 === 1 || undefined}>
        <figure class="media">
          <img src={b.image} alt={b.imageAlt} loading="lazy" />
        </figure>

        <div class="content">
          {b.eyebrow && <p class="eyebrow">{b.eyebrow}</p>}
          <h3 class="title">{b.title}</h3>

          {b.opener && <p class="opener">{b.opener}</p>}

          {b.body.map((p) => (
            <p class="body">{p}</p>
          ))}

          {b.bullets && b.bullets.length > 0 && (
            <ol class="bullets">
              {b.bullets.map((bullet) => (
                <li>{bullet}</li>
              ))}
            </ol>
          )}

          {b.closing && <p class="closing">{b.closing}</p>}

          {b.cta && (
            <div class="actions">
              <Button client:visible variant="secondary" size="md" href={b.cta.href}>
                {b.cta.label ?? "Mehr erfahren"}
                <ArrowRight slot="trailing" :size="14" :stroke-width="2" />
              </Button>
            </div>
          )}
        </div>
      </article>
    ))
  }
</div>

<style>
  .zigzag {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-6);
  }

  .row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--spacing-4);
    align-items: center;
  }

  /* From tablet up, the media + content sit side-by-side. Image gets a
     slightly larger column than text for a magazine-spread proportion. */
  @media (--from-tablet) {
    .row {
      grid-template-columns: 1.05fr 1fr;
      gap: var(--spacing-5);
    }

    /* Alternating odd rows flip — image to the right via column-reverse
       on a flat grid (achieved by reassigning columns to the children). */
    .row[data-reverse] .media {
      grid-column: 2;
      grid-row: 1;
    }
    .row[data-reverse] .content {
      grid-column: 1;
      grid-row: 1;
    }
  }

  .media {
    margin: 0;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--clr-surface-secondary);
    aspect-ratio: 4 / 3;
  }

  .media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-2);
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-content-tertiary);
  }

  .title {
    margin: 0;
    font-family: var(--font-primary);
    font-size: var(--fs-h4);
    font-weight: var(--font-weight-medium);
    line-height: var(--lh-heading);
    letter-spacing: var(--ls-heading);
    color: var(--clr-content-primary);
  }

  /* Opener: short emphatic line under the title, body-large and primary. */
  .opener {
    margin: 0;
    margin-block-start: var(--spacing-1);
    font-size: var(--fs-body-lg);
    line-height: var(--lh-body);
    color: var(--clr-content-primary);
  }

  /* Body paragraphs sit in content-secondary so the closing line stands
     out. Stacked with .body + .body for paragraph spacing. */
  .body {
    margin: 0;
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
    max-width: 60ch;
  }

  /* Closing line — italic serif emphasis to land as the editorial "punch
     line" without competing with the heading. */
  .closing {
    margin: 0;
    margin-block-start: var(--spacing-1);
    font-family: var(--font-secondary);
    font-style: italic;
    font-size: var(--fs-body-lg);
    line-height: var(--lh-heading);
    color: var(--clr-content-primary);
    max-width: 60ch;
  }

  .bullets {
    margin: 0;
    padding-inline-start: var(--spacing-3);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    color: var(--clr-content-secondary);
    line-height: var(--lh-body);
  }

  .bullets li::marker {
    color: var(--clr-content-tertiary);
    font-variant-numeric: tabular-nums;
  }

  .actions {
    margin-block-start: var(--spacing-2);
  }
</style>
