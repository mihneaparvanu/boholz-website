---
/**
 * HouseModelsGrid — responsive grid of house-model cards.
 *
 * Mobile: 1-up. Tablet: 2-up. Desktop+: 3-up.
 *
 * Re-uses `HouseModelCard.vue` for the card body so grid + carousel stay
 * pixel-identical. Mounts each card with `client:load` because the card's
 * hover micro-interaction is local to each instance.
 *
 * Wrap this in `<Section>` (or any container) for heading + eyebrow; this
 * file is responsible only for the grid surface and the cards.
 */
import HouseModelCard from "./HouseModelCard.vue";
import type { HouseModelCardProps } from "./HouseModelCard.vue";

interface Props {
  models: HouseModelCardProps[];
  /** 2 or 3 columns at desktop. Mobile is always 1, tablet always 2. */
  columns?: 2 | 3;
}

const { models, columns = 3 } = Astro.props;
---

<div class="grid" data-cols={columns}>
  {
    models.map((m) => (
      <HouseModelCard
        client:load
        slug={m.slug}
        name={m.name}
        code={m.code}
        image={m.image}
        imageAlt={m.imageAlt}
        specs={m.specs}
        priceHint={m.priceHint}
        href={m.href}
      />
    ))
  }
</div>

<style>
  .grid {
    display: grid;
    width: 100%;
    grid-template-columns: 1fr;
    /* Generous row gap — the cards don't have card chrome, so the breathing
       room between them is the chrome. The old-design grid suffocates
       because everything is hairline-close; ours uses spacing-5 column /
       spacing-6 row by default. */
    column-gap: var(--spacing-4);
    row-gap: var(--spacing-6);
  }

  @media (--from-tablet) {
    .grid[data-cols="2"],
    .grid[data-cols="3"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--spacing-4);
    }
  }

  @media (--from-desktop) {
    .grid[data-cols="3"] {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      column-gap: var(--spacing-5);
    }
    .grid[data-cols="2"] {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--spacing-6);
    }
  }
</style>
