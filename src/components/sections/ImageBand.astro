---
/**
 * ImageBand — narrow full-bleed panoramic strip used as a transitional
 * rhythm break between dense sections. A photo, a soft scrim, and a
 * left-aligned heading + lede pair. No CTA — the band is a breath, not
 * a destination.
 *
 * Heights tuned to feel like a "rule" of imagery cutting across the page
 * (180-260px desktop, 140-200px mobile) — taller and it competes with
 * a proper hero, shorter and it reads as a banner ad.
 */

interface Props {
  heading: string;
  /** Italic-serif accent appended to the heading. */
  highlight?: string;
  lede?: string;
  image: string;
  imageAlt: string;
  /** Optional eyebrow above the heading. */
  eyebrow?: string;
  /** Whether to show a subtle accent rule beneath the heading (default false). */
  rule?: boolean;
}

const { heading, highlight, lede, image, imageAlt, eyebrow, rule = false } =
  Astro.props;
---

<aside class="band full-width" role="complementary">
  <div class="bg">
    <img src={image} alt={imageAlt} loading="lazy" decoding="async" />
    <div class="scrim" aria-hidden="true"></div>
  </div>

  <div class="copy">
    {eyebrow && <p class="eyebrow">{eyebrow}</p>}
    <p class="head">
      {heading}
      {highlight && <span class="highlight"> {highlight}</span>}
    </p>
    {rule && <span class="rule" aria-hidden="true"></span>}
    {lede && <p class="lede">{lede}</p>}
  </div>
</aside>

<style>
  .band {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: var(--clr-pure-white);
    /* Aspect-driven fallback so the image always fills if dvh isn't honoured. */
    min-height: clamp(140px, 32vw, 200px);
    display: flex;
    align-items: center;
  }

  /* Mobile: anchor the band to viewport height so the lifestyle photo
     reads as a true full-bleed rhythm break, not a banner. */
  @media (--mobile) {
    .band {
      min-height: 65dvh;
    }
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Left-weighted scrim — the headline anchors against the darker edge
     while the right half of the photo stays clean. */
  .scrim {
    position: absolute;
    inset: 0;
    background: var(--scrim-left);
  }

  .copy {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-1);
    padding-inline: var(--padding-inline);
    padding-block: var(--spacing-3);
    max-width: 48ch;
  }

  .eyebrow {
    margin: 0;
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    font-size: var(--fs-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--clr-pure-white-soft);
    margin-block-end: var(--spacing-1);
  }

  .head {
    margin: 0;
    font-size: var(--fs-h4);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--ls-heading);
    line-height: var(--lh-heading);
    color: var(--clr-pure-white);
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
    font-weight: var(--font-weight-regular);
  }

  .rule {
    display: block;
    width: var(--spacing-4);
    height: 1px;
    background: var(--clr-pure-white-soft);
    margin-block: var(--spacing-1);
  }

  .lede {
    margin: 0;
    font-size: var(--fs-body);
    color: var(--clr-pure-white-soft);
    max-width: 44ch;
  }

  @media (--from-tablet) {
    .band {
      min-height: clamp(180px, 22vw, 240px);
    }
  }

  @media (--from-desktop) {
    .band {
      min-height: 45dvh;
    }

    .head {
      font-size: var(--fs-h3);
    }
  }
</style>
