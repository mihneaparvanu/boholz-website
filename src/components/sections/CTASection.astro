---
type Tone = "surface" | "accent" | "image";

interface Props {
  title: string;
  highlight?: string;
  subtitle?: string;
  tone?: Tone;
  image?: string;
  imageAlt?: string;
}

const {
  title,
  highlight,
  subtitle,
  tone = "surface",
  image,
  imageAlt = "",
} = Astro.props;

const resolvedTone: Tone = image ? "image" : tone;
---

<section class="cta" data-tone={resolvedTone}>
  {
    resolvedTone === "image" && image && (
      <div class="bg">
        <img src={image} alt={imageAlt} loading="lazy" />
        <div class="scrim" />
      </div>
    )
  }

  <div class="inner">
    <h2>
      {title}
      {highlight && <span class="highlight"> {highlight}</span>}
    </h2>
    {subtitle && <p>{subtitle}</p>}
    {
      Astro.slots.has("actions") && (
        <div class="actions">
          <slot name="actions" />
        </div>
      )
    }
  </div>
</section>

<style>
  .cta {
    position: relative;
    isolation: isolate;
    padding-block: var(--spacing-7);
    padding-inline: var(--padding-inline, var(--spacing-4));
    overflow: hidden;
  }

  .cta[data-tone="surface"] {
    background: var(--clr-surface-secondary);
    color: var(--clr-content-primary);
  }

  .cta[data-tone="accent"] {
    background: var(--clr-accent-primary);
    color: var(--clr-pure-white);
  }

  .cta[data-tone="image"] {
    color: var(--clr-pure-white);
  }

  .bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .scrim {
    position: absolute;
    inset: 0;
    background: var(--clr-overlay-strong);
  }

  .inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--spacing-3);
    max-width: 64rem;
    margin-inline: auto;
  }

  h2 {
    margin: 0;
    font-weight: var(--font-weight-regular);
  }

  .highlight {
    font-family: var(--font-secondary);
    font-style: italic;
  }

  .cta p {
    font-size: var(--fs-body-lg);
    max-width: 56rem;
    margin: 0;
  }

  .cta[data-tone="surface"] p {
    color: var(--clr-content-secondary);
  }

  .cta[data-tone="accent"] p,
  .cta[data-tone="image"] p {
    color: var(--clr-pure-white-soft);
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-2);
    margin-top: var(--spacing-2);
  }
</style>
