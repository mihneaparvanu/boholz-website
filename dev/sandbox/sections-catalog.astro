---
import "@/style/reset.css";
import "@/style/design-system.css";
import "@/style/wrapper.css";

import Eyebrow from "@/components/ui/Eyebrow.astro";
import Divider from "@/components/ui/Divider.astro";

import HouseModelsGrid from "@/components/sections/HouseModelsGrid.astro";
import HouseModelsCarousel from "@/components/sections/HouseModelsCarousel.vue";
import ComparisonStrip from "@/components/sections/ComparisonStrip.astro";
import FilterStrip from "@/components/sections/FilterStrip.vue";

import type { HouseModelCardProps } from "@/components/sections/HouseModelCard.vue";

/* ─── Mock data ───────────────────────────────────────────────────────────
   Realistic German placeholders. Unsplash architecture photos as imagery —
   the loaders / DB stay untouched per the brief. */

// Unsplash architecture photos — premium, daylight, exterior. Sized via
// query so the browser can lazy-decode. All IDs verified reachable.
const img = (id: string) =>
  `https://images.unsplash.com/${id}?w=1200&q=80&auto=format&fit=crop`;

const models: HouseModelCardProps[] = [
  {
    slug: "bungalow-22-134",
    name: "Bungalow 22-134",
    code: "BUNGALOW · 22-134",
    image: img("photo-1564013799919-ab600027ffc6"),
    imageAlt: "Eingeschossiger Bungalow mit Flachdach und Holzfassade.",
    specs: [
      { kind: "area", value: "134 m²" },
      { kind: "rooms", value: "4 Zimmer" },
      { kind: "efficiency", value: "KfW 40" },
    ],
    priceHint: "ab 290.000 €",
  },
  {
    slug: "einfamilienhaus-144-7",
    name: "Einfamilienhaus 144-7",
    code: "EINFAMILIENHAUS · 144-7",
    image: img("photo-1518780664697-55e3ad937233"),
    imageAlt: "Zweigeschossiges Einfamilienhaus mit Satteldach.",
    specs: [
      { kind: "area", value: "144 m²" },
      { kind: "rooms", value: "5 Zimmer" },
      { kind: "efficiency", value: "KfW 40 Plus" },
    ],
    priceHint: "ab 345.000 €",
  },
  {
    slug: "doppelhaus-2x110-140",
    name: "Doppelhaus 2×110/140",
    code: "DOPPELHAUS · 2×110-140",
    image: img("photo-1570129477492-45c003edd2be"),
    imageAlt: "Symmetrisches Doppelhaus mit moderner Fassade.",
    specs: [
      { kind: "area", value: "2× 125 m²" },
      { kind: "rooms", value: "4+4 Zi." },
      { kind: "efficiency", value: "KfW 40" },
    ],
    priceHint: "ab 480.000 €",
  },
  {
    slug: "stadtvilla-180-3",
    name: "Stadtvilla 180-3",
    code: "STADTVILLA · 180-3",
    image: img("photo-1600596542815-ffad4c1539a9"),
    imageAlt: "Moderne Stadtvilla mit großen Fensterflächen.",
    specs: [
      { kind: "area", value: "180 m²" },
      { kind: "rooms", value: "6 Zimmer" },
      { kind: "efficiency", value: "KfW 40 Plus" },
    ],
    priceHint: "ab 420.000 €",
  },
  {
    slug: "tiny-haus-58",
    name: "Tiny Haus 58",
    code: "TINY HAUS · 58",
    image: img("photo-1416331108676-a22ccb276e35"),
    imageAlt: "Kompaktes Tiny House mit großen Glasfronten.",
    specs: [
      { kind: "area", value: "58 m²" },
      { kind: "rooms", value: "2 Zimmer" },
      { kind: "efficiency", value: "KfW 40" },
    ],
    priceHint: "ab 165.000 €",
  },
  {
    slug: "mehrfamilienhaus-340",
    name: "Mehrfamilienhaus 340",
    code: "MEHRFAMILIENHAUS · 340",
    image: img("photo-1605276374104-dee2a0ed3cd6"),
    imageAlt: "Dreigeschossiges Mehrfamilienhaus mit Holzbalkonen.",
    specs: [
      { kind: "area", value: "340 m²" },
      { kind: "rooms", value: "8 Zi." },
      { kind: "efficiency", value: "QNG" },
    ],
    priceHint: "ab 890.000 €",
  },
];

const gridModels = models.slice(0, 3);
const carouselModels = models;

const comparisonModels = [
  {
    slug: "bungalow-22-134",
    name: "Bungalow 22-134",
    code: "BUNGALOW · 22-134",
    image: img("photo-1564013799919-ab600027ffc6"),
    imageAlt: "Eingeschossiger Bungalow mit Flachdach.",
    area: "134 m²",
    rooms: "4 Zimmer",
    efficiency: "KfW 40",
    buildTime: "12–14 Wochen",
    priceRange: "ab 290.000 €",
  },
  {
    slug: "einfamilienhaus-144-7",
    name: "Einfamilienhaus 144-7",
    code: "EINFAMILIENHAUS · 144-7",
    image: img("photo-1518780664697-55e3ad937233"),
    imageAlt: "Zweigeschossiges Einfamilienhaus.",
    area: "144 m²",
    rooms: "5 Zimmer",
    efficiency: "KfW 40 Plus",
    buildTime: "14–16 Wochen",
    priceRange: "ab 345.000 €",
  },
  {
    slug: "stadtvilla-180-3",
    name: "Stadtvilla 180-3",
    code: "STADTVILLA · 180-3",
    image: img("photo-1600596542815-ffad4c1539a9"),
    imageAlt: "Moderne Stadtvilla.",
    area: "180 m²",
    rooms: "6 Zimmer",
    efficiency: "KfW 40 Plus",
    buildTime: "16–18 Wochen",
    priceRange: "ab 420.000 €",
  },
];

const filterCategories = [
  { value: "alle", label: "Alle", count: 24 },
  { value: "bungalow", label: "Bungalow", count: 6 },
  { value: "einfamilien", label: "Einfamilienhaus", count: 9 },
  { value: "doppel", label: "Doppelhaus", count: 4 },
  { value: "stadt", label: "Stadtvilla", count: 3 },
  { value: "mehr", label: "Mehrfamilienhaus", count: 2 },
];

const filterSizes = [
  { value: "sm", label: "Bis 100 m²" },
  { value: "md", label: "100–150 m²" },
  { value: "lg", label: "150–200 m²" },
  { value: "xl", label: "Über 200 m²" },
];

const filterBudgets = [
  { value: "lo", label: "Bis 250.000 €" },
  { value: "mid", label: "250–400.000 €" },
  { value: "hi", label: "400–600.000 €" },
  { value: "top", label: "Über 600.000 €" },
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Sandbox — Catalog & Model Sections</title>
  </head>
  <body>
    <header class="faux-nav">BoHolz Haus — Catalog & Model Sections</header>

    <main class="wrapper">
      <section class="page-hero">
        <p class="page-eyebrow">Pack · Catalog</p>
        <h1>Katalog &amp; Modell-Sections</h1>
        <p class="page-lede">
          Drei Pflicht-Sections plus ein Stretch — alle auf den
          Design-System-Tokens, alle mobile-first.
        </p>
      </section>

      <!-- ══ S1 · HouseModelsGrid ═══════════════════════════════════════ -->
      <section class="group" id="grid">
        <Divider index={1} label="HouseModelsGrid" />
        <div class="stack">
          <header class="section-head">
            <Eyebrow>Hauser-Modelle</Eyebrow>
            <h2 class="section-title">
              Welche Häuser <span class="highlight">gibt es</span>?
            </h2>
            <p class="section-lede">
              Von kompaktem Tiny House bis Stadtvilla — jede Linie ist nach
              Wohnsituation und Effizienzklasse durchdacht.
            </p>
          </header>

          <HouseModelsGrid models={gridModels} columns={3} />
        </div>
      </section>

      <!-- ══ S2 · HouseModelsCarousel ═══════════════════════════════════ -->
      <section class="group" id="carousel">
        <Divider index={2} label="HouseModelsCarousel" />
        <div class="stack">
          <header class="section-head">
            <Eyebrow>Aktuelle Auswahl</Eyebrow>
            <h2 class="section-title">
              Sechs Modelle, <span class="highlight">eine Linie</span>.
            </h2>
            <p class="section-lede">
              Wischen Sie durch die Auswahl. Auf dem Desktop führen die Pfeile
              durch die Reihe.
            </p>
          </header>

          <HouseModelsCarousel
            client:load
            models={carouselModels}
            ariaLabel="Hausmodelle zum Durchsuchen"
          />
        </div>
      </section>

      <!-- ══ S3 · ComparisonStrip ═══════════════════════════════════════ -->
      <section class="group" id="compare">
        <Divider index={3} label="ComparisonStrip" />
        <div class="stack">
          <header class="section-head">
            <Eyebrow>Vergleich</Eyebrow>
            <h2 class="section-title">
              Drei Modelle, <span class="highlight">nebeneinander</span>.
            </h2>
            <p class="section-lede">
              Eckdaten in einer ruhigen, typografischen Tabelle — zum Lesen,
              nicht zum Verkaufen.
            </p>
          </header>

          <ComparisonStrip models={comparisonModels} />
        </div>
      </section>

      <!-- ══ S4 · FilterStrip + Grid (the stretch) ═════════════════════ -->
      <section class="group" id="filter">
        <Divider index={4} label="FilterStrip (Stretch)" />
        <div class="stack">
          <header class="section-head">
            <Eyebrow>Filter (Stretch)</Eyebrow>
            <h2 class="section-title">
              Filter über dem <span class="highlight">Katalog</span>.
            </h2>
            <p class="section-lede">
              Kategorie, Wohnfläche und Budget in einer ruhigen Zeile direkt
              über der Modellauswahl.
            </p>
          </header>

          <FilterStrip
            client:load
            categories={filterCategories}
            sizes={filterSizes}
            budgets={filterBudgets}
            activeCategory="alle"
          />

          <HouseModelsGrid
            models={[models[0], models[1], models[3], models[2], models[4], models[5]]}
            columns={3}
          />
        </div>
      </section>
    </main>

    <style>
      .faux-nav {
        position: sticky;
        top: 0;
        z-index: 50;
        padding: var(--spacing-2) var(--padding-inline);
        background: var(--clr-surface-primary);
        border-bottom: 1px solid var(--clr-border-secondary);
        font-size: var(--fs-body-sm);
        color: var(--clr-content-tertiary);
        letter-spacing: var(--tracking-eyebrow);
        text-transform: uppercase;
        font-weight: var(--font-weight-medium);
      }

      .page-hero {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-2);
        padding-block: var(--spacing-6) var(--spacing-5);
        max-width: 70ch;
      }

      .page-eyebrow {
        margin: 0;
        font-size: var(--fs-body-sm);
        font-weight: var(--font-weight-medium);
        letter-spacing: var(--tracking-eyebrow);
        text-transform: uppercase;
        color: var(--clr-content-tertiary);
      }

      .page-hero h1 {
        margin: 0;
        font-weight: var(--font-weight-light);
        letter-spacing: var(--ls-heading);
      }

      .page-lede {
        margin: 0;
        font-size: var(--fs-body-lg);
        color: var(--clr-content-secondary);
        line-height: var(--lh-body);
      }

      .group {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-4);
        padding-block: var(--spacing-5);
      }

      .stack {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-5);
      }

      .section-head {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-2);
        max-width: 70ch;
      }

      .section-title {
        margin: 0;
        font-weight: var(--font-weight-medium);
        letter-spacing: var(--ls-heading);
        line-height: var(--lh-heading);
      }

      .highlight {
        font-family: var(--font-secondary);
        font-style: italic;
        font-weight: var(--font-weight-regular);
      }

      .section-lede {
        margin: 0;
        color: var(--clr-content-secondary);
        font-size: var(--fs-body);
        max-width: 60ch;
      }
    </style>
  </body>
</html>
