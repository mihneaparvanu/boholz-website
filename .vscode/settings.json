{
  "svg.preview.background": "editor",
  "files.watcherExclude": {
    "**/public/to-organize/**": true,
    "**/public/sorted-assets/**": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/.git": true,
    "**.github/**": true,
    "**.vscode/**": true,
    "**.astro/**": true,
    "drizzle": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.expand": false,
  "explorer.fileNesting.patterns": {
    // Root config files nest under package.json
    "package.json": "package-lock.json, bun.lock, tsconfig.json, astro.config.mjs, drizzle.config.ts, postcss.config.cjs, prettierrc.mjs, Dockerfile, LICENSE, .gitignore, .node-version",
    // Docs nest under README.md
    "README.md": "agent.md, development.md, CLAUDE.md"
  },
  "python.terminal.useEnvFile": true,
  "astro.content-intellisense": true
}
