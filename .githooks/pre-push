#!/bin/bash
# Prevent /dev folder from being pushed to main branch.
# Pre-push hook receives <local_ref> <local_sha> <remote_ref> <remote_sha> on stdin.

while read -r local_ref local_sha remote_ref remote_sha; do
  # Only enforce when the destination ref is main
  if [[ "$remote_ref" != "refs/heads/main" ]]; then
    continue
  fi

  # New branch: diff against empty tree base; otherwise against the remote sha
  if [[ "$remote_sha" =~ ^0+$ ]]; then
    range="$local_sha"
    files=$(git diff-tree --no-commit-id --name-only -r "$local_sha")
  else
    range="$remote_sha..$local_sha"
    files=$(git diff --name-only "$range")
  fi

  if echo "$files" | grep -q "^dev/"; then
    echo "❌ Push rejected: /dev folder cannot be pushed to main branch"
    echo ""
    echo "The /dev folder is for development only and must stay on the dev branch."
    echo "Move any production-ready content out of /dev before pushing to main."
    exit 1
  fi
done

exit 0
